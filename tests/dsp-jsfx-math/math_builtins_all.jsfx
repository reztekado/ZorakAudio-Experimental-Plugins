desc:DSP-JSFX math builtin compile smoke

@init
x = 0.5;
y = -2.0;
z = 3.0;

math_builtin_sum =
    sin(x) + cos(x) + tan(x)
  + asin(x) + acos(x) + atan(x) + atan2(y, z)
  + sqr(y) + sqrt(z) + pow(z, x)
  + exp(x) + log(z) + log10(z)
  + abs(y) + min(y, z) + max(y, z) + sign(y)
  + rand(1) * 0
  + floor(3.9) + ceil(-3.9) + invsqrt(4)
  + $pi * 0 + $phi * 0 + $e * 0;

@sample
spl0 = spl0 + math_builtin_sum * 0;
spl1 = spl1 + math_builtin_sum * 0;
