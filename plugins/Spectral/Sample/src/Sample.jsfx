  gfx_slider_mask |= MASK_S21;
);
ui_button(405, onset_btn_x, btn_y3, onset_btn_w, btn_h) ? (
  slider23 = 1 - (slider23 | 0);
  gfx_slider_mask |= MASK_S23;
);

gfx_setfont(1, "Arial", 11, 0);
gfx_r = 0.92; gfx_g = 0.96; gfx_b = 1.0; gfx_a = 1;

(slider17 | 0) == 2 ? sprintf(#ui_buf, "Hybrid") : ((slider17 | 0) == 1 ? sprintf(#ui_buf, "Tape") : sprintf(#ui_buf, "Raw"));
draw_center_buf(mode_btn_x, btn_y1 + 9, btn_w);

(slider16 | 0) == 1 ? sprintf(#ui_buf, "Punch") : ((slider16 | 0) == 2 ? sprintf(#ui_buf, "Off") : sprintf(#ui_buf, "Auto"));
draw_center_buf(trans_btn_x, btn_y1 + 9, btn_w);

(slider13 | 0) == 2 ? sprintf(#ui_buf, "Walk") : ((slider13 | 0) == 1 ? sprintf(#ui_buf, "Sequence") : sprintf(#ui_buf, "Random"));
draw_center_buf(seq_btn_x, btn_y2 + 9, btn_w);

(slider21 | 0) ? sprintf(#ui_buf, "Mono Source") : sprintf(#ui_buf, "Stereo Source");
draw_center_buf(mono_btn_x, btn_y2 + 9, btn_w);

(slider23 | 0) ? sprintf(#ui_buf, "Gaussian Onset") : sprintf(#ui_buf, "Classic Onset");
draw_center_buf(onset_btn_x, btn_y3 + 9, onset_btn_w);

knob_panel_top = btn_y3 + btn_h + 18;
knob_panel_bottom = right_y + right_h - 18;
knob_area_h = max(140, knob_panel_bottom - knob_panel_top);
knob_count = 15;
knob_cols = right_inner_w >= 720 ? 6 : (right_inner_w >= 460 ? 4 : (right_inner_w >= 320 ? 3 : 2));
knob_rows = floor((knob_count + knob_cols - 1) / knob_cols);
knob_col_gap = clamp(floor(right_inner_w * 0.016), 10, 16);
knob_row_gap = 16;
cell_w = (right_inner_w - knob_col_gap * max(0, knob_cols - 1)) / knob_cols;
cell_h = floor((knob_area_h - knob_row_gap * max(0, knob_rows - 1)) / max(1, knob_rows));
cell_h = min(cell_h, knob_cols >= 6 ? 132 : 116);
kb_r = clamp(min(cell_w * 0.18, cell_h * 0.24), 18, knob_cols >= 6 ? 24 : 22);

// Pitch
grid_idx = 0;
cell_x = right_inner_x + (grid_idx % knob_cols) * (cell_w + knob_col_gap);
cell_y = knob_panel_top + floor(grid_idx / knob_cols) * (cell_h + knob_row_gap);
kc = cell_x + cell_w * 0.5; ky = cell_y + kb_r + 6; label_y = min(cell_y + cell_h - 12, ky + kb_r + 12);
nv = ui_knob(307, kc, ky, kb_r, slider12, -24, 24, 0, 0.021); abs(nv - slider12) > 0.0000001 ? (slider12 = nv; gfx_slider_mask |= MASK_S12;);
