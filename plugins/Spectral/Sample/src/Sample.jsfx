gfx_setfont(1, "Arial", 11, 0); gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1;
sprintf(#ui_buf, "Pitch"); draw_center_buf(cell_x, label_y, cell_w);

// Stretch
