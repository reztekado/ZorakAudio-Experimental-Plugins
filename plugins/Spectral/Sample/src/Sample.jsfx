gfx_r = 0.10; gfx_g = 0.58; gfx_b = 1.0; gfx_a = 0.90; gfx_circle(right_x + 10, right_y + 25, 4, 1);
gfx_r = 0.26; gfx_g = 0.62; gfx_b = 1.0; gfx_a = 0.35; gfx_line(right_x + 18, right_y + 39, right_x + right_w - 18, right_y + 39);

right_inner_x = right_x + 14;
right_inner_w = max(160, right_w - 28);
pt_in(right_x, right_y, right_w, 150) ? ui_hover_id = 1400;

btn_gap_x = 10;
btn_gap_y = 8;
btn_w = floor((right_inner_w - btn_gap_x) * 0.5);
btn_h = 30;
btn_y1 = right_y + 42;
btn_y2 = btn_y1 + btn_h + btn_gap_y;
btn_y3 = btn_y2 + btn_h + btn_gap_y;

mode_btn_x = right_inner_x;
trans_btn_x = right_inner_x + btn_w + btn_gap_x;
