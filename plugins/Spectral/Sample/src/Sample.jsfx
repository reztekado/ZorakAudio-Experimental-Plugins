room_gain_up_coeff = 0.001;
room_min_gain0 = 1;
room_min_gain1 = 1;
room_min_gain2 = 1;
room_min_gain3 = 1;
room_min_gain4 = 1;
room_head_bus = 0;
room_tail_bus = 0;

push_amt = 0;
push_active_prev = 0;
push_preserve = 0.82;
push_trans_w = 0;
push_side_w = 0;
push_max_common_dB = 0;
push_max_side_dB = 0;
push_broad_static_dB = 0;
push_lp15_c = 0.02;
push_lp32_c = 0.08;
push_lp55_c = 0.22;
push_a_lev = 0.001;
push_a_src = 0.001;
push_a_fast = 0.004;
push_a_slow = 0.0001;
push_common_att_coeff = 0.02;
push_common_rel_coeff = 0.002;
push_side_att_coeff = 0.01;
push_side_rel_coeff = 0.001;

slot_signature_loaded = -999999;
pending_signature = -999999;
rescan_pending = 0;
rescan_force = 0;
force_rescan_flag = 1;
poll_counter = 0;
poll_interval_samps = 22050;
rescan_flash = 0;
last_note = -1;
last_sid = -1;

ui_active = -1;
ui_down_y = 0;
ui_down_val = 0;
ui_prev_down = 0;
ui_prev_rdown = 0;
ui_value_changed = 0;
ui_hover_id = -1;
ui_wheel = 0;
ui_wheel_used = 0;
ui_now = 0;
ui_last_click_id = -1;
ui_last_click_t = -10;
ui_dblclick_time = 0.32;

mix_fast = 0;
mix_slow = 0;
tone_lp_l = 0;
tone_lp_r = 0;
focus_lp_l = 0;
focus_lp_r = 0;


tone_lp_coeff = 0.04;
focus_lp_coeff = 0.08;
env_att_coeff = 0.12;
env_rel_coeff = 0.01;
m2e_smooth_coeff = 0.002;
m2e_mode_coeff = 0.001;
m2e_detect_window_samps = 24000;
m2e_timeout_samps = 96000;
m2e_clock_samps = 0;
transient_guard_s = 0;
transport_running_prev = 0;
transport_playpos_prev = -1;
transport_play_state_prev = -1;

reset_bank_state();
m2e_reset();

@serialize
file_var(0, slope_schema);

@slider
attack_samps = max(1, floor(slider2 * srate * 0.001));
decay_samps = max(1, floor(slider3 * srate * 0.001));
sustain_level = clamp01(slider4);
release_samps = max(1, floor(slider5 * srate * 0.001));
hold_samps = max(0, floor(slider20 * srate * 0.001));
mono_source = (slider21 | 0) ? 1 : 0;
dynamics_amt = clamp01(slider22);
clean_amt = clamp01(slider25);
room_amt = clamp01(slider26);
push_amt = clamp01(slider27 / 100);
(slope_schema < 0.5) ? (
  slider28 = env_migrate_old_slope(slider28, ENV_RISE);
  slider29 = env_migrate_old_slope(slider29, ENV_FALL);
  slider30 = env_migrate_old_slope(slider30, ENV_FALL);
  slope_schema = 1;
  sliderchange(MASK_S28 + MASK_S29 + MASK_S30);
);
attack_slope_pct = clamp(slider28, -100, 100);
decay_slope_pct = clamp(slider29, -100, 100);
release_slope_pct = clamp(slider30, -100, 100);
(clean_amt <= 0.0001 && clean_active_prev > 0) ? reset_clean_buffers();
(room_amt <= 0.0001 && room_active_prev > 0) ? reset_room_buffers();
(push_amt <= 0.0001 && push_active_prev > 0) ? reset_push_buffers();
clean_active_prev = clean_amt > 0.0001 ? 1 : 0;
room_active_prev = room_amt > 0.0001 ? 1 : 0;
push_active_prev = push_amt > 0.0001 ? 1 : 0;
onset_mode_target = clamp(slider23 | 0, 0, 1);
bank_budget_mb = max(0, slider24);
attack_coef = attack_samps <= 1 ? 1 : (1 - exp(-6.90775527898214 / attack_samps));
decay_coef = decay_samps <= 1 ? 1 : (1 - exp(-6.90775527898214 / decay_samps));
release_coef = release_samps <= 1 ? 0 : exp(-6.90775527898214 / release_samps);
truth_mix = clamp01(slider10);
out_trim = db2amp(slider11);
pitch_semi = clamp(slider12, -24, 24);
selection_mode = clamp(slider13 | 0, 0, 2);
sequence_mode = selection_mode == 1 ? 1 : 0;
walk_mode = selection_mode == 2 ? 1 : 0;
stretch_ratio = clamp(slider14, 1, 4);
stretch_norm = clamp01((stretch_ratio - 1) / 3);
weight_amt = clamp01(slider15);
transient_mode = clamp(slider16 | 0, 0, 2);
playback_mode = clamp(slider17 | 0, 0, 2);
granular_amt = clamp01(slider18);
tail_borrow = clamp01(slider19);
poll_interval_samps = max(1024, floor(0.35 * srate));

stretch_grain_samps = clamp(floor(srate * lerp(0.024, 0.070, stretch_norm)), 192, 4096);
stretch_hop_samps = max(24, floor(stretch_grain_samps * lerp(0.34, 0.22, stretch_norm)));
hybrid_grain_samps = clamp(floor(srate * lerp(0.028, 0.090, granular_amt) * lerp(1.0, 1.30, stretch_norm)), 160, 4096);
hybrid_grain_samps = max(160, 4 * floor(hybrid_grain_samps / 4));
hybrid_hop_samps = max(20, floor(hybrid_grain_samps * 0.25));
hybrid_body_jitter = max(6, floor(hybrid_grain_samps * (0.04 + 0.18 * slider9)));
hybrid_tail_jitter = max(24, floor(hybrid_grain_samps * (0.16 + 0.28 * tail_borrow + 0.10 * slider9)));
release_handoff_samps = clamp(floor(min(release_samps * 0.30, max(srate * 0.020, hybrid_grain_samps * 0.70))), 32, floor(srate * 0.090));
seam_bridge_samps = clamp(
  floor(max(attack_samps * 0.85, min(release_samps * 0.30, srate * 0.18))),
  max(8, floor(srate * 0.012)),
  max(16, floor(srate * 0.420))
);
seam_bridge_release_coef = exp(-6.90775527898214 / max(1, seam_bridge_samps));

weight_scale = 1 + stretch_norm * 1.8;
weight_ap1_len = clamp(floor(srate * (0.0032 * weight_scale)), 16, AP_BUF_LEN - 1);
weight_ap2_len = clamp(floor(srate * (0.0066 * weight_scale)), 24, AP_BUF_LEN - 1);
weight_tap1 = clamp(floor(srate * (0.0085 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap2 = clamp(floor(srate * (0.0135 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap3 = clamp(floor(srate * (0.0205 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap4 = clamp(floor(srate * (0.0315 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap5 = clamp(floor(srate * (0.0470 * weight_scale)), 1, ER_BUF_LEN - 1);
weight_tap6 = clamp(floor(srate * (0.0680 * weight_scale)), 1, ER_BUF_LEN - 1);

weight_mix = weight_amt * (0.10 + 0.42 * max(stretch_norm, 0.35));
weight_body = weight_amt * (0.02 + 0.10 * max(stretch_norm, 0.25));
weight_sat = weight_amt * (0.01 + 0.05 * stretch_norm);
weight_ap_g1 = clamp(0.10 + weight_amt * (0.28 + 0.10 * stretch_norm), 0, 0.72);
weight_ap_g2 = clamp(0.08 + weight_amt * (0.25 + 0.14 * stretch_norm), 0, 0.72);
weight_in_coeff = clamp((1400 - 700 * stretch_norm) / max(srate, 1), 0.002, 0.12);
weight_wet_coeff = clamp((900 - 350 * stretch_norm) / max(srate, 1), 0.001, 0.08);

tone_lp_coeff = clamp(1900 / max(srate, 1), 0.005, 0.18);
focus_lp_coeff = clamp(4400 / max(srate, 1), 0.01, 0.40);
env_att_coeff = clamp(1200 / max(srate, 1), 0.02, 0.5);
env_rel_coeff = clamp(60 / max(srate, 1), 0.001, 0.12);
m2e_smooth_coeff = clamp(42 / max(srate, 1), 0.0006, 0.02);
m2e_mode_coeff = clamp(24 / max(srate, 1), 0.0004, 0.02);
m2e_detect_window_samps = max(1024, floor(0.75 * srate));
m2e_timeout_samps = max(2048, floor(1.7 * srate));

dyn_drive = 1 + dynamics_amt * 2.6;
dyn_thresh = lerp(0.98, 0.42, dynamics_amt);
dyn_ratio = lerp(1, 6.5, dynamics_amt);
dyn_makeup = 1 + dynamics_amt * 0.75;
dyn_sat_mix = dynamics_amt * (0.08 + 0.30 * dynamics_amt);
dyn_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.006 * srate)));
dyn_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.160 * srate)));
dyn_gain_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.004 * srate)));
dyn_gain_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.120 * srate)));
dyn_lim_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.0015 * srate)));
dyn_lim_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.070 * srate)));
dyn_ceiling = 0.985 - 0.01 * dynamics_amt;

clean_lp_c1 = clamp(1 - exp(-6.283185307179586 * 180 / max(srate, 1)), 0.0001, 0.60);
clean_lp_c2 = clamp(1 - exp(-6.283185307179586 * 720 / max(srate, 1)), 0.0002, 0.72);
clean_lp_c3 = clamp(1 - exp(-6.283185307179586 * 2600 / max(srate, 1)), 0.0005, 0.86);
clean_lp_c4 = clamp(1 - exp(-6.283185307179586 * 7800 / max(srate, 1)), 0.0010, 0.94);
clean_env_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.006 * srate)));
clean_env_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.520 * srate)));
clean_floor_up_coeff = 1 - exp(-6.90775527898214 / max(1, floor(4.200 * srate)));
clean_floor_down_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.280 * srate)));
clean_gain_down_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.018 * srate)));
clean_gain_up_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.140 * srate)));
clean_gain_protect_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.006 * srate)));
clean_thresh_floor = 1.18 + clean_amt * 3.10;
clean_thresh_env = 0.0035 + clean_amt * 0.022;
clean_abs_floor = 0.00000025 + clean_amt * 0.0000015;
clean_expand_pow = 0.85 + clean_amt * 2.15;
clean_min_gain = db2amp(-(2.0 + 12.0 * clean_amt));

room_lp_c1 = clamp(1 - exp(-6.283185307179586 * 220 / max(srate, 1)), 0.0001, 0.62);
room_lp_c2 = clamp(1 - exp(-6.283185307179586 * 950 / max(srate, 1)), 0.0002, 0.76);
room_lp_c3 = clamp(1 - exp(-6.283185307179586 * 3800 / max(srate, 1)), 0.0005, 0.88);
room_lp_c4 = clamp(1 - exp(-6.283185307179586 * 9000 / max(srate, 1)), 0.0010, 0.95);
room_env_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.010 * srate)));
room_env_fast_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.085 * srate)));
room_env_slow_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.180 * srate)));
room_env_slow_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.850 * srate)));
room_gain_down_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.026 * srate)));
room_gain_up_coeff = 1 - exp(-6.90775527898214 / max(1, floor(0.180 * srate)));
room_min_gain0 = db2amp(-(0.4 + 1.4 * room_amt));
room_min_gain1 = db2amp(-(1.0 + 5.4 * room_amt));
room_min_gain2 = db2amp(-(0.8 + 4.6 * room_amt));
room_min_gain3 = db2amp(-(0.5 + 2.8 * room_amt));
room_min_gain4 = db2amp(-(0.2 + 1.0 * room_amt));

push_lp15_c = clamp(1 - exp(-6.283185307179586 * min(1500, srate * 0.49) / max(srate, 1)), 0.0001, 0.80);
push_lp32_c = clamp(1 - exp(-6.283185307179586 * min(3200, srate * 0.49) / max(srate, 1)), 0.0002, 0.88);
push_lp55_c = clamp(1 - exp(-6.283185307179586 * min(5500, srate * 0.49) / max(srate, 1)), 0.0003, 0.93);
push_a_lev = 1 - exp(-1 / max(1, floor(0.110 * srate)));
push_a_src = 1 - exp(-1 / max(1, floor(0.160 * srate)));
push_a_fast = 1 - exp(-1 / max(1, floor(0.020 * srate)));
push_a_slow = 1 - exp(-1 / max(1, floor(0.520 * srate)));
push_preserve = clamp(0.82 - 0.52 * push_amt, 0.22, 0.82);
push_trans_w = (0.08 + 1.15 * push_amt) * (0.70 + 0.30 * (1 - push_preserve));
push_side_w = (0.45 + 0.90 * push_amt) * (1 - 0.35 * push_preserve);
push_max_common_dB = 18.0 * (push_amt ^ 1.10);
push_max_side_dB = 12.0 * (push_amt ^ 1.20);
push_broad_static_dB = 7.0 * push_amt * push_amt;
push_common_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.070 + 0.045 * (1 - push_amt)) * srate)));
push_common_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.750 + 1.650 * push_amt) * srate)));
push_side_att_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.110 + 0.060 * (1 - push_amt)) * srate)));
push_side_rel_coeff = 1 - exp(-6.90775527898214 / max(1, floor((0.900 + 1.900 * push_amt) * srate)));

(onset_mode_target != onset_mode_active) ? (
  onset_mode_active = onset_mode_target;
  sample_count > 0 ? (
    release_all_voices_transport(1);
    reanalyze_bank();
  );
);

((slider1 | 0) > 0) ? (
  force_rescan_flag = 1;
  slider1 = 0;
  sliderchange(MASK_S1);
);

@block
m2e_clock_samps += samplesblock;

// Transport panic/seek reconciliation. REAPER does not guarantee MIDI note-offs
// when playback is paused, stopped, or the edit cursor jumps while a note is
// sounding. Treat those discontinuities as an all-notes-off and hard-clear the
// sampler voices so held Hybrid/Tape notes cannot become orphaned.
transport_running = (play_state & 1) ? 1 : 0;
transport_paused = (play_state & 2) ? 1 : 0;
transport_stopped = play_state == 0;
transport_discontinuity = 0;

transport_play_state_prev < 0 ? (
  transport_play_state_prev = play_state;
  transport_playpos_prev = play_position;
);

transport_running && transport_playpos_prev >= 0 ? (
  transport_expected_pos = transport_playpos_prev + samplesblock / max(srate, 1);
  transport_seek_tol = max(0.050, 3 * samplesblock / max(srate, 1));
  abs(play_position - transport_expected_pos) > transport_seek_tol ? transport_discontinuity = 1;
);

((transport_paused || transport_stopped) && transport_running_prev) ? (
  transport_discontinuity = 1;
);

transport_discontinuity ? (
  release_all_voices_transport(1);
  seam_bridge_env = 0;
  seam_bridge_idx = -1;
  seam_bridge_phase = -1;
  seam_bridge_same_note = 0;
);

transport_running ? (
  transport_running_prev = 1;
  transport_playpos_prev = play_position;
) : (
  transport_running_prev = 0;
  transport_playpos_prev = -1;
);

transport_play_state_prev = play_state;

force_rescan_flag ? (
  poll_slot(1);
  force_rescan_flag = 0;
  poll_counter = 0;
);

poll_counter += samplesblock;
while (poll_counter >= poll_interval_samps) (
  poll_counter -= poll_interval_samps;
  poll_slot(0);
);

while (midirecv(offset, msg1, msg23)) (
  status = msg1 & 240;
  chan   = msg1 & 15;
  note   = msg23 & 127;
  vel    = (msg23 / 256) & 127;

  status == 176 ? (
    (chan == M2E_CHAN) ? (
      ccnum = note;
      ccval = vel;

      (ccnum >= M2E_BASE_FIXED && ccnum < (M2E_BASE_FIXED + M2E_LANE_COUNT)) ? (
        m2e_cc_age_base[ccnum] = m2e_clock_samps;
        m2e_cc_val_base[ccnum] = ccval;
        m2e_last_any_cc_samps = m2e_clock_samps;

        m2e_base = M2E_BASE_FIXED;
        m2e_last_msg_samps = m2e_clock_samps;
        m2e_apply_cc(m2e_base, ccnum, ccval);
      );
    );

    bank_loaded && (note == 120 || note == 123) ? (
      reset_note_gates();
      release_all_voices_transport(note == 120);
    );

    midisend(offset, msg1, msg23);
  ) : (
    (status == 144 && vel > 0) ? (
      bank_loaded ? (
        note_gate_on(note, chan);
        start_voice(note, vel, chan);
      ) : midisend(offset, msg1, msg23);
    ) : (
      (status == 128 || (status == 144 && vel == 0)) ? (
        bank_loaded ? (
          note_gate_off(note, chan);
          release_voice(note, chan);
        ) : midisend(offset, msg1, msg23);
      ) : (
        midisend(offset, msg1, msg23);
      );
    );
  );
);

cand_base = m2e_detect_base(m2e_clock_samps);
cand_base >= 0 ? (
  m2e_base = M2E_BASE_FIXED;
  m2e_decode_snapshot(m2e_base);
  m2e_active = 1;
);

(m2e_active && ((m2e_clock_samps - m2e_last_msg_samps) > m2e_timeout_samps)) ? (
  m2e_active = 0;
);

m2e_target = m2e_active ? 1 : 0;

rescan_pending ? (
  (!voices_busy() || rescan_force) ? (
    load_bank();
    slot_signature_loaded = pending_signature;
    rescan_pending = 0;
    rescan_force = 0;
  );
);

@sample
outL = 0;
outR = 0;
punch_bus = 0;
clean_head_bus = 0;
clean_tail_bus = 0;
room_head_bus = 0;
room_tail_bus = 0;

i = 0;
while (i < MAX_VOICES) (
  v = voice_base + i * VC_STRIDE;

  v[VC_ACTIVE] > 0 ? (
    sid = v[VC_SAMPLE] | 0;
    sm  = sample_meta_base + sid * SM_STRIDE;
    frames = sm[SM_FRAMES] | 0;
    ptr = sm[SM_PTR] | 0;
    nch = max(1, sm[SM_NCH] | 0);

    stage = v[VC_STAGE] | 0;
    tleft = max(0, floor(v[VC_TLEFT]));
    rel_handoff_left = max(0, floor(v[VC_RHLEFT]));
    rel_handoff_len = max(1, floor(v[VC_RHLEN]));
    rel_handoff_mix = 1 - rel_handoff_left / rel_handoff_len;
    body_start = max(0, floor(v[VC_BODYSTART]));
    tailstart = clamp(floor(v[VC_TAILSTART]), body_start, max(body_start, frames - 2));
    body_end = clamp(floor(v[VC_BODYEND]), body_start + 1, max(body_start + 1, frames - 2));

    hybrid_body_release = (v[VC_GMODE] > 0 && stage == ENV_RELEASE && v[VC_GMIX] > 0.0001) ? 1 : 0;
    hybrid_tail_release = (stage == ENV_RELEASE && !hybrid_body_release && v[VC_TAILMIX] > 0.0001) ? 1 : 0;

    // In Hybrid granular release, keep the body-grain engine running and let the
    // Release envelope do the fade. Only force the tail path when there is no
    // granular body layer available and Tail Borrow is acting as the release source.
    (v[VC_GMODE] > 0 && stage == ENV_RELEASE && !hybrid_body_release && rel_handoff_left <= 0) ? (
      v[VC_POS] < tailstart ? v[VC_POS] = tailstart;
      v[VC_NEXTSRC] < tailstart ? v[VC_NEXTSRC] = tailstart;
    );

    rawL = 0;
    rawR = 0;
    grainL = 0;
    grainR = 0;
    got_raw = 0;
    got_grain = 0;
    direct_alive = 0;
    activeg = 0;

    // Direct playback path always carries the head and the core identity.
    pos = v[VC_POS];
    held_body_only = (v[VC_GMODE] > 0 && (stage != ENV_RELEASE || hybrid_body_release));
    body_cutoff = max(body_start + 1, tailstart);
    held_body_only && pos >= body_cutoff ? (
      pos = body_cutoff;
      v[VC_POS] = pos;
    ) : (
      ip = pos | 0;
      ip < (frames - 1) ? (
        got_raw = sample_frame2(ptr, nch, pos);
        rawL = readL;
        rawR = readR;
        direct_alive = got_raw;

        play_rate = v[VC_RATE];
        voice_stretch = max(1, v[VC_STRETCH]);
        (tleft > 0 && voice_stretch > 1.01 && v[VC_TPROT] > 0) ? (
          holdn = clamp01(tleft / max(1, v[VC_THOLD]));
          holdn = holdn * holdn;
          play_rate *= 1 + (voice_stretch - 1) * holdn * v[VC_TPROT];
        );

        pos += play_rate;
        held_body_only && pos >= body_cutoff ? (
          pos = body_cutoff;
          direct_alive = 0;
        );
        v[VC_POS] = pos;
        pos >= (frames - 1) ? direct_alive = 0;
      );
    );

    tleft > 0 ? (
      tleft -= 1;
      v[VC_TLEFT] = tleft;
    );

    // Hybrid mode overlays granular body/tail material after the protected head.
    hybrid_release_only = hybrid_tail_release;
    (v[VC_GMODE] > 0 && (v[VC_GMIX] > 0.0001 || hybrid_release_only)) ? (
      (stage == ENV_RELEASE && !hybrid_body_release && rel_handoff_left <= 0) ? (
        v[VC_NEXTSRC] < tailstart ? v[VC_NEXTSRC] = tailstart;
      );

      gran_hold_guard = ((stage == ENV_ATTACK || stage == ENV_HOLD) && direct_alive) ? 1 : 0;
      (tleft <= 0 && !gran_hold_guard) ? (
        hop = max(1, floor(v[VC_OHOP]));
        gsize = max(hop + 1, floor(v[VC_GSIZE]));
        timer = floor(v[VC_GTIMER]) - 1;
        spawn_guard = 0;

        while (timer <= 0 && spawn_guard < NUM_GRAINS && v[VC_CANSPAWN] > 0) (
          gslot = -1;
          oldest = 0;
          oldest_age = -1;

          gk = 0;
          while (gk < NUM_GRAINS) (
            gb = v + VC_GBASE + gk * VG_STRIDE;
            gb[VG_ACTIVE] <= 0 ? (
              gslot = gk;
              gk = NUM_GRAINS;
            ) : (
              gb[VG_AGE] > oldest_age ? (
                oldest_age = gb[VG_AGE];
                oldest = gk;
              );
              gk += 1;
            );
          );

          gslot < 0 ? gslot = oldest;
          gb = v + VC_GBASE + gslot * VG_STRIDE;

          source_exhausted = !direct_alive && !(stage == ENV_RELEASE && !hybrid_body_release && rel_handoff_left > 0);
          gsid = sid;
          gsm = sm;
          gframes = frames;
          gsrc = body_start;
          grate = v[VC_RATE];
          ggain = 1;
          ghist_lo = body_start;
          ghist_hi = max(body_start + 1, body_end);

          (stage == ENV_RELEASE && !hybrid_body_release && rel_handoff_left <= 0) ? (
            donor_blend = clamp01(v[VC_TAILMIX]);
            self_lo = tailstart;
            self_hi = max(self_lo + 1, frames - 2);
            self_span = max(1, self_hi - self_lo);

            donor = v[VC_DONOR] | 0;
            donor < 0 ? donor = sid;
            donor_sm = sample_meta_base + donor * SM_STRIDE;
            donor_frames = donor_sm[SM_FRAMES] | 0;
            donor_tail = clamp(donor_sm[SM_TAILSTART], 0, max(0, donor_frames - 2));
            donor_hi = max(donor_tail + 1, donor_frames - 2);
            donor_phase = clamp01((max(v[VC_DONORPOS], donor_tail) - donor_tail) / max(1, donor_hi - donor_tail));
            self_phase = clamp01((max(v[VC_POS], tailstart) - tailstart) / max(1, self_hi - self_lo));
            tail_phase01 = max(self_phase, donor_phase);

            self_pos = choose_region_pos(i, sid, 1, tail_phase01, 0.28 + 0.46 * donor_blend + 0.14 * slider9);
            self_pen = grain_hist_penalty(i, sid, self_pos, self_lo, self_hi);

            alt_sid = donor_blend > 0.001 ? choose_region_donor(sid, 1, clamp01(donor_blend * 0.55 + self_pen * 0.10 + 0.18), i) : sid;
            alt_sid != sid ? (
              alt_pos = choose_region_pos(i, alt_sid, 1, tail_phase01, 0.42 + 0.46 * donor_blend + 0.18 * slider9);
              alt_sm = sample_meta_base + alt_sid * SM_STRIDE;
              alt_lo = clamp(alt_sm[SM_TAILSTART], 0, max(0, alt_sm[SM_FRAMES] - 2));
              alt_hi = max(alt_lo + 1, alt_sm[SM_FRAMES] - 2);
              alt_pen = grain_hist_penalty(i, alt_sid, alt_pos, alt_lo, alt_hi);

              (alt_pen > self_pen + 0.55 && sample_count > 2) ? (
                alt_sid2 = choose_region_donor(sid, 1, 1, i);
                (alt_sid2 != sid && alt_sid2 != alt_sid) ? (
                  alt_sm2 = sample_meta_base + alt_sid2 * SM_STRIDE;
                  alt_lo2 = clamp(alt_sm2[SM_TAILSTART], 0, max(0, alt_sm2[SM_FRAMES] - 2));
                  alt_hi2 = max(alt_lo2 + 1, alt_sm2[SM_FRAMES] - 2);
                  alt_pos2 = choose_region_pos(i, alt_sid2, 1, tail_phase01, 0.55 + 0.22 * slider9);
                  alt_pen2 = grain_hist_penalty(i, alt_sid2, alt_pos2, alt_lo2, alt_hi2);
                  alt_pen2 < alt_pen ? (
                    alt_sid = alt_sid2;
                    alt_sm = alt_sm2;
                    alt_lo = alt_lo2;
                    alt_hi = alt_hi2;
                    alt_pos = alt_pos2;
                    alt_pen = alt_pen2;
                  );
                );
              );

              use_alt = (alt_pen + 0.12 < self_pen) || (rand(1) < donor_blend * (0.42 + 0.14 * clamp01(self_pen * 0.30) + 0.12 * source_exhausted));
            ) : (
              use_alt = 0;
            );

            use_alt ? (
              gsid = alt_sid;
              gsm = alt_sm;
              gframes = gsm[SM_FRAMES] | 0;
              gsrc = alt_pos;
              grate = v[VC_RATE] * (gsm[SM_SR] / max(sm[SM_SR], 1));
              ggain = 0.90 + 0.10 * tail_phase01;
              ghist_lo = alt_lo;
              ghist_hi = alt_hi;
              v[VC_DONOR] = alt_sid;
              v[VC_DONORPOS] = min(max(alt_lo, alt_pos + hop * abs(grate) * (0.78 + 0.44 * rand(1))), max(alt_lo, alt_hi - 1));
            ) : (
              gsid = sid;
              gsm = sm;
              gframes = frames;
              gsrc = self_pos;
              grate = v[VC_RATE];
              ggain = 1;
              ghist_lo = self_lo;
              ghist_hi = self_hi;
              v[VC_DONOR] = sid;
              v[VC_DONORPOS] = min(max(self_lo, self_pos + hop * abs(grate) * (0.72 + 0.36 * rand(1))), max(self_lo, self_hi - 1));
            );
          ) : (
            grow_lo = body_start;
            grow_hi = min(max(grow_lo + 1, body_end), max(grow_lo + 1, frames - 2));
            grow_span = max(1, grow_hi - grow_lo);

            hybrid_body_release ? (
              // Release is one-way through the body window. Do not wrap back to
              // the start and do not widen to body donors; both can sound like a
              // second hit after a short one-shot has already finished.
              grow_cursor = clamp(v[VC_NEXTSRC], grow_lo, max(grow_lo, grow_hi - 1));
              grow_phase01 = clamp01((grow_cursor - grow_lo) / max(1, grow_span - 1));
              advance = v[VC_SRCHOP] * (0.72 + 0.22 * rand(1));
              nextsrc = grow_cursor + advance;
              wrapped = nextsrc >= grow_hi;
              wrapped ? (
                nextsrc = max(grow_lo, grow_hi - 1);
                v[VC_CANSPAWN] = 0;
              );
              v[VC_NEXTSRC] = nextsrc;
              source_exhausted = 0;

              release_jitter = min(max(2, floor(v[VC_GSIZE] * 0.08)), max(2, floor(grow_span * 0.10)));
              self_pos = clamp(grow_cursor + (rand(1) - 0.5) * release_jitter, grow_lo, max(grow_lo, grow_hi - 1));
              self_pen = 0;
            ) : (
              grow_cursor = wrap_in_range(v[VC_NEXTSRC], grow_lo, grow_hi);
              grow_phase01 = clamp01((grow_cursor - grow_lo) / max(1, grow_span - 1));
              advance = v[VC_SRCHOP] * (0.80 + 0.65 * rand(1));
              nextsrc = grow_cursor + advance;
              wrapped = nextsrc >= grow_hi;
              nextsrc = wrap_in_range(nextsrc, grow_lo, grow_hi);
              source_exhausted ? (
                nextsrc = wrap_in_range(nextsrc + (rand(1) - 0.5) * grow_span * 0.30, grow_lo, grow_hi);
              );
              v[VC_NEXTSRC] = nextsrc;

              self_pos = choose_region_pos(i, sid, 0, grow_phase01, 0.18 + 0.48 * slider9 + 0.22 * source_exhausted);
              self_pen = grain_hist_penalty(i, sid, self_pos, grow_lo, grow_hi);
            );

            need_alt = (!hybrid_body_release) && (source_exhausted || wrapped || (self_pen > 2.35) || (grow_span < max(64, floor(v[VC_GSIZE] * 0.55))));
            alt_sid = sid;
            alt_pen = 1000000000;

            need_alt && sample_count > 1 ? (
              alt_sid = choose_region_donor(sid, 0, clamp01(0.16 + 0.40 * source_exhausted + 0.20 * wrapped + 0.10 * slider9 + 0.08 * clamp01((self_pen - 1.2) * 0.6)), i);
              alt_sid != sid ? (
                alt_pos = choose_region_pos(i, alt_sid, 0, grow_phase01, 0.26 + 0.56 * slider9 + 0.24 * source_exhausted);
                alt_sm = sample_meta_base + alt_sid * SM_STRIDE;
                alt_lo = clamp(alt_sm[SM_HEADEND], 0, max(0, alt_sm[SM_TAILSTART] - 1));
                alt_hi = clamp(alt_sm[SM_TAILSTART], alt_lo + 1, max(alt_lo + 1, alt_sm[SM_FRAMES] - 2));
                alt_pen = grain_hist_penalty(i, alt_sid, alt_pos, alt_lo, alt_hi);

                (alt_pen > self_pen + 0.65 && sample_count > 2) ? (
                  alt_sid2 = choose_region_donor(sid, 0, 1, i);
                  (alt_sid2 != sid && alt_sid2 != alt_sid) ? (
                    alt_sm2 = sample_meta_base + alt_sid2 * SM_STRIDE;
                    alt_lo2 = clamp(alt_sm2[SM_HEADEND], 0, max(0, alt_sm2[SM_TAILSTART] - 1));
                    alt_hi2 = clamp(alt_sm2[SM_TAILSTART], alt_lo2 + 1, max(alt_lo2 + 1, alt_sm2[SM_FRAMES] - 2));
                    alt_pos2 = choose_region_pos(i, alt_sid2, 0, grow_phase01, 0.44 + 0.26 * slider9);
                    alt_pen2 = grain_hist_penalty(i, alt_sid2, alt_pos2, alt_lo2, alt_hi2);
                    alt_pen2 < alt_pen ? (
                      alt_sid = alt_sid2;
                      alt_sm = alt_sm2;
                      alt_lo = alt_lo2;
                      alt_hi = alt_hi2;
                      alt_pos = alt_pos2;
                      alt_pen = alt_pen2;
                    );
                  );
                );
              );
            );

            use_alt = (!hybrid_body_release) && (alt_sid != sid) && (source_exhausted || (alt_pen + 0.18 < self_pen) || (wrapped && rand(1) < 0.65));
            use_alt ? (
              gsid = alt_sid;
              gsm = alt_sm;
              gframes = gsm[SM_FRAMES] | 0;
              gsrc = alt_pos;
              grate = v[VC_RATE] * (gsm[SM_SR] / max(sm[SM_SR], 1));
              ggain = 0.95;
              ghist_lo = alt_lo;
              ghist_hi = alt_hi;
            ) : (
              gsid = sid;
              gsm = sm;
              gframes = frames;
              gsrc = self_pos;
              grate = v[VC_RATE];
              ggain = 1;
              ghist_lo = grow_lo;
              ghist_hi = grow_hi;
            );
          );

          gb[VG_ACTIVE] = 1;
          gb[VG_AGE] = 0;
          gb[VG_SRC] = gsrc;
          gb[VG_SID] = gsid;
          gb[VG_RATE] = grate;
          gb[VG_GAIN] = ggain;
          grain_hist_push(i, gsid, gsrc, ghist_lo, ghist_hi);

          timer += hop;
          spawn_guard += 1;
        );

        v[VC_GTIMER] = timer;

        sumL = 0;
        sumR = 0;
        sumW = 0;
        activeg = 0;

        gk = 0;
        while (gk < NUM_GRAINS) (
          gb = v + VC_GBASE + gk * VG_STRIDE;

          gb[VG_ACTIVE] > 0 ? (
            gsid = gb[VG_SID] | 0;
            gsm = sample_meta_base + gsid * SM_STRIDE;
            gptr = gsm[SM_PTR] | 0;
            gnch = max(1, gsm[SM_NCH] | 0);
            gframes = gsm[SM_FRAMES] | 0;
            age = gb[VG_AGE];
            gsize = max(1, floor(v[VC_GSIZE]));

            age < gsize ? (
              srcp = gb[VG_SRC] + age * gb[VG_RATE];

              srcp < (gframes - 1) ? (
                sample_frame2(gptr, gnch, srcp);
                gl = readL;
                gr = readR;

                w = stretch_window(age, gsize) * gb[VG_GAIN];
                sumL += gl * w;
                sumR += gr * w;
                sumW += w;
              );

              age += 1;
              gb[VG_AGE] = age;
              ((age >= gsize) || (srcp >= (gframes - 1))) ? (
                gb[VG_ACTIVE] = 0;
              ) : (
                activeg += 1;
              );
            ) : (
              gb[VG_ACTIVE] = 0;
            );
          );

          gk += 1;
        );

        sumW > 0 ? (
          // Do not normalize by the instantaneous overlap sum. That cancels the
          // window fade whenever only one grain is active and makes seams obvious.
          // Instead, target the COLA sum for a periodic Hann window at 25%% hop.
          ola_norm = max(2.0, sumW);
          grainL = sumL / ola_norm;
          grainR = sumR / ola_norm;
          got_grain = 1;
        );
      );
    );

    stage = v[VC_STAGE] | 0;
    env = v[VC_ENV];

    stage == ENV_ATTACK ? (
      (env_slope_is_classic(v[VC_ACURVE], ENV_RISE)) ? (
        env += (1 - env) * v[VC_ASTEP];
        env >= 0.999 ? (
          env = 1;
          stage = (v[VC_HLEFT] > 0) ? ENV_HOLD : ENV_DECAY;
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = env;
        );
      ) : (
        env_phase = v[VC_EPHASE] + 1;
        env_len = max(1, floor(v[VC_ALEN]));
        env_n = clamp01(env_phase / env_len);
        env = v[VC_ESTART] + (1 - v[VC_ESTART]) * env_slope_shape(env_n, env_segment_slope(v[VC_ACURVE], ENV_RISE));
        v[VC_EPHASE] = env_phase;
        (env_phase >= env_len || env >= 0.999) ? (
          env = 1;
          stage = (v[VC_HLEFT] > 0) ? ENV_HOLD : ENV_DECAY;
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = env;
        );
      );
    );

    stage == ENV_HOLD ? (
      env = 1;
      hleft = max(0, floor(v[VC_HLEFT]) - 1);
      v[VC_HLEFT] = hleft;
      hleft <= 0 ? (
        stage = ENV_DECAY;
        v[VC_EPHASE] = 0;
        v[VC_ESTART] = env;
      );
    );

    stage == ENV_DECAY ? (
      (env_slope_is_classic(v[VC_DCURVE], ENV_FALL)) ? (
        env += (sustain_level - env) * v[VC_DSTEP];
        abs(env - sustain_level) <= 0.0005 ? (
          env = sustain_level;
          stage = ENV_SUSTAIN;
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = env;
        );
      ) : (
        env_phase = v[VC_EPHASE] + 1;
        env_len = max(1, floor(v[VC_DLEN]));
        env_n = clamp01(env_phase / env_len);
        env = v[VC_ESTART] + (sustain_level - v[VC_ESTART]) * env_slope_shape(env_n, env_segment_slope(v[VC_DCURVE], ENV_FALL));
        v[VC_EPHASE] = env_phase;
        (env_phase >= env_len || abs(env - sustain_level) <= 0.0005) ? (
          env = sustain_level;
          stage = ENV_SUSTAIN;
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = env;
        );
      );
    );

    stage == ENV_SUSTAIN ? (
      env = sustain_level;
    );

    stage == ENV_RELEASE ? (
      rel_handoff_left > 0 ? (
        rel_handoff_left -= 1;
        v[VC_RHLEFT] = rel_handoff_left;
        rel_handoff_mix = 1 - rel_handoff_left / rel_handoff_len;
      );
      (env_slope_is_classic(v[VC_RCURVE], ENV_FALL)) ? (
        env *= v[VC_RSTEP];
      ) : (
        env_phase = v[VC_EPHASE] + 1;
        env_len = max(1, floor(v[VC_RLEN]));
        env_n = clamp01(env_phase / env_len);
        env = v[VC_ESTART] * (1 - env_slope_shape(env_n, env_segment_slope(v[VC_RCURVE], ENV_FALL)));
        v[VC_EPHASE] = env_phase;
      );
      (env <= 0.00005 || ((!env_slope_is_classic(v[VC_RCURVE], ENV_FALL)) && v[VC_EPHASE] >= max(1, floor(v[VC_RLEN])))) ? (
        env = 0;
        v[VC_ACTIVE] = 0;
        stage = ENV_OFF;
      );
    );

    v[VC_STAGE] = stage;
    v[VC_ENV] = env;

    got_sig = 0;
    mix = 0;
    got_raw && got_grain ? (
      tail_phase = clamp01((v[VC_POS] - tailstart) / max(1, frames - tailstart));
      prebody_mix = (stage == ENV_ATTACK || stage == ENV_HOLD) ? 0 : 1;
      mix = clamp(v[VC_GMIX] * prebody_mix * (0.18 + 0.18 * tail_phase + (stage == ENV_RELEASE ? 0.40 : 0)), 0, 0.90);
      stage == ENV_RELEASE ? (
        rel_release_mix = hybrid_body_release ? clamp01(0.32 + 0.46 * v[VC_GMIX] + 0.12 * slider9) : clamp01(0.10 + 0.22 * rel_handoff_mix + 0.68 * v[VC_TAILMIX]);
        mix = max(mix, rel_release_mix);
      );
      l = lerp(rawL, grainL, mix);
      r = lerp(rawR, grainR, mix);
      got_sig = 1;
    ) : got_raw ? (
      l = rawL;
      r = rawR;
      got_sig = 1;
    ) : got_grain ? (
      l = grainL;
      r = grainR;
      got_sig = 1;
    );

    g = v[VC_BASE] * env;
    keepalive = direct_alive || got_grain || activeg > 0 || (v[VC_GMODE] > 0 && stage != ENV_OFF && (stage != ENV_RELEASE || v[VC_CANSPAWN] > 0));

    (g > 0 && got_sig) ? (
      outL += l * g;
      outR += r * g;
      (v[VC_TLEFT] > 0) ? (
        punch_bus = max(punch_bus, v[VC_TPROT]);
        clean_head_bus = max(clean_head_bus, v[VC_TPROT]);
        room_head_bus = max(room_head_bus, v[VC_TPROT]);
      );
      (stage == ENV_HOLD && hold_samps > 0) ? (
        punch_bus = max(punch_bus, (0.18 + 0.32 * clamp01(v[VC_HLEFT] / max(1, hold_samps))) * (0.45 + 0.55 * max(0.25, v[VC_TPROT])));
        clean_head_bus = max(clean_head_bus, 0.22 * (0.45 + 0.55 * max(0.25, v[VC_TPROT])));
        room_head_bus = max(room_head_bus, 0.36 * (0.45 + 0.55 * max(0.25, v[VC_TPROT])));
      );
      clean_tail_score = 0;
      stage == ENV_RELEASE ? clean_tail_score = max(clean_tail_score, 0.82 + 0.18 * clamp01(v[VC_TAILMIX]));
      (v[VC_POS] >= tailstart && stage != ENV_ATTACK && stage != ENV_HOLD) ? clean_tail_score = max(clean_tail_score, 0.45);
      clean_tail_bus = max(clean_tail_bus, clean_tail_score * clamp01(env * 1.35));
      room_tail_bus = max(room_tail_bus, clean_tail_score * clamp01(env * 1.20));
    ) : (
      (!keepalive || stage == ENV_OFF) ? v[VC_ACTIVE] = 0;
    );
  );

  i += 1;
);

midm = abs(0.5 * (outL + outR));
mix_fast += (midm - mix_fast) * (midm > mix_fast ? env_att_coeff : env_rel_coeff);
mix_slow += (midm - mix_slow) * env_rel_coeff;
transient = clamp01((mix_fast - mix_slow) * 10);
transient_guard = clamp01(max(punch_bus, transient * (0.72 + 0.28 * punch_bus)));
transient_guard_s += (transient_guard - transient_guard_s) * (transient_guard > transient_guard_s ? 0.12 : 0.02);

m2e_mix += (m2e_target - m2e_mix) * m2e_mode_coeff;
m2e_env_s += (m2e_env_raw - m2e_env_s) * m2e_smooth_coeff;
m2e_rigid_s += (m2e_rigid_raw - m2e_rigid_s) * m2e_smooth_coeff;
m2e_impact_s += (m2e_impact_raw - m2e_impact_s) * m2e_smooth_coeff;
m2e_pan_s += (m2e_pan_raw - m2e_pan_s) * m2e_smooth_coeff;
m2e_entropy_s += (m2e_entropy_raw - m2e_entropy_s) * m2e_smooth_coeff;
m2e_axis_v_s += (m2e_axis_v_raw - m2e_axis_v_s) * m2e_smooth_coeff;
m2e_axis_acc_s += (m2e_axis_acc_raw - m2e_axis_acc_s) * m2e_smooth_coeff;
m2e_lat_v_s += (m2e_lat_v_raw - m2e_lat_v_s) * m2e_smooth_coeff;
m2e_lat_amp_s += (m2e_lat_amp_raw - m2e_lat_amp_s) * m2e_smooth_coeff;
m2e_micro_s += (m2e_micro_raw - m2e_micro_s) * m2e_smooth_coeff;
m2e_meso_s += (m2e_meso_raw - m2e_meso_s) * m2e_smooth_coeff;
m2e_macro_s += (m2e_macro_raw - m2e_macro_s) * m2e_smooth_coeff;
m2e_excite_s += (m2e_excite_raw - m2e_excite_s) * m2e_smooth_coeff;
m2e_activity_s += (m2e_activity_raw - m2e_activity_s) * m2e_smooth_coeff;

m2e_depth = m2e_mix * (0.22 + 0.78 * max(0.18, slider9));
m2e_depth *= (1 - 0.35 * m2e_rigid_s);
(playback_mode == 2) ? m2e_depth *= (0.94 - 0.12 * granular_amt * (0.55 + 0.45 * tail_borrow));
m2e_depth = clamp01(m2e_depth);
m2e_activity_hi = clamp01((m2e_activity_s - 1) / 3);

m2e_tone_bias =
  ((m2e_excite_s - 0.5) * 0.18
  + (m2e_micro_s - 0.5) * 0.10
  + (m2e_meso_s - 0.5) * 0.05
  - (m2e_macro_s - 0.5) * 0.12
  + (m2e_env_s - 0.5) * 0.06) * m2e_depth;

m2e_focus_bias =
  (m2e_impact_s * 0.22
  + abs(m2e_axis_acc_s) * 0.10
  + abs(m2e_axis_v_s) * 0.04
  + m2e_excite_s * 0.06
  - m2e_macro_s * 0.06) * m2e_depth;

m2e_width_bias =
  (m2e_lat_amp_s * 0.24
  + m2e_activity_hi * 0.12
  + m2e_excite_s * 0.10
  - m2e_rigid_s * 0.08
  - m2e_entropy_s * 0.04) * m2e_depth;

m2e_pan_bias =
  (((m2e_pan_s - 0.5) * 2) * 0.20
  + m2e_lat_v_s * 0.08
  + m2e_axis_v_s * 0.04) * m2e_depth;

m2e_body_bias =
  ((m2e_env_s - 0.5) * 0.10
  + m2e_impact_s * 0.08
  + m2e_excite_s * 0.06
  - m2e_macro_s * 0.04) * m2e_depth;

m2e_sat_mix =
  (m2e_impact_s * 0.26
  + m2e_excite_s * 0.18
  + abs(m2e_axis_acc_s) * 0.08
  + m2e_meso_s * 0.06) * m2e_depth;
m2e_sat_mix = min(clamp01(m2e_sat_mix), 0.22);

trans_mode_mix = 0.6;
transient_mode == 1 ? trans_mode_mix = 1
: transient_mode == 2 ? trans_mode_mix = 0;
m2e_transient_damp = clamp(1 - transient_guard_s * (0.52 + 0.28 * trans_mode_mix), 0.12, 1);
m2e_tone_bias *= 0.48 + 0.52 * m2e_transient_damp;
m2e_focus_bias *= 0.18 + 0.82 * m2e_transient_damp * m2e_transient_damp;
m2e_width_bias *= 0.62 + 0.38 * m2e_transient_damp;
m2e_pan_bias *= 0.30 + 0.70 * m2e_transient_damp;
m2e_body_bias *= 0.56 + 0.44 * m2e_transient_damp;
m2e_sat_mix *= 0.16 + 0.84 * m2e_transient_damp * m2e_transient_damp;

clean_amt > 0.0001 ? apply_cleaner();
room_amt > 0.0001 ? apply_room_tame();

tone_lp_l += (outL - tone_lp_l) * tone_lp_coeff;
tone_lp_r += (outR - tone_lp_r) * tone_lp_coeff;
focus_lp_l += (outL - focus_lp_l) * focus_lp_coeff;
focus_lp_r += (outR - focus_lp_r) * focus_lp_coeff;

tone_hp_l = outL - tone_lp_l;
tone_hp_r = outR - tone_lp_r;
focus_hp_l = outL - focus_lp_l;
focus_hp_r = outR - focus_lp_r;

tone_amt = clamp(slider6 + m2e_tone_bias, -1, 1);
focus_amt = clamp(slider7 + m2e_focus_bias, -1, 1);
width_amt = clamp(slider8 + m2e_width_bias, 0, 1);

outL += tone_amt * (tone_hp_l * 0.17 - tone_lp_l * 0.035);
outR += tone_amt * (tone_hp_r * 0.17 - tone_lp_r * 0.035);

focus_mix = focus_amt * (0.05 + transient * (0.11 + 0.08 * m2e_impact_s * m2e_depth));
outL += focus_hp_l * focus_mix;
outR += focus_hp_r * focus_mix;

mid = 0.5 * (outL + outR);
side = 0.5 * (outL - outR);
side *= 1 + width_amt * 0.22;
side += mid * m2e_pan_bias * 0.45;
mid *= 1 + m2e_body_bias;
outL = mid + side;
outR = mid - side;

satL = outL - (outL * outL * outL) * 0.1666666667;
satR = outR - (outR * outR * outR) * 0.1666666667;
outL = lerp(outL, satL, m2e_sat_mix);
outR = lerp(outR, satR, m2e_sat_mix);

weight_amt > 0.0001 ? (
  wmid = 0.5 * (outL + outR);
  wside = 0.5 * (outL - outR);

  weight_in_src_l = outL * 0.74 + wmid * 0.42 - wside * 0.06;
  weight_in_src_r = outR * 0.74 + wmid * 0.42 + wside * 0.06;

  weight_in_lp_l += (weight_in_src_l - weight_in_lp_l) * weight_in_coeff;
  weight_in_lp_r += (weight_in_src_r - weight_in_lp_r) * weight_in_coeff;

  ap_idx = weight_ap1_pos;
  ap_del = weight_ap1_l_base[ap_idx];
  ap1L = -weight_ap_g1 * weight_in_lp_l + ap_del;
  weight_ap1_l_base[ap_idx] = weight_in_lp_l + weight_ap_g1 * ap1L;
  ap_del = weight_ap1_r_base[ap_idx];
  ap1R = -weight_ap_g1 * weight_in_lp_r + ap_del;
  weight_ap1_r_base[ap_idx] = weight_in_lp_r + weight_ap_g1 * ap1R;
  weight_ap1_pos += 1;
  weight_ap1_pos >= weight_ap1_len ? weight_ap1_pos = 0;

  ap_idx = weight_ap2_pos;
  ap_del = weight_ap2_l_base[ap_idx];
  ap2L = -weight_ap_g2 * ap1L + ap_del;
  weight_ap2_l_base[ap_idx] = ap1L + weight_ap_g2 * ap2L;
  ap_del = weight_ap2_r_base[ap_idx];
  ap2R = -weight_ap_g2 * ap1R + ap_del;
  weight_ap2_r_base[ap_idx] = ap1R + weight_ap_g2 * ap2R;
  weight_ap2_pos += 1;
  weight_ap2_pos >= weight_ap2_len ? weight_ap2_pos = 0;

  er_idx = weight_er_pos;
  weight_er_l_base[er_idx] = ap2L;
  weight_er_r_base[er_idx] = ap2R;

  rd1 = er_idx - weight_tap1; rd1 < 0 ? rd1 += ER_BUF_LEN;
  rd2 = er_idx - weight_tap2; rd2 < 0 ? rd2 += ER_BUF_LEN;
  rd3 = er_idx - weight_tap3; rd3 < 0 ? rd3 += ER_BUF_LEN;
  rd4 = er_idx - weight_tap4; rd4 < 0 ? rd4 += ER_BUF_LEN;
  rd5 = er_idx - weight_tap5; rd5 < 0 ? rd5 += ER_BUF_LEN;
  rd6 = er_idx - weight_tap6; rd6 < 0 ? rd6 += ER_BUF_LEN;

  dl1 = weight_er_l_base[rd1]; dr1 = weight_er_r_base[rd1];
  dl2 = weight_er_l_base[rd2]; dr2 = weight_er_r_base[rd2];
  dl3 = weight_er_l_base[rd3]; dr3 = weight_er_r_base[rd3];
  dl4 = weight_er_l_base[rd4]; dr4 = weight_er_r_base[rd4];
  dl5 = weight_er_l_base[rd5]; dr5 = weight_er_r_base[rd5];
  dl6 = weight_er_l_base[rd6]; dr6 = weight_er_r_base[rd6];

  dm3 = 0.5 * (dl3 + dr3);
  dm6 = 0.5 * (dl6 + dr6);

  wetL = dl1 * 0.29 + dr2 * 0.22 + dm3 * 0.19 + dl4 * 0.14 + dr5 * 0.10 + dm6 * 0.07;
  wetR = dr1 * 0.29 + dl2 * 0.22 + dm3 * 0.19 + dr4 * 0.14 + dl5 * 0.10 + dm6 * 0.07;

  weight_er_pos += 1;
  weight_er_pos >= ER_BUF_LEN ? weight_er_pos = 0;

  weight_wet_lp_l += (wetL - weight_wet_lp_l) * weight_wet_coeff;
  weight_wet_lp_r += (wetR - weight_wet_lp_r) * weight_wet_coeff;

  wet_damp = 0.52 + 0.22 * stretch_norm;
  wetL = lerp(wetL, weight_wet_lp_l, wet_damp);
  wetR = lerp(wetR, weight_wet_lp_r, wet_damp);

  weight_duck = clamp(1 - transient_guard_s * (0.64 + 0.20 * trans_mode_mix + 0.08 * weight_amt), 0.14, 1);
  bloom = 0.5 * (weight_wet_lp_l + weight_wet_lp_r) * weight_body * (0.42 + 0.58 * weight_duck);
  outL += wetL * weight_mix * weight_duck + bloom;
  outR += wetR * weight_mix * weight_duck + bloom;

  heavySatL = outL - (outL * outL * outL) * 0.11;
  heavySatR = outR - (outR * outR * outR) * 0.11;
  outL = lerp(outL, heavySatL, weight_sat * (0.42 + 0.58 * weight_duck));
  outR = lerp(outR, heavySatR, weight_sat * (0.42 + 0.58 * weight_duck));
);

dynamics_amt > 0.0001 ? (
  dynL = outL * dyn_drive;
  dynR = outR * dyn_drive;

  dyn_det = max(abs(dynL), abs(dynR));
  dyn_env += (dyn_det - dyn_env) * (dyn_det > dyn_env ? dyn_att_coeff : dyn_rel_coeff);

  dyn_over = max(0, dyn_env - dyn_thresh);
  dyn_target_gain = dyn_over > 0 ? (dyn_thresh + dyn_over / dyn_ratio) / max(dyn_env, 0.000001) : 1;
  dyn_comp_gain += (dyn_target_gain - dyn_comp_gain) * (dyn_target_gain < dyn_comp_gain ? dyn_gain_att_coeff : dyn_gain_rel_coeff);

  dynL *= dyn_comp_gain;
  dynR *= dyn_comp_gain;

  dynSatL = dynL / (1 + abs(dynL));
  dynSatR = dynR / (1 + abs(dynR));
  dynL = lerp(dynL, dynSatL * 1.16, dyn_sat_mix);
  dynR = lerp(dynR, dynSatR * 1.16, dyn_sat_mix);

  dynL *= dyn_makeup;
  dynR *= dyn_makeup;

  dyn_post = max(abs(dynL), abs(dynR));
  dyn_lim_tgt = dyn_post > dyn_ceiling ? dyn_ceiling / dyn_post : 1;
  dyn_lim_gain += (dyn_lim_tgt - dyn_lim_gain) * (dyn_lim_tgt < dyn_lim_gain ? dyn_lim_att_coeff : dyn_lim_rel_coeff);

  outL = dynL * dyn_lim_gain;
  outR = dynR * dyn_lim_gain;
) : (
  dyn_env += (0 - dyn_env) * dyn_rel_coeff;
  dyn_comp_gain += (1 - dyn_comp_gain) * dyn_gain_rel_coeff;
  dyn_lim_gain += (1 - dyn_lim_gain) * dyn_lim_rel_coeff;
);

push_amt > 0.0001 ? apply_push();

spl0 += outL * out_trim;
spl1 += outR * out_trim;

@gfx 920 560
gfx_getchar();
mouse_down = mouse_cap & 1;
mouse_rdown = mouse_cap & 2;
ui_shift = (mouse_cap & 8) ? 1 : 0;
mouse_pressed = mouse_down && !ui_prev_down;
mouse_rpressed = mouse_rdown && !ui_prev_rdown;
ui_now = time_precise();
ui_wheel = mouse_wheel;
mouse_wheel = 0;
ui_wheel_used = 0;
ui_value_changed = 0;
ui_hover_id = -1;
gfx_slider_mask = 0;
sprintf(#tip_title, "");
sprintf(#tip_body, "");

// UI-side safety net: when REAPER stops/pause-freezes processing, @gfx can
// still run. Clear orphaned transport voices here too, but only after a prior
// running transport state, so live MIDI use while stopped is not affected.
gfx_transport_running = (play_state & 1) ? 1 : 0;
gfx_transport_paused = (play_state & 2) ? 1 : 0;
gfx_transport_stopped = play_state == 0;
((gfx_transport_paused || gfx_transport_stopped) && transport_running_prev) ? (
  // Inline hard panic for @gfx. Some JSFX builds do not resolve audio helper
  // functions from @gfx during compile, so keep this side-effect-only clear local.
  panic_i = 0;
  while (panic_i < MAX_VOICES) (
    panic_v = voice_base + panic_i * VC_STRIDE;
    panic_v[VC_ENV] = 0;
    panic_v[VC_STAGE] = ENV_OFF;
    panic_v[VC_ACTIVE] = 0;
    panic_i += 1;
  );

  panic_i = 0;
  while (panic_i < NOTE_GATE_CELLS) (
    note_gate_base[panic_i] = 0;
    panic_i += 1;
  );

  weight_ap1_pos = 0;
  weight_ap2_pos = 0;
  weight_er_pos = 0;
  weight_in_lp_l = 0;
  weight_in_lp_r = 0;
  weight_wet_lp_l = 0;
  weight_wet_lp_r = 0;
  panic_i = 0;
  while (panic_i < AP_BUF_LEN) (
    weight_ap1_l_base[panic_i] = 0;
    weight_ap1_r_base[panic_i] = 0;
    weight_ap2_l_base[panic_i] = 0;
    weight_ap2_r_base[panic_i] = 0;
    panic_i += 1;
  );
  panic_i = 0;
  while (panic_i < ER_BUF_LEN) (
    weight_er_l_base[panic_i] = 0;
    weight_er_r_base[panic_i] = 0;
    panic_i += 1;
  );

  clean_lp1_l = 0;
  clean_lp2_l = 0;
  clean_lp3_l = 0;
  clean_lp4_l = 0;
  clean_lp1_r = 0;
  clean_lp2_r = 0;
  clean_lp3_r = 0;
  clean_lp4_r = 0;
  clean_head_bus = 0;
  clean_tail_bus = 0;
  panic_i = 0;
  while (panic_i < CLEAN_BANDS) (
    clean_env_base[panic_i] = 0;
    clean_floor_base[panic_i] = 0;
    clean_gain_base[panic_i] = 1;
    panic_i += 1;
  );

  room_lp1_l = 0;
  room_lp2_l = 0;
  room_lp3_l = 0;
  room_lp4_l = 0;
  room_lp1_r = 0;
  room_lp2_r = 0;
  room_lp3_r = 0;
  room_lp4_r = 0;
  room_fast_env = 0;
  room_slow_env = 0;
  room_g0 = 1;
  room_g1 = 1;
  room_g2 = 1;
  room_g3 = 1;
  room_g4 = 1;
  room_head_bus = 0;
  room_tail_bus = 0;

  push_m_lp15 = 0;
  push_m_lp32 = 0;
  push_m_lp55 = 0;
  push_s_lp15 = 0;
  push_s_lp32 = 0;
  push_s_lp55 = 0;
  push_bodyE = 0;
  push_formE = 0;
  push_edgeE = 0;
  push_airE = 0;
  push_srcE = 0;
  push_m_hiE = 0;
  push_s_hiE = 0;
  push_click_fastE = 0;
  push_click_slowE = 0;
  push_common_dB = 0;
  push_side_dB = 0;
  push_hot_dB = -150;
  push_click_dB = 0;
  push_side_rel_dB = -150;

  transient_guard_s = 0;
  dyn_env = 0;
  dyn_comp_gain = 1;
  dyn_lim_gain = 1;
  mix_fast = 0;
  mix_slow = 0;

  seam_bridge_env = 0;
  seam_bridge_idx = -1;
  seam_bridge_phase = -1;
  seam_bridge_same_note = 0;
  transport_running_prev = 0;
  transport_playpos_prev = -1;
  transport_play_state_prev = play_state;
);

bg_r = 0.055; bg_g = 0.065; bg_b = 0.085;
gfx_r = bg_r; gfx_g = bg_g; gfx_b = bg_b; gfx_a = 1;
gfx_rect(0, 0, gfx_w, gfx_h, 1);

// Header
x0 = 18; y0 = 18;
header_h = 64;
gfx_r = 0.09; gfx_g = 0.11; gfx_b = 0.14; gfx_a = 1;
gfx_rect(x0, y0, gfx_w - 36, header_h, 1);
gfx_r = 0.18; gfx_g = 0.23; gfx_b = 0.29; gfx_a = 1;
gfx_rect(x0, y0, gfx_w - 36, header_h, 0);

gfx_setfont(1, "Arial", 24, 0);
gfx_x = x0 + 14; gfx_y = y0 + 10;
gfx_r = 0.92; gfx_g = 0.96; gfx_b = 1.0; gfx_a = 1;
gfx_drawstr("Load-and-Go MultiSampler");
pt_in(x0, y0, gfx_w - 36, header_h) ? ui_hover_id = 1001;

gfx_setfont(1, "Arial", 14, 0);
gfx_x = x0 + 16; gfx_y = y0 + 38;
gfx_r = 0.62; gfx_g = 0.71; gfx_b = 0.82; gfx_a = 1;
gfx_drawstr("Auto-polls slot 0, rescans on change, bank-wide triggering.");

lamp_x = gfx_w - 180;
lamp_y = y0 + 16;
status_on = bank_loaded ? 1 : 0;
bank_partial = bank_loaded && bank_selected_count > 0 && sample_count < bank_selected_count;
gfx_r = bank_partial ? 0.90 : (status_on ? 0.28 : 0.18);
gfx_g = bank_partial ? 0.66 : (status_on ? 0.80 : 0.20);
gfx_b = bank_partial ? 0.22 : (status_on ? 0.44 : 0.20);
gfx_a = 1;
gfx_circle(lamp_x, lamp_y + 12, 8, 1);
gfx_r = 0.85; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1;
gfx_x = lamp_x + 16; gfx_y = lamp_y + 2;
bank_partial ? sprintf(#ui_buf, "Bank partial") : (bank_loaded ? sprintf(#ui_buf, "Bank ready") : sprintf(#ui_buf, "No bank"));
gfx_drawstr(#ui_buf);

gfx_r = 0.72; gfx_g = 0.77; gfx_b = 0.84; gfx_a = 1;
gfx_x = gfx_w - 180; gfx_y = y0 + 36;
bank_partial ? (
  bank_memory_limited ? sprintf(#ui_buf, "Loaded %d/%d | %.0f MB", sample_count, bank_selected_count, pool_ram_mb) : (
    bank_cap_limited ? sprintf(#ui_buf, "Loaded %d/%d | pool max %d", sample_count, bank_selected_count, sample_pool_capacity) : sprintf(#ui_buf, "Loaded %d/%d | %.0f MB", sample_count, bank_selected_count, pool_ram_mb)
  )
) : (
  bank_loaded ? sprintf(#ui_buf, "Loaded %d/%d | %.0f MB", sample_count, max(bank_selected_count, sample_count), pool_ram_mb) : (
    rescan_pending ? (
      rescan_force ? sprintf(#ui_buf, "Rescan now") : sprintf(#ui_buf, "Rescan queued")
    ) : sprintf(#ui_buf, "Auto-rescan live")
  )
);
gfx_drawstr(#ui_buf);

m2e_lamp_x = gfx_w - 332;
m2e_lamp_y = y0 + 16;
m2e_recent = (m2e_clock_samps - m2e_last_any_cc_samps) <= m2e_detect_window_samps ? 1 : 0;
m2e_on = m2e_mix > 0.02 ? 1 : 0;
gfx_r = m2e_on ? 0.54 : (m2e_recent ? 0.76 : 0.20);
gfx_g = m2e_on ? 0.64 : (m2e_recent ? 0.54 : 0.20);
gfx_b = m2e_on ? 0.96 : (m2e_recent ? 0.22 : 0.22);
gfx_a = 1;
gfx_circle(m2e_lamp_x, m2e_lamp_y + 12, 8, 1);
gfx_r = 0.85; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1;
gfx_x = m2e_lamp_x + 16; gfx_y = m2e_lamp_y + 2;
m2e_on ? sprintf(#ui_buf, "FluxBridge live") : (m2e_recent ? sprintf(#ui_buf, "FluxBridge detect") : sprintf(#ui_buf, "FluxBridge idle"));
gfx_drawstr(#ui_buf);
gfx_r = 0.72; gfx_g = 0.77; gfx_b = 0.84; gfx_a = 1;
gfx_x = m2e_lamp_x + 16; gfx_y = m2e_lamp_y + 36;
sprintf(#ui_buf, "Auto-detect");
gfx_drawstr(#ui_buf);

pt_in(m2e_lamp_x - 8, m2e_lamp_y - 2, 160, 40) ? ui_hover_id = 1003;
pt_in(lamp_x - 8, lamp_y - 2, 150, 40) ? ui_hover_id = 1002;

// Panels - responsive layout
panel_gap = 18;
panel_total_w = gfx_w - 36;
panel_total_h = gfx_h - 118;

left_x = 18; left_y = 100;
left_w = clamp(floor(panel_total_w * 0.22), 200, 300);
mid_w  = clamp(floor(panel_total_w * 0.31), 260, 430);
right_w = panel_total_w - left_w - mid_w - panel_gap * 2;
right_min_w = 300;
right_target_max = panel_total_w >= 1280 ? 780 : 860;

right_w > right_target_max ? (
  excess = right_w - right_target_max;
  add_mid = min(excess * 0.65, max(0, 460 - mid_w));
  mid_w += add_mid;
  excess -= add_mid;
  add_left = min(excess, max(0, 330 - left_w));
  left_w += add_left;
  right_w = panel_total_w - left_w - mid_w - panel_gap * 2;
);

right_w < right_min_w ? (
  deficit = right_min_w - right_w;
  take_mid = min(deficit * 0.70, max(0, mid_w - 240));
  mid_w -= take_mid;
  deficit -= take_mid;
  take_left = min(deficit, max(0, left_w - 190));
  left_w -= take_left;
  right_w = panel_total_w - left_w - mid_w - panel_gap * 2;
);

mid_x = left_x + left_w + panel_gap; mid_y = left_y;
right_x = mid_x + mid_w + panel_gap; right_y = left_y;
left_h = panel_total_h;
mid_h = panel_total_h;
right_h = panel_total_h;

gfx_r = 0.085; gfx_g = 0.10; gfx_b = 0.125; gfx_a = 1;
gfx_rect(left_x, left_y, left_w, left_h, 1);
gfx_rect(mid_x, mid_y, mid_w, mid_h, 1);
gfx_rect(right_x, right_y, right_w, right_h, 1);
gfx_r = 0.18; gfx_g = 0.23; gfx_b = 0.29; gfx_a = 1;
gfx_rect(left_x, left_y, left_w, left_h, 0);
gfx_rect(mid_x, mid_y, mid_w, mid_h, 0);
gfx_rect(right_x, right_y, right_w, right_h, 0);

// Left panel: bank overview
gfx_setfont(1, "Arial", 18, 0);
gfx_r = 0.90; gfx_g = 0.95; gfx_b = 1.0; gfx_a = 1;
gfx_x = left_x + 14; gfx_y = left_y + 12;
gfx_drawstr("Bank overview");

gfx_setfont(1, "Arial", 14, 0);
bank_selected_count > 0 && sample_count < bank_selected_count ? sprintf(#ui_buf, "%d/%d samples loaded", sample_count, bank_selected_count) : sprintf(#ui_buf, "%d samples loaded", sample_count);
gfx_x = left_x + 14; gfx_y = left_y + 42; gfx_r = bank_partial ? 0.95 : 0.70; gfx_g = bank_partial ? 0.76 : 0.78; gfx_b = bank_partial ? 0.42 : 0.88;
gfx_drawstr(#ui_buf);

sprintf(#ui_buf, "%d voices active", count_active_voices());
gfx_x = left_x + 14; gfx_y = left_y + 62; gfx_drawstr(#ui_buf);

(last_sid >= 0) ? (
  selection_mode == 2 ? sprintf(#ui_buf, "Last sample %d | Walk", last_sid + 1) : (
    sequence_mode ? sprintf(#ui_buf, "Last sample %d | Seq", last_sid + 1) : sprintf(#ui_buf, "Last sample %d | Random", last_sid + 1)
  );
) : (
  selection_mode == 2 ? sprintf(#ui_buf, "Last sample -- | Walk") : (
    sequence_mode ? sprintf(#ui_buf, "Last sample -- | Seq") : sprintf(#ui_buf, "Last sample -- | Random")
  );
);
gfx_x = left_x + 14; gfx_y = left_y + 82; gfx_drawstr(#ui_buf);
pt_in(left_x + 10, left_y + 8, left_w - 20, 84) ? ui_hover_id = 1100;

meter_x = left_x + 14; meter_y = left_y + 122; meter_w = left_w - 28; meter_h = 12;
gfx_r = 0.12; gfx_g = 0.14; gfx_b = 0.18; gfx_a = 1;
gfx_rect(meter_x, meter_y, meter_w, meter_h, 1);
gfx_r = 0.24; gfx_g = 0.62; gfx_b = 0.89; gfx_a = 1;
gfx_rect(meter_x, meter_y, meter_w * bank_pitchiness, meter_h, 1);
gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
gfx_x = meter_x; gfx_y = meter_y - 20;
gfx_drawstr("Pitch confidence");
pt_in(meter_x, meter_y - 22, meter_w, meter_h + 26) ? ui_hover_id = 1101;

meter_y2 = meter_y + 52;
gfx_r = 0.12; gfx_g = 0.14; gfx_b = 0.18; gfx_a = 1;
gfx_rect(meter_x, meter_y2, meter_w, meter_h, 1);
gfx_r = 0.33; gfx_g = 0.67; gfx_b = 0.54; gfx_a = 1;
gfx_rect(meter_x, meter_y2, meter_w * bank_brightness, meter_h, 1);
gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
gfx_x = meter_x; gfx_y = meter_y2 - 20;
gfx_drawstr("Average brightness");
pt_in(meter_x, meter_y2 - 22, meter_w, meter_h + 26) ? ui_hover_id = 1102;

meter_y3 = meter_y2 + 52;
gfx_r = 0.12; gfx_g = 0.14; gfx_b = 0.18; gfx_a = 1;
gfx_rect(meter_x, meter_y3, meter_w, meter_h, 1);
gfx_r = 0.62; gfx_g = 0.54; gfx_b = 0.86; gfx_a = 1;
gfx_rect(meter_x, meter_y3, meter_w * bank_sharpness, meter_h, 1);
gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
gfx_x = meter_x; gfx_y = meter_y3 - 20;
gfx_drawstr("Average attack focus");
pt_in(meter_x, meter_y3 - 22, meter_w, meter_h + 26) ? ui_hover_id = 1103;

map_x = left_x + 14; map_y = left_y + 250; map_w = left_w - 28; map_h = max(80, left_h - 266);
gfx_r = 0.10; gfx_g = 0.12; gfx_b = 0.16; gfx_a = 1;
gfx_rect(map_x, map_y, map_w, map_h, 1);
gfx_r = 0.18; gfx_g = 0.23; gfx_b = 0.29; gfx_a = 1;
gfx_rect(map_x, map_y, map_w, map_h, 0);
gfx_x = map_x; gfx_y = map_y - 22; gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88;
gfx_drawstr("Sample map");
pt_in(map_x, map_y, map_w, map_h) ? (
  sample_count > 0 ? (
    hov_bw = map_w / max(sample_count, 1);
    hov_sid = clamp(floor((mouse_x - map_x) / max(hov_bw, 0.000001)), 0, sample_count - 1);
    ui_hover_id = 5000 + hov_sid;
  ) : ui_hover_id = 1200;
);

sample_count > 0 ? (
  bw = map_w / max(sample_count, 1);
  i = 0;
  while (i < sample_count) (
    sm = sample_meta_base + i * SM_STRIDE;
    rootn = clamp01((sm[SM_ROOT] - ROOT_LOW) / max(ROOT_HIGH - ROOT_LOW, 1));
    bright = sm[SM_BRIGHT];
    sharp = sm[SM_SHARP];
    bh = 10 + (map_h - 20) * clamp01(0.15 + bright * 0.85);
    bx = map_x + i * bw;
    by = map_y + map_h - bh - 4;
    gfx_r = lerp(0.18, 0.82, rootn);
    gfx_g = lerp(0.32, 0.72, sharp);
    gfx_b = lerp(0.50, 0.28, bright);
    gfx_a = (i == last_sid) ? 1 : 0.82;
    gfx_rect(bx + 1, by, max(1, bw - 2), bh, 1);
    i += 1;
  );
) : (
  gfx_r = 0.48; gfx_g = 0.54; gfx_b = 0.62; gfx_a = 1;
  gfx_x = map_x + 12; gfx_y = map_y + 12;
  gfx_drawstr("Drop a multi-file selection onto slot 0.");
);

// Mid panel: AHDSR graph and controls
gfx_setfont(1, "Arial", 18, 0);
gfx_r = 0.90; gfx_g = 0.95; gfx_b = 1.0; gfx_a = 1;
gfx_x = mid_x + 14; gfx_y = mid_y + 12;
gfx_drawstr("Envelope");
pt_in(mid_x, mid_y, mid_w, 34) ? ui_hover_id = 1300;

graph_x = mid_x + 16; graph_y = mid_y + 48; graph_w = mid_w - 32; graph_h = 190;
gfx_r = 0.10; gfx_g = 0.12; gfx_b = 0.16; gfx_a = 1;
gfx_rect(graph_x, graph_y, graph_w, graph_h, 1);
gfx_r = 0.18; gfx_g = 0.23; gfx_b = 0.29; gfx_a = 1;
gfx_rect(graph_x, graph_y, graph_w, graph_h, 0);

an = curve_norm(slider2, 0.1, 500, CURVE_TIME);
hn = slider20 <= 0.5 ? 0 : curve_norm(max(slider20, 1), 1, 2000, CURVE_TIME);
dn = curve_norm(slider3, 1, 5000, CURVE_TIME);
rn = curve_norm(slider5, 5, 5000, CURVE_TIME);
susn = 0.18;
sumw = an * 0.72 + hn * 0.55 + dn * 0.88 + susn + rn * 1.05 + 0.2;
p0x = graph_x + 14; p0y = graph_y + graph_h - 18;
p1x = p0x + (graph_w - 28) * (an * 0.72) / sumw; p1y = graph_y + 18;
p2x = p1x + (graph_w - 28) * (hn * 0.55) / sumw; p2y = p1y;
p3x = p2x + (graph_w - 28) * (dn * 0.88) / sumw; p3y = graph_y + graph_h - 18 - (graph_h - 36) * sustain_level;
p4x = p3x + (graph_w - 28) * susn / sumw; p4y = p3y;
p5x = graph_x + graph_w - 14; p5y = graph_y + graph_h - 18;

gfx_r = 0.18; gfx_g = 0.22; gfx_b = 0.28; gfx_a = 1;
gfx_line(graph_x + 14, graph_y + graph_h - 18, graph_x + graph_w - 14, graph_y + graph_h - 18);
gfx_line(graph_x + 14, graph_y + 18, graph_x + 14, graph_y + graph_h - 18);

gfx_r = 0.32; gfx_g = 0.67; gfx_b = 0.92; gfx_a = 1;
draw_curve_line(p0x, p0y, p1x, p1y, env_segment_slope(attack_slope_pct, ENV_RISE));
gfx_line(p1x, p1y, p2x, p2y);
draw_curve_line(p2x, p2y, p3x, p3y, env_segment_slope(decay_slope_pct, ENV_FALL));
gfx_line(p3x, p3y, p4x, p4y);
draw_curve_line(p4x, p4y, p5x, p5y, env_segment_slope(release_slope_pct, ENV_FALL));

for_y = graph_y + graph_h - 18 - (graph_h - 36) * sustain_level;
gfx_r = 0.26; gfx_g = 0.52; gfx_b = 0.74; gfx_a = 0.6;
gfx_line(graph_x + 14, for_y, graph_x + graph_w - 14, for_y);

gfx_setfont(1, "Arial", 14, 0);
gfx_r = 0.74; gfx_g = 0.80; gfx_b = 0.88; gfx_a = 1;
sprintf(#ui_buf, "A %.1f ms   H %.0f ms   D %.0f ms   S %.0f%%   R %.0f ms", slider2, slider20, slider3, slider4 * 100, slider5);
gfx_x = graph_x; gfx_y = graph_y + graph_h + 8;
gfx_drawstr(#ui_buf);
pt_in(graph_x, graph_y, graph_w, graph_h) ? ui_hover_id = 1301;

adsr_y = mid_y + 290;
adsr_h = max(120, mid_h - 310);
track_count = 5;
adsr_inner_w = mid_w - 40;
track_w = clamp(floor((adsr_inner_w - 14 * (track_count - 1)) / track_count), 20, 28);
track_gap = max(10, (adsr_inner_w - track_w * track_count) / max(1, track_count - 1));
track_x = mid_x + 20;

nv = ui_vslider(201, track_x, adsr_y, track_w, adsr_h, slider2, 0.1, 500, CURVE_TIME, 3, 0.020); abs(nv - slider2) > 0.0000001 ? (slider2 = nv; gfx_slider_mask |= MASK_S2;);
nv = ui_shift_wheel_slope(201, slider28, 100); abs(nv - slider28) > 0.0000001 ? (slider28 = nv; gfx_slider_mask |= MASK_S28;);
gfx_x = track_x + (track_w - 7) * 0.5; gfx_y = adsr_y + adsr_h + 12; gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1; gfx_drawstr("A");
sprintf(#ui_buf, "%.1f", slider2); gfx_x = track_x + (track_w - 18) * 0.5; gfx_y = adsr_y - 20; gfx_r = 0.70; gfx_g = 0.78; gfx_b = 0.88; gfx_drawstr(#ui_buf);

track_x += track_w + track_gap;
nv = ui_vslider(205, track_x, adsr_y, track_w, adsr_h, slider20, 0, 2000, CURVE_LINEAR, 20, 0.015); abs(nv - slider20) > 0.0000001 ? (slider20 = nv; gfx_slider_mask |= MASK_S20;);
gfx_x = track_x + (track_w - 7) * 0.5; gfx_y = adsr_y + adsr_h + 12; gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1; gfx_drawstr("H");
sprintf(#ui_buf, "%.0f", slider20); gfx_x = track_x + (track_w - 18) * 0.5; gfx_y = adsr_y - 20; gfx_r = 0.70; gfx_g = 0.78; gfx_b = 0.88; gfx_drawstr(#ui_buf);

track_x += track_w + track_gap;
nv = ui_vslider(202, track_x, adsr_y, track_w, adsr_h, slider3, 1, 5000, CURVE_TIME, 110, 0.020); abs(nv - slider3) > 0.0000001 ? (slider3 = nv; gfx_slider_mask |= MASK_S3;);
nv = ui_shift_wheel_slope(202, slider29, -100); abs(nv - slider29) > 0.0000001 ? (slider29 = nv; gfx_slider_mask |= MASK_S29;);
gfx_x = track_x + (track_w - 7) * 0.5; gfx_y = adsr_y + adsr_h + 12; gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1; gfx_drawstr("D");
sprintf(#ui_buf, "%.0f", slider3); gfx_x = track_x + (track_w - 18) * 0.5; gfx_y = adsr_y - 20; gfx_r = 0.70; gfx_g = 0.78; gfx_b = 0.88; gfx_drawstr(#ui_buf);

track_x += track_w + track_gap;
nv = ui_vslider(203, track_x, adsr_y, track_w, adsr_h, slider4, 0, 1, CURVE_SUSTAIN, 0.82, 0.018); abs(nv - slider4) > 0.0000001 ? (slider4 = nv; gfx_slider_mask |= MASK_S4;);
gfx_x = track_x + (track_w - 7) * 0.5; gfx_y = adsr_y + adsr_h + 12; gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1; gfx_drawstr("S");
sprintf(#ui_buf, "%.0f%%", slider4 * 100); gfx_x = track_x + (track_w - 28) * 0.5; gfx_y = adsr_y - 20; gfx_r = 0.70; gfx_g = 0.78; gfx_b = 0.88; gfx_drawstr(#ui_buf);

track_x += track_w + track_gap;
nv = ui_vslider(204, track_x, adsr_y, track_w, adsr_h, slider5, 5, 5000, CURVE_TIME, 180, 0.020); abs(nv - slider5) > 0.0000001 ? (slider5 = nv; gfx_slider_mask |= MASK_S5;);
nv = ui_shift_wheel_slope(204, slider30, -100); abs(nv - slider30) > 0.0000001 ? (slider30 = nv; gfx_slider_mask |= MASK_S30;);
gfx_x = track_x + (track_w - 7) * 0.5; gfx_y = adsr_y + adsr_h + 12; gfx_r = 0.86; gfx_g = 0.90; gfx_b = 0.96; gfx_a = 1; gfx_drawstr("R");
sprintf(#ui_buf, "%.0f", slider5); gfx_x = track_x + (track_w - 18) * 0.5; gfx_y = adsr_y - 20; gfx_r = 0.70; gfx_g = 0.78; gfx_b = 0.88; gfx_drawstr(#ui_buf);

// Right panel: playback controls
