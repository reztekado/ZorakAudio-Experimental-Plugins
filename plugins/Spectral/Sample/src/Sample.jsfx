desc:Load-and-Go Psycho MultiSampler (FluxBridge + tape + hybrid)
tags:instrument sampler ui

// Slot 0 is the load-and-go sample bank.
// Use the filename slot UI for this instrument and choose Open Multiple... on slot 0.
// #FILE: Sample Bank {Open Multiple... loads the whole bank into slot 0; the bank auto-rescans when the selection changes.}
filename:0,sample.wav

// #HELP: # Sample
// #HELP:
// #HELP: ## What it is
// #HELP: Sample is a load-and-go psycho multisampler: load files into slot 0, play notes, and shape the bank with compact macro controls.
// #HELP:
// #HELP: ## Quick start
// #HELP: 1. Insert Sample. 2. On slot 0, choose Open Multiple... and select files. 3. Play MIDI notes. 4. Choose Random, Sequence, or Walk. 5. Shape with Envelope, Playback, Clean, Room Tame, Push, and Output.
// #HELP:
// #HELP: ## Selection modes
// #HELP: Random picks from the full bank with anti-repeat weighting. Sequence steps through loaded files. Walk bridges from the previous sample using brightness, focus, transient richness, length, pitch confidence, body span, and tail span.
// #HELP:
// #HELP: ## Envelope
// #HELP: Attack, Hold, Decay, Sustain, and Release shape each trigger. Shift+Wheel on Attack, Decay, or Release changes slope from -100% to +100%; 0% is linear. Defaults preserve the original curve behavior.
// #HELP:
// #HELP: ## Playback engines
// #HELP: Raw plays the source directly. Tape uses the slower/heavier rate path. Hybrid keeps the head direct, sustains from body grains, can borrow matched tails, and can hand off Release level/body phase into the next Attack.
// #HELP:
// #HELP: ## Cleanup and depth
// #HELP: Clean reduces low-level hiss/room bed. Room Tame restrains late room smear. Push is a salience budget: higher values push the instrument farther back, with 100% as extreme background placement.
// #HELP:
// #HELP: ## Tone and feel
// #HELP: Color warms/brightens. Focus softens/clarifies. Width spreads safely. Liveliness adds variation. Truth moves from matched behavior toward raw sample individuality. Dynamics adds density with protection.
// #HELP:
// #HELP: ## FluxBridge
// #HELP: When the fixed FluxBridge CC lane block is present, Sample adds subtle motion-driven tone, focus, width, pan, and body contour while protecting transient-rich hits.
// #HELP:
// #HELP: ## Best uses
// #HELP: Fast one-shot banks, found-sound instruments, texture instruments, sketching, and exploratory sound design.
// #HELP:
// #HELP: ## Wrong tool
// #HELP: Use a traditional multisampler when you need exact key zones, velocity-layer authoring, or realistic note-by-note recreation.
// #HELP:
// #HELP: ## In one sentence
// #HELP: Sample turns a loose bank of audio files into a playable, variable instrument with almost no setup.

slider1:0<0,1,1{idle,rescan}>--Force rescan slot 0
slider2:3<0.1,500,0.1>--Attack (ms)
slider3:110<1,5000,1>--Decay (ms)
slider4:0.82<0,1,0.001>--Sustain level
slider5:180<5,5000,1>--Release (ms)
slider6:0<-1,1,0.001>--Color (-warmer / +brighter)
slider7:0<-1,1,0.001>--Focus (-softer / +clearer)
slider8:0.18<0,1,0.001>--Width
slider9:0.22<0,1,0.001>--Liveliness
slider10:0.30<0,1,0.001>--Truth (0=matched / 1=raw)
slider11:-9<-24,12,0.1>--Output (dB)
slider12:0<-24,24,0.01>--Pitch (semitones)
slider13:0<0,2,1{random,sequence,walk}>--Selection mode
slider14:1<1,4,0.001>--Stretch (x)
slider15:0<0,1,0.001>--Weight
slider16:0<0,2,1{auto,punch,off}>--Transient mode
slider17:1<0,2,1{raw,tape,hybrid}>--Playback mode
slider18:0.55<0,1,0.001>--Granular body
slider19:0.35<0,1,0.001>--Tail borrow
slider20:20<0,2000,1>--Hold (ms)
slider21:0<0,1,1{stereo,mono}>--Mono Source
slider22:0<0,1,0.001>--Dynamics
slider23:0<0,1,1{classic,gaussian}>--Onset align mode
slider24:0<0,65536,256>--Bank RAM Budget (MB, 0=unlimited)
slider25:0<0,1,0.001>--Clean
slider26:0<0,1,0.001>--Room Tame
slider27:0<0,100,0.1>--Push (%)
slider28:100<-100,100,1>--Attack slope (%)
slider29:-100<-100,100,1>--Decay slope (%)
slider30:-100<-100,100,1>--Release slope (%)
@init
/*
Runtime sample-pool API used here:
  pool  = sample_pool_from_slot(slot, #name);
  sample_pool_commit(pool);
  id    = sample_get(pool, index);
  value = sample_read_interp(pool, id, channel, phase);

Decoded audio is held outside JSFX mem[] as packed float32 by the runtime.
This keeps large banks from expanding into 64-bit JSFX double cells.

This instrument stays load-and-go:
- slot 0 is polled automatically
- sample_pool_generation() detects completed reloads
- the metadata rebuild is deferred until voices are idle
- no zones or bank metadata are required
*/

function clamp(x lo hi)
(
  min(hi, max(lo, x));
);

function clamp01(x)
(
  clamp(x, 0, 1);
);

function wrap_in_range(x lo hi) local(span)
(
  span = max(1, hi - lo);
  while (x < lo) (x += span;);
  while (x >= hi) (x -= span;);
  x;
);

function curve_denorm(norm vmin vmax mode) local(n ratio)
(
  n = clamp01(norm);
  mode == CURVE_TIME ? (
    ratio = max(vmax / max(vmin, 0.000001), 1.000001);
    exp(log(max(vmin, 0.000001)) + n * log(ratio));
  ) : mode == CURVE_SUSTAIN ? (
    sqrt(n);
  ) : (
    vmin + n * (vmax - vmin);
  );
);

function curve_norm(val vmin vmax mode) local(v ratio)
(
  v = clamp(val, vmin, vmax);
  mode == CURVE_TIME ? (
    ratio = max(vmax / max(vmin, 0.000001), 1.000001);
    clamp01(log(max(v, 0.000001) / max(vmin, 0.000001)) / log(ratio));
  ) : mode == CURVE_SUSTAIN ? (
    clamp01(v * v);
  ) : (
    clamp01((v - vmin) / max(vmax - vmin, 0.000001));
  );
);

function env_curve01(t) local(k d)
(
  k = ENV_VIS_SHAPE;
  d = 1 - exp(-k);
  d <= 0 ? clamp01(t) : (1 - exp(-k * clamp01(t))) / d;
);

function env_slope_shape(t slope_pct) local(n a p d)
(
  n = clamp01(t);
  a = clamp(slope_pct, -100, 100) / 100;

  abs(a) < 0.000001 ? (
    n;
  ) : a >= 0.999999 ? (
    // Full positive slope is the original one-pole envelope curve.
    env_curve01(n);
  ) : a > 0 ? (
    // Positive: fast start, slow finish.
    p = 1 + a * (ENV_VIS_SHAPE - 1);
    1 - ((1 - n) ^ p);
  ) : (
    // Negative: slow start, fast finish.
    p = 1 + (-a) * (ENV_VIS_SHAPE - 1);
    n ^ p;
  );
);

function env_slope_inv(y slope_pct) local(n a p d)
(
  n = clamp01(y);
  a = clamp(slope_pct, -100, 100) / 100;

  abs(a) < 0.000001 ? (
    n;
  ) : a >= 0.999999 ? (
    d = 1 - exp(-ENV_VIS_SHAPE);
    d <= 0 ? n : clamp01(-log(max(0.000000001, 1 - n * d)) / ENV_VIS_SHAPE);
  ) : a > 0 ? (
    p = 1 + a * (ENV_VIS_SHAPE - 1);
    1 - ((1 - n) ^ (1 / p));
  ) : (
    p = 1 + (-a) * (ENV_VIS_SHAPE - 1);
    n ^ (1 / p);
  );
);

function env_segment_slope(raw_slope polarity)
(
  clamp(raw_slope, -100, 100) * polarity;
);

function env_slope_is_classic(raw_slope polarity)
(
  env_segment_slope(raw_slope, polarity) >= 99.999;
);

function env_migrate_old_slope(v polarity)
(
  v == 0 ? (polarity == ENV_RISE ? 100 : -100)
  : v == 1 ? 0
  : v == 2 ? (polarity == ENV_RISE ? -70 : 70)
  : v == 3 ? (polarity == ENV_RISE ? 70 : -70)
  : v == 4 ? 0
  : v;
);

function stretch_window(age gsize) local(n denom)
(
  // Periodic Hann window for COLA-friendly grain overlap.
  // With a 25%% hop (4x overlap), the summed window is constant.
  n = clamp(age, 0, max(0, gsize - 1));
  denom = max(gsize, 1);
  0.5 - 0.5 * cos(6.283185307179586 * n / denom);
);

function lerp(a b t)
(
  a + (b-a)*t;
);

function db2amp(db)
(
  exp(db * 0.11512925464970229);
);

function midi_ratio(semi)
(
  exp(semi * 0.0577622650466621);
);

function cents_ratio(cents)
(
  exp(cents * 0.000577622650466621);
);

function cc_to_u01(cc)
(
  clamp01(cc / 127);
);

function cc_to_s11(cc)
(
  clamp((cc / 63.5) - 1, -1, 1);
);

function cc_to_ratio(cc)
(
  cc <= 63 ? (cc / 63) : (1 + ((cc - 64) / 63) * 3);
);

function m2e_apply_cc(base ccnum ccval) local(off)
(
  off = ccnum - base;

  off == 0  ? m2e_env_raw = cc_to_u01(ccval);
  off == 5  ? m2e_rigid_abs_raw = cc_to_u01(ccval);
  off == 6  ? m2e_rigid_rel_raw = cc_to_u01(ccval);
  off == 17 ? m2e_impact_raw = cc_to_u01(ccval);
  off == 18 ? m2e_pan_raw = cc_to_u01(ccval);
  off == 19 ? m2e_entropy_raw = cc_to_u01(ccval);
  off == 20 ? m2e_axis_v_raw = cc_to_s11(ccval);
  off == 21 ? m2e_axis_acc_raw = cc_to_s11(ccval);
  off == 24 ? m2e_lat_v_raw = cc_to_s11(ccval);
  off == 28 ? m2e_lat_amp_raw = cc_to_u01(ccval);
  off == 29 ? m2e_micro_raw = cc_to_u01(ccval);
  off == 31 ? m2e_meso_raw = cc_to_u01(ccval);
  off == 32 ? m2e_macro_raw = cc_to_u01(ccval);
  off == 33 ? m2e_excite_raw = cc_to_u01(ccval);
  off == 34 ? m2e_activity_raw = cc_to_ratio(ccval);

  m2e_rigid_raw = 0.5 * (m2e_rigid_abs_raw + m2e_rigid_rel_raw);
);

function m2e_decode_snapshot(base) local(i cc)
(
  i = 0;
  while (i < M2E_LANE_COUNT) (
    (m2e_clock_samps - m2e_cc_age_base[base + i]) <= (m2e_detect_window_samps * 4) ? (
      cc = clamp(m2e_cc_val_base[base + i], 0, 127);
      m2e_apply_cc(base, base + i, cc);
    );
    i += 1;
  );
);

function m2e_detect_base(now_samps) local(base k age count g0 g1 g2 g3 best best_count)
(
  best = -1;
  best_count = 0;

  base = M2E_BASE_MIN;
  while (base <= M2E_BASE_MAX) (
    count = 0;
    g0 = 0; g1 = 0; g2 = 0; g3 = 0;

    k = 0;
    while (k < M2E_LANE_COUNT) (
      age = now_samps - m2e_cc_age_base[base + k];
      age <= m2e_detect_window_samps ? (
        count += 1;
        k <= 4 ? g0 = 1;
        (k >= 15 && k <= 19) ? g1 = 1;
        (k >= 20 && k <= 28) ? g2 = 1;
        k >= 29 ? g3 = 1;
      );
      k += 1;
    );

    (g0 && g1 && g2 && g3 && (count > best_count)) ? (
      best_count = count;
      best = base;
    );

    base += 1;
  );

  m2e_detect_count = best_count;
  best_count >= M2E_DETECT_MIN ? best : -1;
);

function m2e_reset() local(i)
(
  i = 0;
  while (i < 128) (
    m2e_cc_age_base[i] = -1000000000;
    m2e_cc_val_base[i] = 0;
    i += 1;
  );

  m2e_base = M2E_BASE_FIXED;
  m2e_detect_count = 0;
  m2e_active = 0;
  m2e_last_msg_samps = -1000000000;
  m2e_last_any_cc_samps = -1000000000;
  m2e_target = 0;
  m2e_mix = 0;

  m2e_env_raw = 0.5;
  m2e_rigid_abs_raw = 0;
  m2e_rigid_rel_raw = 0;
  m2e_rigid_raw = 0;
  m2e_impact_raw = 0;
  m2e_pan_raw = 0.5;
  m2e_entropy_raw = 0;
  m2e_axis_v_raw = 0;
  m2e_axis_acc_raw = 0;
  m2e_lat_v_raw = 0;
  m2e_lat_amp_raw = 0;
  m2e_micro_raw = 0;
  m2e_meso_raw = 0;
  m2e_macro_raw = 0;
  m2e_excite_raw = 0;
  m2e_activity_raw = 1;

  m2e_env_s = m2e_env_raw;
  m2e_rigid_s = m2e_rigid_raw;
  m2e_impact_s = m2e_impact_raw;
  m2e_pan_s = m2e_pan_raw;
  m2e_entropy_s = m2e_entropy_raw;
  m2e_axis_v_s = m2e_axis_v_raw;
  m2e_axis_acc_s = m2e_axis_acc_raw;
  m2e_lat_v_s = m2e_lat_v_raw;
  m2e_lat_amp_s = m2e_lat_amp_raw;
  m2e_micro_s = m2e_micro_raw;
  m2e_meso_s = m2e_meso_raw;
  m2e_macro_s = m2e_macro_raw;
  m2e_excite_s = m2e_excite_raw;
  m2e_activity_s = m2e_activity_raw;
);

function mono_frame(ptr nch frame) local(l r)
(
  // SM_PTR stores a runtime sample-pool ID, not a mem[] pointer.
  nch >= 2 ? (
    l = sample_read(bank_pool, ptr, 0, frame);
    r = sample_read(bank_pool, ptr, 1, frame);
    0.5 * (l + r);
  ) : (
    sample_read(bank_pool, ptr, 0, frame);
  );
);

function sample_frame2(ptr nch phase) local(ok l r)
(
  ok = sample_read2_interp(bank_pool, ptr, phase, l, r);
  mono_source ? (
    l = 0.5 * (l + r);
    r = l;
  );
  readL = l;
  readR = r;
  ok;
);

function pt_in(x y w h)
(
  mouse_x >= x && mouse_x <= (x + w) && mouse_y >= y && mouse_y <= (y + h);
);

function recent_penalty(sample_id) local(i pen)
(
  pen = 0;
  i = 0;
  while (i < RECENT_LEN) (
    recent_base[i] == sample_id ? pen += (RECENT_LEN - i);
    i += 1;
  );
  pen;
);

function push_recent(sample_id) local(i)
(
  i = RECENT_LEN - 1;
  while (i > 0) (
    recent_base[i] = recent_base[i-1];
    i -= 1;
  );
  recent_base[0] = sample_id;
);

function grain_hist_clear_voice(vix) local(base j)
(
  base = vix * GRAIN_HIST_LEN;
  j = 0;
  while (j < GRAIN_HIST_LEN) (
    grain_hist_sid_base[base + j] = -1;
    grain_hist_pos_base[base + j] = -1000000;
    grain_hist_phase_base[base + j] = -1;
    j += 1;
  );
);

function reset_grain_histories() local(vix)
(
  vix = 0;
  while (vix < MAX_VOICES) (
    grain_hist_clear_voice(vix);
    vix += 1;
  );
);

function grain_hist_push(vix sid pos lo hi) local(base j span phasebin)
(
  span = max(1, hi - lo);
  phasebin = min(GRAIN_PHASE_BINS - 1, max(0, floor(clamp01((pos - lo) / max(1, span - 1)) * GRAIN_PHASE_BINS)));
  base = vix * GRAIN_HIST_LEN;
  j = GRAIN_HIST_LEN - 1;
  while (j > 0) (
    grain_hist_sid_base[base + j] = grain_hist_sid_base[base + j - 1];
    grain_hist_pos_base[base + j] = grain_hist_pos_base[base + j - 1];
    grain_hist_phase_base[base + j] = grain_hist_phase_base[base + j - 1];
    j -= 1;
  );
  grain_hist_sid_base[base] = sid;
  grain_hist_pos_base[base] = pos;
  grain_hist_phase_base[base] = phasebin;
);

function grain_sid_penalty(vix sid) local(base j pen)
(
  pen = 0;
  base = vix * GRAIN_HIST_LEN;
  j = 0;
  while (j < GRAIN_HIST_LEN) (
    grain_hist_sid_base[base + j] == sid ? pen += (GRAIN_HIST_LEN - j) * 0.22;
    j += 1;
  );
  pen;
);

function grain_hist_penalty(vix sid pos lo hi) local(base j pen span phasebin hsid hpos hbin near1 near2)
(
  pen = 0;
  span = max(1, hi - lo);
  phasebin = min(GRAIN_PHASE_BINS - 1, max(0, floor(clamp01((pos - lo) / max(1, span - 1)) * GRAIN_PHASE_BINS)));
  near1 = max(12, floor(span * 0.09));
  near2 = max(24, floor(span * 0.18));
  base = vix * GRAIN_HIST_LEN;
  j = 0;
  while (j < GRAIN_HIST_LEN) (
    hsid = grain_hist_sid_base[base + j] | 0;
    hsid >= 0 ? (
      hpos = grain_hist_pos_base[base + j];
      hbin = grain_hist_phase_base[base + j] | 0;
      hsid == sid ? pen += (GRAIN_HIST_LEN - j) * 0.16;
      hbin == phasebin ? pen += (GRAIN_HIST_LEN - j) * 0.06;
      (hsid == sid && abs(pos - hpos) < near2) ? pen += (GRAIN_HIST_LEN - j) * 0.22;
      (hsid == sid && abs(pos - hpos) < near1) ? pen += (GRAIN_HIST_LEN - j) * 0.38;
      (hsid == sid && hbin == phasebin) ? pen += (GRAIN_HIST_LEN - j) * 0.14;
    );
    j += 1;
  );
  pen;
);


function update_sample_cluster(sm) local(br sh tr len pitch len_norm pitch_norm)
(
  // Compact descriptor-bin cluster for Walk mode.
  // It is intentionally cheap: brightness, attack focus, transient richness, length, and pitch bin.
  br = min(3, max(0, floor(clamp01(sm[SM_BRIGHT]) * 4)));
  sh = min(3, max(0, floor(clamp01(sm[SM_SHARP]) * 4)));
  tr = min(3, max(0, floor(clamp01(sm[SM_FLAGS]) * 4)));
  len_norm = clamp01(log(sm[SM_LENMS] + 1) / log(5001));
  len = min(4, max(0, floor(len_norm * 5)));
  pitch_norm = clamp01((sm[SM_ROOT] - ROOT_LOW) / max(ROOT_HIGH - ROOT_LOW, 1));
  pitch = sm[SM_PITCHCONF] > 0.55 ? min(5, max(0, floor(pitch_norm * 6))) : 0;

  sm[SM_CLUSTER] = br + sh * 4 + tr * 16 + len * 64 + pitch * 320;
);

function walk_cluster_distance(a b) local(
  ca cb
  abr ash atr alen apit
  bbr bsh btr blen bpit
)
(
  ca = a[SM_CLUSTER] | 0;
  cb = b[SM_CLUSTER] | 0;

  abr = ca % 4; ca = floor(ca / 4);
  ash = ca % 4; ca = floor(ca / 4);
  atr = ca % 4; ca = floor(ca / 4);
  alen = ca % 5; ca = floor(ca / 5);
  apit = ca % 6;

  bbr = cb % 4; cb = floor(cb / 4);
  bsh = cb % 4; cb = floor(cb / 4);
  btr = cb % 4; cb = floor(cb / 4);
  blen = cb % 5; cb = floor(cb / 5);
  bpit = cb % 6;

  abs(abr - bbr) * 0.12
  + abs(ash - bsh) * 0.13
  + abs(atr - btr) * 0.10
  + abs(alen - blen) * 0.10
  + abs(apit - bpit) * (bank_pitchiness > 0.35 ? 0.055 : 0.018);
);

function sample_descriptor_distance(a b region_mode) local(
  brighterr sharperr transerr lenerr pitcherr regionerr clustererr
  aspan bspan
)
(
  brighterr = abs(a[SM_BRIGHT] - b[SM_BRIGHT]);
  sharperr  = abs(a[SM_SHARP] - b[SM_SHARP]);
  transerr  = abs(a[SM_FLAGS] - b[SM_FLAGS]);
  lenerr    = min(1.8, abs(log((a[SM_LENMS] + 1) / (b[SM_LENMS] + 1))));

  pitcherr = 0;
  (a[SM_PITCHCONF] > 0.45 && b[SM_PITCHCONF] > 0.45) ? (
    pitcherr = min(1.5, abs(a[SM_ROOT] - b[SM_ROOT]) / 24);
  );

  region_mode ? (
    aspan = max(1, a[SM_FRAMES] - a[SM_TAILSTART]) / max(1, a[SM_FRAMES]);
    bspan = max(1, b[SM_FRAMES] - b[SM_TAILSTART]) / max(1, b[SM_FRAMES]);
  ) : (
    aspan = max(1, a[SM_TAILSTART] - a[SM_HEADEND]) / max(1, a[SM_FRAMES]);
    bspan = max(1, b[SM_TAILSTART] - b[SM_HEADEND]) / max(1, b[SM_FRAMES]);
  );
  regionerr = abs(aspan - bspan);

  clustererr = walk_cluster_distance(a, b);

  brighterr * 0.80
  + sharperr * 0.88
  + transerr * 0.66
  + lenerr * 0.22
  + regionerr * 0.55
  + pitcherr * (0.10 + 0.36 * bank_pitchiness)
  + clustererr * 0.38;
);

function choose_random_sample(note velnorm) local(
  i sm sid score bright_t brighterr sharp_t sharperr
  rep rep_scale totalw pick accum weight temp
)
(
  sample_count <= 0 ? 0 : (
    bright_t = clamp01(0.5 + slider6 * 0.20 + (velnorm - 0.5) * 0.06);
    sharp_t  = clamp01(0.48 + slider7 * 0.22 + (velnorm - 0.5) * 0.10);
    rep_scale = 0.30 + slider9 * 1.45;
    temp = lerp(4.0, 1.4, slider9);
    totalw = 0;

    i = 0;
    while (i < sample_count) (
      sm = sample_meta_base + i * SM_STRIDE;
      brighterr = abs(sm[SM_BRIGHT] - bright_t);
      sharperr  = abs(sm[SM_SHARP] - sharp_t);
      score = brighterr * 0.95 + sharperr * 1.10;
      score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);
      weight = 0.15 + exp(-score * temp);
      totalw += weight;
      i += 1;
    );

    totalw <= 0 ? (
      floor(rand(max(sample_count, 1)));
    ) : (
      pick = rand(totalw);
      accum = 0;
      sid = sample_count - 1;
      i = 0;
      while (i < sample_count) (
        sm = sample_meta_base + i * SM_STRIDE;
        brighterr = abs(sm[SM_BRIGHT] - bright_t);
        sharperr  = abs(sm[SM_SHARP] - sharp_t);
        score = brighterr * 0.95 + sharperr * 1.10;
        score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);
        weight = 0.15 + exp(-score * temp);
        accum += weight;
        accum >= pick ? (
          sid = i;
          i = sample_count;
        ) : i += 1;
      );
      sid;
    );
  );
);

function choose_walk_sample(note velnorm) local(
  i sm sid lastsm prevsm
  score bright_t sharperr brighterr toneerr
  dlast dprev clustererr target jump too_close prev_bounce
  rep rep_scale totalw pick accum weight temp
)
(
  sample_count <= 0 ? 0 : (
    (walk_last_sid < 0 || walk_last_sid >= sample_count || sample_count <= 1) ? (
      choose_random_sample(note, velnorm);
    ) : (
      lastsm = sample_meta_base + walk_last_sid * SM_STRIDE;
      prevsm = (walk_prev_sid >= 0 && walk_prev_sid < sample_count) ? (sample_meta_base + walk_prev_sid * SM_STRIDE) : lastsm;

      bright_t = clamp01(0.5 + slider6 * 0.18 + (velnorm - 0.5) * 0.05);
      target = 0.16 + slider9 * 0.30 + truth_mix * 0.06;
      rep_scale = 0.45 + slider9 * 1.30;
      temp = lerp(7.2, 2.0, slider9);
      totalw = 0;

      i = 0;
      while (i < sample_count) (
        i != walk_last_sid ? (
          sm = sample_meta_base + i * SM_STRIDE;

          dlast = sample_descriptor_distance(lastsm, sm, 0);
          dprev = sample_descriptor_distance(prevsm, sm, 0);
          clustererr = walk_cluster_distance(lastsm, sm);

          brighterr = abs(sm[SM_BRIGHT] - bright_t);
          sharperr  = abs(sm[SM_SHARP] - clamp01(lastsm[SM_SHARP] * 0.72 + slider7 * 0.12 + 0.18));
          toneerr = brighterr * 0.36 + sharperr * 0.28;

          jump = max(0, dlast - (0.44 + slider9 * 0.38));
          too_close = max(0, (0.035 + (1 - slider9) * 0.045) - dlast);
          prev_bounce = (walk_prev_sid >= 0 && i == walk_prev_sid && sample_count > 2) ? 0.42 : 0;
          (dprev < 0.055 && sample_count > 3) ? prev_bounce += 0.18;

          score = abs(dlast - target) * 2.15;
          score += jump * 3.20;
          score += too_close * 4.60;
          score += clustererr * (0.18 + 0.24 * (1 - slider9));
          score += toneerr;
          score += prev_bounce;
          score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);

          weight = 0.002 + exp(-score * temp);
          totalw += weight;
        );
        i += 1;
      );

      totalw <= 0 ? (
        choose_random_sample(note, velnorm);
      ) : (
        pick = rand(totalw);
        accum = 0;
        sid = walk_last_sid;
        i = 0;
        while (i < sample_count) (
          i != walk_last_sid ? (
            sm = sample_meta_base + i * SM_STRIDE;

            dlast = sample_descriptor_distance(lastsm, sm, 0);
            dprev = sample_descriptor_distance(prevsm, sm, 0);
            clustererr = walk_cluster_distance(lastsm, sm);

            brighterr = abs(sm[SM_BRIGHT] - bright_t);
            sharperr  = abs(sm[SM_SHARP] - clamp01(lastsm[SM_SHARP] * 0.72 + slider7 * 0.12 + 0.18));
            toneerr = brighterr * 0.36 + sharperr * 0.28;

            jump = max(0, dlast - (0.44 + slider9 * 0.38));
            too_close = max(0, (0.035 + (1 - slider9) * 0.045) - dlast);
            prev_bounce = (walk_prev_sid >= 0 && i == walk_prev_sid && sample_count > 2) ? 0.42 : 0;
            (dprev < 0.055 && sample_count > 3) ? prev_bounce += 0.18;

            score = abs(dlast - target) * 2.15;
            score += jump * 3.20;
            score += too_close * 4.60;
            score += clustererr * (0.18 + 0.24 * (1 - slider9));
            score += toneerr;
            score += prev_bounce;
            score += recent_penalty(i) * rep_scale / max(RECENT_LEN, 1);

            weight = 0.002 + exp(-score * temp);
            accum += weight;
            accum >= pick ? (
              sid = i;
              i = sample_count;
            ) : i += 1;
          ) : i += 1;
        );
        sid == walk_last_sid ? choose_random_sample(note, velnorm) : sid;
      );
    );
  );
);

function choose_region_donor(src_sid region_mode wideness vix) local(
  src sm i pick accum totalw sid temp minspan
  src_lo src_hi src_span lo hi span
  brighterr sharperr transerr lenerr pitcherr regionerr histpen walkerr score weight
)
(
  (sample_count <= 1 || src_sid < 0) ? src_sid : (
    src = sample_meta_base + src_sid * SM_STRIDE;
    region_mode ? (
      src_lo = clamp(src[SM_TAILSTART], 0, max(0, src[SM_FRAMES] - 2));
      src_hi = max(src_lo + 1, src[SM_FRAMES] - 2);
      minspan = max(24, floor(hybrid_grain_samps * 0.22));
    ) : (
      src_lo = clamp(src[SM_HEADEND], 0, max(0, src[SM_TAILSTART] - 1));
      src_hi = clamp(src[SM_TAILSTART], src_lo + 1, max(src_lo + 1, src[SM_FRAMES] - 2));
      minspan = max(48, floor(hybrid_grain_samps * 0.36));
    );
    src_span = max(1, src_hi - src_lo);
    temp = lerp(10.0, 1.25, clamp01(wideness));
    totalw = 0;

    i = 0;
    while (i < sample_count) (
      i != src_sid ? (
        sm = sample_meta_base + i * SM_STRIDE;
        region_mode ? (
          lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
          hi = max(lo + 1, sm[SM_FRAMES] - 2);
        ) : (
          lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
          hi = clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
        );
        span = max(1, hi - lo);

        span >= minspan ? (
          brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
          sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
          transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
          lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
          regionerr = abs(log((span + 1) / (src_span + 1)));

          pitcherr = 0;
          (src[SM_PITCHCONF] > 0.45 && sm[SM_PITCHCONF] > 0.45) ? (
            pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
          );

          histpen = grain_sid_penalty(vix, i);
          score = brighterr * 1.00 + sharperr * 1.05 + transerr * 0.72 + lenerr * 0.26 + regionerr * 0.62;
          score += pitcherr * (0.14 + 0.56 * bank_pitchiness);
          score += histpen * 0.24;
          walk_mode ? (
            walkerr = sample_descriptor_distance(src, sm, region_mode);
            score += walkerr * (0.16 + 0.34 * (1 - clamp01(wideness)));
          );

          weight = 0.0005 + exp(-score * temp);
          totalw += weight;
        );
      );
      i += 1;
    );

    totalw <= 0 ? src_sid : (
      pick = rand(totalw);
      accum = 0;
      sid = src_sid;
      i = 0;
      while (i < sample_count) (
        i != src_sid ? (
          sm = sample_meta_base + i * SM_STRIDE;
          region_mode ? (
            lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
            hi = max(lo + 1, sm[SM_FRAMES] - 2);
          ) : (
            lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
            hi = clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
          );
          span = max(1, hi - lo);

          span >= minspan ? (
            brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
            sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
            transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
            lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
            regionerr = abs(log((span + 1) / (src_span + 1)));

            pitcherr = 0;
            (src[SM_PITCHCONF] > 0.45 && sm[SM_PITCHCONF] > 0.45) ? (
              pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
            );

            histpen = grain_sid_penalty(vix, i);
            score = brighterr * 1.00 + sharperr * 1.05 + transerr * 0.72 + lenerr * 0.26 + regionerr * 0.62;
            score += pitcherr * (0.14 + 0.56 * bank_pitchiness);
            score += histpen * 0.24;
            walk_mode ? (
              walkerr = sample_descriptor_distance(src, sm, region_mode);
              score += walkerr * (0.16 + 0.34 * (1 - clamp01(wideness)));
            );

            weight = 0.0005 + exp(-score * temp);
            accum += weight;
            accum >= pick ? (
              sid = i;
              i = sample_count;
            ) : i += 1;
          ) : i += 1;
        ) : i += 1;
      );
      sid;
    );
  );
);

function choose_region_pos(vix sid region_mode phase01 jitter_norm) local(
  sm lo hi span center pos jitter scale
  best bestscore score dist try limit
)
(
  sm = sample_meta_base + sid * SM_STRIDE;
  region_mode ? (
    lo = clamp(sm[SM_TAILSTART], 0, max(0, sm[SM_FRAMES] - 2));
    hi = max(lo + 1, sm[SM_FRAMES] - 2);
    limit = hybrid_tail_jitter;
  ) : (
    lo = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_TAILSTART] - 1));
    hi = clamp(sm[SM_TAILSTART], lo + 1, max(lo + 1, sm[SM_FRAMES] - 2));
    limit = hybrid_body_jitter;
  );
  span = max(1, hi - lo);
  center = lo + clamp01(phase01) * max(1, span - 1);
  best = clamp(center, lo, max(lo, hi - 1));
  bestscore = 1000000000;

  try = 0;
  while (try < GRAIN_CAND_TRIES) (
    scale = min(span * lerp(0.16, 0.52, clamp01(jitter_norm)), limit);
    jitter = (rand(1) - 0.5) * scale * 2;
    pos = center + jitter;
    region_mode ? (
      pos = clamp(pos, lo, max(lo, hi - 1));
    ) : (
      pos = wrap_in_range(pos, lo, hi);
    );
    dist = abs(pos - center) / max(1, span);
    score = grain_hist_penalty(vix, sid, pos, lo, hi) + dist * (region_mode ? 0.12 : 0.16);
    score < bestscore ? (
      bestscore = score;
      best = pos;
    );
    try += 1;
  );

  best;
);

function voices_busy() local(i v busy)
(
  busy = 0;
  i = 0;
  while (i < MAX_VOICES && !busy) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] > 0 ? busy = 1;
    i += 1;
  );
  busy;
);

function count_active_voices() local(i v cnt)
(
  cnt = 0;
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] > 0 ? cnt += 1;
    i += 1;
  );
  cnt;
);

function estimate_pitch(sm) local(
  ptr nch sr frames attack
  start win endp i
  x prevsign signcur
  last_cross interval
  sumint sumint2 cnt
  mu var relvar freq note conf
)
(
  ptr    = sm[SM_PTR]   | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = sm[SM_SR];
  frames = sm[SM_FRAMES] | 0;
  attack = sm[SM_ATTACK] | 0;

  note = 60;
  conf = 0;

  start = attack + min(64, max(8, floor(frames * 0.02)));
  win   = min(2048, frames - start - 1);

  win > 256 ? (
    last_cross = -1;
    sumint = 0;
    sumint2 = 0;
    cnt = 0;

    x = mono_frame(ptr, nch, start);
    prevsign = x >= 0 ? 1 : -1;

    i = start + 1;
    endp = start + win;
    while (i < endp) (
      x = mono_frame(ptr, nch, i);
      signcur = x >= 0 ? 1 : -1;

      signcur != prevsign ? (
        last_cross >= 0 ? (
          interval = i - last_cross;
          interval > 1 ? (
            sumint += interval;
            sumint2 += interval * interval;
            cnt += 1;
          );
        );
        last_cross = i;
        prevsign = signcur;
      );

      i += 1;
    );

    cnt >= 8 ? (
      mu = sumint / cnt;
      var = max(0, sumint2 / cnt - mu * mu);
      relvar = sqrt(var) / max(mu, 0.000001);
      freq = sr / max(2 * mu, 1);

      (freq >= 30 && freq <= 4000) ? (
        note = 69 + 17.31234049066756 * log(freq / 440);
        conf = clamp01(1 - relvar * 4);
      );
    );
  );

  sm[SM_PITCHNOTE] = note;
  sm[SM_PITCHCONF] = conf;
);

function analyze_sample_classic(sm) local(
  ptr nch sr frames scan i x ax prev lp hf prevhf
  peak sumsq sumabs sumdiff brightsum roughsum rms bright edge
  thresh attack attack_ms sharp transrich
  target_rms norm lpcoef
  head_ms head_end tail_start tail_thresh tail_minlen
  step chunkabs cnt j found
)
(
  ptr    = sm[SM_PTR]   | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = sm[SM_SR];
  frames = sm[SM_FRAMES] | 0;

  peak = 0;
  sumsq = 0;
  sumabs = 0;
  sumdiff = 0;
  brightsum = 0;
  roughsum = 0;
  prev = 0;
  prevhf = 0;
  lp = 0;

  scan = min(frames, max(256, floor(sr * 0.16)));
  lpcoef = clamp(1400 / max(sr, 1), 0.01, 0.35);

  i = 0;
  while (i < scan) (
    x = mono_frame(ptr, nch, i);
    ax = abs(x);
    peak = max(peak, ax);
    sumsq += x * x;
    sumabs += ax;
    i > 0 ? sumdiff += abs(x - prev);

    lp += (x - lp) * lpcoef;
    hf = x - lp;
    brightsum += abs(hf);
    i > 0 ? roughsum += abs(hf - prevhf);

    prev = x;
    prevhf = hf;
    i += 1;
  );

  rms = sqrt(sumsq / max(scan, 1));
  bright = clamp01((brightsum / max(sumabs, 0.000001) - 0.08) * 2.1);
  edge = clamp01((roughsum / max(brightsum, 0.000001)) * 0.34);

  thresh = max(peak * 0.12, rms * 1.8);
  attack = -1;
  i = 0;
  while (i < scan && attack < 0) (
    abs(mono_frame(ptr, nch, i)) >= thresh ? attack = i;
    i += 1;
  );
  attack < 0 ? attack = 0;

  attack_ms = 1000 * attack / max(sr, 1);
  sharp = clamp01((1 - min(1, attack_ms / 70)) * 0.72 + edge * 0.28);
  transrich = clamp01(sharp * 0.64 + edge * 0.18 + (1 - min(1, attack_ms / 55)) * 0.24 + bright * 0.06);

  head_ms = 8 + transrich * 48;
  head_end = clamp(attack + floor(sr * head_ms * 0.001), attack + 8, max(attack + 8, frames - 2));
  head_end = clamp(head_end, 0, max(0, frames - 2));

  tail_thresh = max(rms * (0.46 + 0.22 * transrich), peak * (0.040 + 0.020 * bright));
  step = max(1, floor(frames / 1024));
  tail_start = max(head_end + 16, frames - 2);
  found = 0;
  i = frames - 1;
  while (i > head_end + step && !found) (
    chunkabs = 0;
    cnt = 0;
    j = 0;
    while (j < step && (i - j) >= 0) (
      chunkabs += abs(mono_frame(ptr, nch, i - j));
      cnt += 1;
      j += 1;
    );
    (chunkabs / max(cnt, 1)) > tail_thresh ? (
      tail_start = clamp(i + step * 2, head_end + 16, max(head_end + 16, frames - 2));
      found = 1;
    );
    i -= step;
  );

  tail_minlen = min(max(floor(sr * (0.08 + 0.04 * (1 - transrich))), 192), max(192, floor(frames * 0.34)));
  !found ? tail_start = clamp(floor(frames * (0.60 + 0.14 * (1 - transrich))), head_end + 16, max(head_end + 16, frames - 2));
  tail_start = min(tail_start, max(head_end + 16, frames - tail_minlen));
  tail_start <= (head_end + 8) ? tail_start = min(max(head_end + 24, floor(frames * 0.72)), max(head_end + 24, frames - 2));
  tail_start = clamp(tail_start, min(head_end + 1, max(0, frames - 2)), max(0, frames - 2));

  target_rms = 0.12;
  norm = clamp(target_rms / max(rms, 0.000001), 0.25, 4.0);

  sm[SM_RMS]    = rms;
  sm[SM_PEAK]   = peak;
  sm[SM_EDGE]   = edge;
  sm[SM_ATTACK] = attack;
  sm[SM_SHARP]  = sharp;
  sm[SM_NORM]   = norm;
  sm[SM_LENMS]  = 1000 * frames / max(sr, 1);
  sm[SM_BRIGHT] = bright;
  sm[SM_FLAGS]  = transrich;
  sm[SM_HEADEND] = head_end;
  sm[SM_TAILSTART] = tail_start;

  estimate_pitch(sm);
);

function analyze_sample_gauss(sm) local(
  ptr nch sr frames
  onset_scan hop onset_lpcoef nov_count i j x ax lp hf env_prev hf_prev env_now hf_now cnt nov novsum
  peaki peakv mean_nov smoothv starti peakthr lowthr onset_conf onset_rise onset_rise_ms
  fallback_scan fallback_peak fallback_sumsq fallback_rms thresh attack fallback_attack
  feat_lo feat_hi scan prev prevhf lpcoef
  peak sumsq sumabs sumdiff brightsum roughsum rms bright edge
  sharp transrich
  target_rms norm head_ms head_end tail_start tail_thresh tail_minlen
  step chunkabs found
)
(
  ptr    = sm[SM_PTR]   | 0;
  nch    = max(1, sm[SM_NCH] | 0);
  sr     = sm[SM_SR];
  frames = sm[SM_FRAMES] | 0;

  onset_scan = min(frames, max(4096, floor(sr * 2.00)));
  hop = max(1, floor(sr * 0.00075));
  hop = max(hop, floor((onset_scan + ONSET_SCRATCH_MAX - 1) / max(1, ONSET_SCRATCH_MAX)));
  onset_lpcoef = clamp(2200 / max(sr, 1), 0.015, 0.40);

  lp = 0;
  env_prev = 0;
  hf_prev = 0;
  nov_count = 0;
  novsum = 0;

  i = 0;
  while (i < onset_scan && nov_count < ONSET_SCRATCH_MAX) (
    env_now = 0;
    hf_now = 0;
    cnt = 0;
    j = 0;
    while (j < hop && (i + j) < onset_scan) (
      x = mono_frame(ptr, nch, i + j);
      ax = abs(x);
      lp += (x - lp) * onset_lpcoef;
      hf = x - lp;
      env_now += ax;
      hf_now += abs(hf);
      cnt += 1;
      j += 1;
    );
    env_now /= max(cnt, 1);
    hf_now /= max(cnt, 1);
    nov = max(0, hf_now - hf_prev * 0.90) + 0.32 * max(0, env_now - env_prev * 0.94);
    nov += 0.10 * max(0, hf_now - env_now * 0.22);
    onset_raw_base[nov_count] = nov;
    novsum += nov;
    env_prev = env_now;
    hf_prev = hf_now;
    nov_count += 1;
    i += hop;
  );

  peaki = 0;
  peakv = 0;
  i = 0;
  while (i < nov_count) (
    smoothv = (
      onset_raw_base[clamp(i - 3, 0, max(0, nov_count - 1))] +
      onset_raw_base[clamp(i - 2, 0, max(0, nov_count - 1))] * 6 +
      onset_raw_base[clamp(i - 1, 0, max(0, nov_count - 1))] * 15 +
      onset_raw_base[i] * 20 +
      onset_raw_base[clamp(i + 1, 0, max(0, nov_count - 1))] * 15 +
      onset_raw_base[clamp(i + 2, 0, max(0, nov_count - 1))] * 6 +
      onset_raw_base[clamp(i + 3, 0, max(0, nov_count - 1))]
    ) * 0.015625;
    onset_smooth_base[i] = smoothv;
    smoothv > peakv ? (
      peakv = smoothv;
      peaki = i;
    );
    i += 1;
  );

  fallback_scan = min(frames, onset_scan);
  fallback_peak = 0;
  fallback_sumsq = 0;
  i = 0;
  while (i < fallback_scan) (
    x = mono_frame(ptr, nch, i);
    ax = abs(x);
    fallback_peak = max(fallback_peak, ax);
    fallback_sumsq += x * x;
    i += 1;
  );
  fallback_rms = sqrt(fallback_sumsq / max(fallback_scan, 1));
  thresh = max(fallback_peak * 0.12, fallback_rms * 1.8);
  fallback_attack = -1;
  i = 0;
  while (i < fallback_scan && fallback_attack < 0) (
    abs(mono_frame(ptr, nch, i)) >= thresh ? fallback_attack = i;
    i += 1;
  );
  fallback_attack < 0 ? fallback_attack = 0;

  mean_nov = nov_count > 0 ? (novsum / nov_count) : 0;
  onset_conf = peakv > 0 ? clamp01((peakv - mean_nov * 1.35) / max(peakv, 0.000001)) : 0;
  starti = peaki;
  peakthr = peakv * (0.18 + 0.08 * (1 - onset_conf));
  while (starti > 0 && onset_smooth_base[starti - 1] >= peakthr) (
    starti -= 1;
  );
  lowthr = peakv * 0.10;
  while (starti > 0 && onset_smooth_base[starti - 1] > lowthr && (peaki - starti) < 8) (
    starti -= 1;
  );

  attack = floor(starti * hop);
  (onset_conf < 0.12 || peakv <= 0.00001) ? attack = fallback_attack;
  attack = clamp(attack, 0, max(0, frames - 2));

  onset_rise = max(hop, (peaki - starti) * hop);
  onset_rise_ms = 1000 * onset_rise / max(sr, 1);

  feat_lo = max(0, attack - min(attack, floor(sr * 0.008)));
  feat_hi = min(frames, attack + max(256, floor(sr * 0.18)));
  scan = max(1, feat_hi - feat_lo);
  lpcoef = clamp(1400 / max(sr, 1), 0.01, 0.35);

  peak = 0;
  sumsq = 0;
  sumabs = 0;
  sumdiff = 0;
  brightsum = 0;
  roughsum = 0;
  lp = 0;
  prev = mono_frame(ptr, nch, feat_lo);
  prevhf = 0;

  i = feat_lo;
  while (i < feat_hi) (
    x = mono_frame(ptr, nch, i);
    ax = abs(x);
    peak = max(peak, ax);
    sumsq += x * x;
    sumabs += ax;
    i > feat_lo ? sumdiff += abs(x - prev);

    lp += (x - lp) * lpcoef;
    hf = x - lp;
    brightsum += abs(hf);
    i > feat_lo ? roughsum += abs(hf - prevhf);

    prev = x;
    prevhf = hf;
    i += 1;
  );

  rms = sqrt(sumsq / max(scan, 1));
  bright = clamp01((brightsum / max(sumabs, 0.000001) - 0.08) * 2.1);
  edge = clamp01((roughsum / max(brightsum, 0.000001)) * 0.34);

  sharp = clamp01((1 - min(1, onset_rise_ms / 18)) * 0.58 + edge * 0.24 + onset_conf * 0.18);
  transrich = clamp01(sharp * 0.58 + edge * 0.14 + onset_conf * 0.18 + bright * 0.10);

  head_ms = 4 + transrich * 30 + min(14, onset_rise_ms * 0.32);
  head_end = clamp(attack + floor(sr * head_ms * 0.001), attack + 8, max(attack + 8, frames - 2));
  head_end = clamp(head_end, 0, max(0, frames - 2));

  tail_thresh = max(rms * (0.46 + 0.22 * transrich), peak * (0.040 + 0.020 * bright));
  step = max(1, floor(frames / 1024));
  tail_start = max(head_end + 16, frames - 2);
  found = 0;
  i = frames - 1;
  while (i > head_end + step && !found) (
    chunkabs = 0;
    cnt = 0;
    j = 0;
    while (j < step && (i - j) >= 0) (
      chunkabs += abs(mono_frame(ptr, nch, i - j));
      cnt += 1;
      j += 1;
    );
    (chunkabs / max(cnt, 1)) > tail_thresh ? (
      tail_start = clamp(i + step * 2, head_end + 16, max(head_end + 16, frames - 2));
      found = 1;
    );
    i -= step;
  );

  tail_minlen = min(max(floor(sr * (0.08 + 0.04 * (1 - transrich))), 192), max(192, floor(frames * 0.34)));
  !found ? tail_start = clamp(floor(frames * (0.60 + 0.14 * (1 - transrich))), head_end + 16, max(head_end + 16, frames - 2));
  tail_start = min(tail_start, max(head_end + 16, frames - tail_minlen));
  tail_start <= (head_end + 8) ? tail_start = min(max(head_end + 24, floor(frames * 0.72)), max(head_end + 24, frames - 2));
  tail_start = clamp(tail_start, min(head_end + 1, max(0, frames - 2)), max(0, frames - 2));

  target_rms = 0.12;
  norm = clamp(target_rms / max(rms, 0.000001), 0.25, 4.0);

  sm[SM_RMS]    = rms;
  sm[SM_PEAK]   = peak;
  sm[SM_EDGE]   = edge;
  sm[SM_ATTACK] = attack;
  sm[SM_SHARP]  = sharp;
  sm[SM_NORM]   = norm;
  sm[SM_LENMS]  = 1000 * frames / max(sr, 1);
  sm[SM_BRIGHT] = bright;
  sm[SM_FLAGS]  = transrich;
  sm[SM_HEADEND] = head_end;
  sm[SM_TAILSTART] = tail_start;

  estimate_pitch(sm);
);

function analyze_sample(sm)
(
  onset_mode_active ? analyze_sample_gauss(sm) : analyze_sample_classic(sm);
);

function reset_voices() local(i j v)
(
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    j = 0;
    while (j < VC_STRIDE) (
      v[j] = 0;
      j += 1;
    );
    v[VC_STAGE] = ENV_OFF;
    i += 1;
  );
);

function note_gate_idx(note chan)
(
  (clamp(chan, 0, 15) | 0) * 128 + (clamp(note, 0, 127) | 0);
);

function reset_note_gates() local(i)
(
  i = 0;
  while (i < NOTE_GATE_CELLS) (
    note_gate_base[i] = 0;
    i += 1;
  );
);

function note_gate_on(note chan) local(idx)
(
  idx = note_gate_idx(note, chan);
  note_gate_base[idx] = min(32, note_gate_base[idx] + 1);
);

function note_gate_off(note chan) local(idx)
(
  idx = note_gate_idx(note, chan);
  note_gate_base[idx] = max(0, note_gate_base[idx] - 1);
);

function note_gate_forget_voice(v) local(idx)
(
  (v[VC_ACTIVE] > 0 && v[VC_STAGE] != ENV_RELEASE) ? (
    idx = note_gate_idx(v[VC_NOTE], v[VC_CHAN]);
    note_gate_base[idx] = max(0, note_gate_base[idx] - 1);
  );
);

function count_held_note_voices(note chan) local(i v cnt)
(
  cnt = 0;
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (v[VC_ACTIVE] > 0 && v[VC_NOTE] == note && v[VC_CHAN] == chan && v[VC_STAGE] != ENV_RELEASE) ? cnt += 1;
    i += 1;
  );
  cnt;
);

function reset_weight_buffers() local(i)
(
  weight_ap1_pos = 0;
  weight_ap2_pos = 0;
  weight_er_pos = 0;
  weight_in_lp_l = 0;
  weight_in_lp_r = 0;
  weight_wet_lp_l = 0;
  weight_wet_lp_r = 0;

  i = 0;
  while (i < AP_BUF_LEN) (
    weight_ap1_l_base[i] = 0;
    weight_ap1_r_base[i] = 0;
    weight_ap2_l_base[i] = 0;
    weight_ap2_r_base[i] = 0;
    i += 1;
  );

  i = 0;
  while (i < ER_BUF_LEN) (
    weight_er_l_base[i] = 0;
    weight_er_r_base[i] = 0;
    i += 1;
  );
);

function reset_clean_buffers() local(i)
(
  clean_lp1_l = 0;
  clean_lp2_l = 0;
  clean_lp3_l = 0;
  clean_lp4_l = 0;
  clean_lp1_r = 0;
  clean_lp2_r = 0;
  clean_lp3_r = 0;
  clean_lp4_r = 0;
  clean_head_bus = 0;
  clean_tail_bus = 0;

  i = 0;
  while (i < CLEAN_BANDS) (
    clean_env_base[i] = 0;
    clean_floor_base[i] = 0;
    clean_gain_base[i] = 1;
    i += 1;
  );
);

function reset_room_buffers()
(
  room_lp1_l = 0;
  room_lp2_l = 0;
  room_lp3_l = 0;
  room_lp4_l = 0;
  room_lp1_r = 0;
  room_lp2_r = 0;
  room_lp3_r = 0;
  room_lp4_r = 0;

  room_fast_env = 0;
  room_slow_env = 0;
  room_g0 = 1;
  room_g1 = 1;
  room_g2 = 1;
  room_g3 = 1;
  room_g4 = 1;

  room_head_bus = 0;
  room_tail_bus = 0;
);

function reset_push_buffers()
(
  push_m_lp15 = 0;
  push_m_lp32 = 0;
  push_m_lp55 = 0;
  push_s_lp15 = 0;
  push_s_lp32 = 0;
  push_s_lp55 = 0;

  push_bodyE = 0;
  push_formE = 0;
  push_edgeE = 0;
  push_airE = 0;
  push_srcE = 0;
  push_m_hiE = 0;
  push_s_hiE = 0;
  push_click_fastE = 0;
  push_click_slowE = 0;

  push_common_dB = 0;
  push_side_dB = 0;
  push_hot_dB = -150;
  push_click_dB = 0;
  push_side_rel_dB = -150;
);


function clean_update_gain(idx det amount bias) local(env floorv thresh under tgt g amt upc)
(
  env = clean_env_base[idx];
  env += (det - env) * (det > env ? clean_env_att_coeff : clean_env_rel_coeff);
  clean_env_base[idx] = env;

  floorv = clean_floor_base[idx];
  floorv += (det - floorv) * (det > floorv ? clean_floor_up_coeff : clean_floor_down_coeff);
  floorv = min(floorv, env * 0.62 + 0.00000003);
  floorv = max(0, floorv);
  clean_floor_base[idx] = floorv;

  thresh = floorv * clean_thresh_floor + env * clean_thresh_env + clean_abs_floor;
  under = clamp(det / max(thresh, 0.000000001), 0, 1);
  tgt = det < thresh ? max(clean_min_gain, under ^ clean_expand_pow) : 1;

  amt = clamp01(amount * bias);
  tgt = lerp(1, tgt, amt);

  g = clean_gain_base[idx];
  upc = amount < 0.02 ? clean_gain_protect_coeff : clean_gain_up_coeff;
  g += (tgt - g) * (tgt < g ? clean_gain_down_coeff : upc);
  g = clamp(g, clean_min_gain, 1);
  clean_gain_base[idx] = g;
  g;
);

function apply_cleaner() local(
  inL inR
  b0l b1l b2l b3l b4l b0r b1r b2r b3r b4r
  d0 d1 d2 d3 d4
  protect amount
  g0 g1 g2 g3 g4
)
(
  // ERB-ish detector/control split: low, low-mid, presence, air, top-noise.
  // The bands sum back to the original signal when all gains are 1.
  inL = outL;
  inR = outR;

  clean_lp1_l += (inL - clean_lp1_l) * clean_lp_c1;
  clean_lp2_l += (inL - clean_lp2_l) * clean_lp_c2;
  clean_lp3_l += (inL - clean_lp3_l) * clean_lp_c3;
  clean_lp4_l += (inL - clean_lp4_l) * clean_lp_c4;

  clean_lp1_r += (inR - clean_lp1_r) * clean_lp_c1;
  clean_lp2_r += (inR - clean_lp2_r) * clean_lp_c2;
  clean_lp3_r += (inR - clean_lp3_r) * clean_lp_c3;
  clean_lp4_r += (inR - clean_lp4_r) * clean_lp_c4;

  b0l = clean_lp1_l;
  b1l = clean_lp2_l - clean_lp1_l;
  b2l = clean_lp3_l - clean_lp2_l;
  b3l = clean_lp4_l - clean_lp3_l;
  b4l = inL - clean_lp4_l;

  b0r = clean_lp1_r;
  b1r = clean_lp2_r - clean_lp1_r;
  b2r = clean_lp3_r - clean_lp2_r;
  b3r = clean_lp4_r - clean_lp3_r;
  b4r = inR - clean_lp4_r;

  d0 = max(abs(b0l), abs(b0r)) * 0.62 + abs(0.5 * (b0l + b0r)) * 0.38;
  d1 = max(abs(b1l), abs(b1r)) * 0.62 + abs(0.5 * (b1l + b1r)) * 0.38;
  d2 = max(abs(b2l), abs(b2r)) * 0.62 + abs(0.5 * (b2l + b2r)) * 0.38;
  d3 = max(abs(b3l), abs(b3r)) * 0.62 + abs(0.5 * (b3l + b3r)) * 0.38;
  d4 = max(abs(b4l), abs(b4r)) * 0.62 + abs(0.5 * (b4l + b4r)) * 0.38;

  protect = clamp01(transient_guard_s * (0.86 + 0.14 * trans_mode_mix) + clean_head_bus * 0.90);
  amount = clamp01(clean_amt * (1 - protect));
  amount = clamp01(amount * (1 + clean_tail_bus * 0.35));

  g0 = clean_update_gain(0, d0, amount, 0.32);
  g1 = clean_update_gain(1, d1, amount, 0.66);
  g2 = clean_update_gain(2, d2, amount, 0.98);
  g3 = clean_update_gain(3, d3, amount, 1.16);
  g4 = clean_update_gain(4, d4, amount, 1.28);

  clean_amt > 0.0001 ? (
    outL = b0l * g0 + b1l * g1 + b2l * g2 + b3l * g3 + b4l * g4;
    outR = b0r * g0 + b1r * g1 + b2r * g2 + b3r * g3 + b4r * g4;
  );
);

function apply_room_tame() local(
  inL inR det
  b0l b1l b2l b3l b4l b0r b1r b2r b3r b4r
  mid1 side1 mid2 side2 mid3 side3
  late protect region amount side_trim
  target0 target1 target2 target3 target4
)
(
  // Late-tail room suppressor: broad, detector-driven, and deliberately mild.
  // It mostly trims low-mid / presence smear during decays and release tails.
  inL = outL;
  inR = outR;

  room_lp1_l += (inL - room_lp1_l) * room_lp_c1;
  room_lp2_l += (inL - room_lp2_l) * room_lp_c2;
  room_lp3_l += (inL - room_lp3_l) * room_lp_c3;
  room_lp4_l += (inL - room_lp4_l) * room_lp_c4;

  room_lp1_r += (inR - room_lp1_r) * room_lp_c1;
  room_lp2_r += (inR - room_lp2_r) * room_lp_c2;
  room_lp3_r += (inR - room_lp3_r) * room_lp_c3;
  room_lp4_r += (inR - room_lp4_r) * room_lp_c4;

  b0l = room_lp1_l;
  b1l = room_lp2_l - room_lp1_l;
  b2l = room_lp3_l - room_lp2_l;
  b3l = room_lp4_l - room_lp3_l;
  b4l = inL - room_lp4_l;

  b0r = room_lp1_r;
  b1r = room_lp2_r - room_lp1_r;
  b2r = room_lp3_r - room_lp2_r;
  b3r = room_lp4_r - room_lp3_r;
  b4r = inR - room_lp4_r;

  det = max(abs(inL), abs(inR)) * 0.54 + abs(0.5 * (inL + inR)) * 0.46;
  room_fast_env += (det - room_fast_env) * (det > room_fast_env ? room_env_att_coeff : room_env_fast_rel_coeff);
  room_slow_env += (det - room_slow_env) * (det > room_slow_env ? room_env_slow_att_coeff : room_env_slow_rel_coeff);

  late = clamp01((room_slow_env - room_fast_env) / max(room_slow_env, 0.0000001));
  protect = clamp01(transient_guard_s * (0.90 + 0.10 * trans_mode_mix) + room_head_bus * 0.92);
  region = clamp01(room_tail_bus * 0.92 + late * (0.22 + 0.50 * room_amt));
  amount = clamp01(room_amt * (1 - protect) * region);
  amount = clamp01(amount * (0.72 + 0.28 * room_amt));

  target0 = clamp(1 - amount * 0.08, room_min_gain0, 1);
  target1 = clamp(1 - amount * (0.24 + 0.14 * room_amt), room_min_gain1, 1);
  target2 = clamp(1 - amount * (0.20 + 0.12 * room_amt), room_min_gain2, 1);
  target3 = clamp(1 - amount * (0.11 + 0.07 * room_amt), room_min_gain3, 1);
  target4 = clamp(1 - amount * 0.035, room_min_gain4, 1);

  room_g0 += (target0 - room_g0) * (target0 < room_g0 ? room_gain_down_coeff : room_gain_up_coeff);
  room_g1 += (target1 - room_g1) * (target1 < room_g1 ? room_gain_down_coeff : room_gain_up_coeff);
  room_g2 += (target2 - room_g2) * (target2 < room_g2 ? room_gain_down_coeff : room_gain_up_coeff);
  room_g3 += (target3 - room_g3) * (target3 < room_g3 ? room_gain_down_coeff : room_gain_up_coeff);
  room_g4 += (target4 - room_g4) * (target4 < room_g4 ? room_gain_down_coeff : room_gain_up_coeff);

  side_trim = clamp01(amount * (0.08 + 0.14 * room_amt));
  mid1 = 0.5 * (b1l + b1r); side1 = 0.5 * (b1l - b1r) * (1 - side_trim * 0.80);
  mid2 = 0.5 * (b2l + b2r); side2 = 0.5 * (b2l - b2r) * (1 - side_trim);
  mid3 = 0.5 * (b3l + b3r); side3 = 0.5 * (b3l - b3r) * (1 - side_trim * 0.55);

  outL = b0l * room_g0 + (mid1 + side1) * room_g1 + (mid2 + side2) * room_g2 + (mid3 + side3) * room_g3 + b4l * room_g4;
  outR = b0r * room_g0 + (mid1 - side1) * room_g1 + (mid2 - side2) * room_g2 + (mid3 - side3) * room_g3 + b4r * room_g4;
);

function apply_push() local(
  inL inR M S
  M_body M_form M_edge M_air S_body S_form S_edge S_air
  body_inst form_inst edge_inst air_inst src_inst M_hi S_hi
  src_dB src_w self_allow trans_allow side_allow
  ex_self ex_trans ex_side level_want common_want side_want
  head_damp cC cS g_form g_edge g_air g_side g_broad
  formW edgeW airW broadW broad_dB
)
(
  // Single-knob salience budget. Derived from the separate Salience Push idea,
  // but self-keyed only: it trims presence/air, reins in pokey upper spikes,
  // narrows bright side wash, and adds broadband distance at high settings.
  inL = outL;
  inR = outR;

  M = 0.5 * (inL + inR);
  S = 0.5 * (inL - inR);

  push_m_lp15 += (M - push_m_lp15) * push_lp15_c;
  push_m_lp32 += (M - push_m_lp32) * push_lp32_c;
  push_m_lp55 += (M - push_m_lp55) * push_lp55_c;
  push_s_lp15 += (S - push_s_lp15) * push_lp15_c;
  push_s_lp32 += (S - push_s_lp32) * push_lp32_c;
  push_s_lp55 += (S - push_s_lp55) * push_lp55_c;

  M_body = push_m_lp15;
  M_form = push_m_lp32 - push_m_lp15;
  M_edge = push_m_lp55 - push_m_lp32;
  M_air  = M - push_m_lp55;

  S_body = push_s_lp15;
  S_form = push_s_lp32 - push_s_lp15;
  S_edge = push_s_lp55 - push_s_lp32;
  S_air  = S - push_s_lp55;

  body_inst = M_body*M_body + S_body*S_body;
  form_inst = M_form*M_form + S_form*S_form;
  edge_inst = M_edge*M_edge + S_edge*S_edge;
  air_inst  = M_air*M_air   + S_air*S_air;
  src_inst  = 0.5 * (inL*inL + inR*inR);

  M_hi = M_edge + M_air;
  S_hi = S_edge + S_air;

  push_bodyE += push_a_lev * (body_inst - push_bodyE);
  push_formE += push_a_lev * (form_inst - push_formE);
  push_edgeE += push_a_lev * (edge_inst - push_edgeE);
  push_airE  += push_a_lev * (air_inst  - push_airE);
  push_srcE  += push_a_src * (src_inst  - push_srcE);
  push_m_hiE += push_a_lev * (M_hi*M_hi - push_m_hiE);
  push_s_hiE += push_a_lev * (S_hi*S_hi - push_s_hiE);

  push_click_fastE += push_a_fast * ((edge_inst + 0.62*air_inst) - push_click_fastE);
  push_click_slowE += push_a_slow * ((edge_inst + 0.62*air_inst) - push_click_slowE);

  push_hot_dB = 10 * log((0.35*push_formE + 1.00*push_edgeE + 1.18*push_airE + PUSH_EPS) / (push_bodyE + 0.55*push_formE + PUSH_EPS)) * LOG10_INV;
  push_click_dB = 10 * log((push_click_fastE + PUSH_EPS) / (push_click_slowE + PUSH_EPS)) * LOG10_INV;
  push_side_rel_dB = 10 * log((push_s_hiE + PUSH_EPS) / (push_m_hiE + PUSH_EPS)) * LOG10_INV;
  src_dB = 10 * log(push_srcE + PUSH_EPS) * LOG10_INV;

  src_w = clamp01((src_dB + 72) / 20);

  self_allow  = -5.0 - 6.5 * push_amt + 4.0 * push_preserve - 1.5;
  trans_allow = clamp(6.5 - 3.2 * push_amt + 2.0 * push_preserve + 0.7, 1.0, 10.0);
  side_allow  = clamp(3.0 - 2.0 * push_amt + 3.0 * push_preserve - 2.3, -3.0, 8.0);

  ex_self = max(0, push_hot_dB - self_allow);
  ex_trans = max(0, push_click_dB - trans_allow);
  ex_side = max(0, push_side_rel_dB - side_allow);

  level_want = src_w * ex_self * (0.18 + 0.92 * push_amt);
  common_want = level_want + src_w * ex_trans * push_trans_w;
  common_want = min(common_want, push_max_common_dB);

  side_want = src_w * ex_side * push_side_w;
  side_want = min(side_want, push_max_side_dB);

  // Keep hit identity, but do not let attacks punch all the way forward at high Push.
  head_damp = clamp01(transient_guard_s * (0.38 - 0.18 * push_amt));
  common_want *= 1 - head_damp;
  side_want *= 1 - head_damp * 0.55;

  cC = common_want > push_common_dB ? push_common_att_coeff : push_common_rel_coeff;
  push_common_dB += (common_want - push_common_dB) * cC;

  cS = side_want > push_side_dB ? push_side_att_coeff : push_side_rel_coeff;
  push_side_dB += (side_want - push_side_dB) * cS;

  formW = clamp((0.50 - 0.24 * push_preserve), 0.12, 0.80);
  edgeW = clamp((0.98 - 0.10 * push_preserve), 0.68, 1.18);
  airW  = clamp((1.20 - 0.34 * push_preserve), 0.54, 1.36);
  broadW = clamp(0.05 + 0.22 * push_amt * (1 - 0.35 * push_preserve), 0, 0.30);

  g_form = db2amp(-(push_common_dB * formW));
  g_edge = db2amp(-(push_common_dB * edgeW));
  g_air  = db2amp(-(push_common_dB * airW));
  g_side = db2amp(-push_side_dB);
  broad_dB = push_common_dB * broadW + push_broad_static_dB * src_w;
  g_broad = db2amp(-broad_dB);

  M_form *= g_form;  S_form *= g_form;
  M_edge *= g_edge;  S_edge *= g_edge * g_side;
  M_air  *= g_air;   S_air  *= g_air  * g_side;

  M = M_body + M_form + M_edge + M_air;
  S = S_body + S_form + S_edge + S_air;

  outL = (M + S) * g_broad;
  outR = (M - S) * g_broad;
);


function reset_bank_state() local(i)
(
  sample_count = 0;
  bank_selected_count = 0;
  bank_scan_count = 0;
  bank_skipped_count = 0;
  bank_cap_limited = 0;
  bank_memory_limited = 0;
  bank_pool_capacity = sample_pool_capacity;
  bank_pitchiness = 0;
  bank_brightness = 0;
  bank_sharpness = 0;
  next_audio = AUDIO_BASE;
  seq_cursor = 0;
  walk_last_sid = -1;
  walk_prev_sid = -1;
  walk_steps = 0;
  last_sid = -1;
  last_note = -1;
  i = 0;
  while (i < RECENT_LEN) (
    recent_base[i] = -1;
    i += 1;
  );
  reset_grain_histories();
  reset_voices();
  reset_note_gates();
  reset_weight_buffers();
  reset_clean_buffers();
  reset_room_buffers();
  reset_push_buffers();
  transient_guard_s = 0;
  seam_bridge_env = 0;
  seam_bridge_idx = -1;
  seam_bridge_phase = -1;
  seam_bridge_same_note = 0;
);

function load_one_pool_sample(sample_index) local(
  sid nch sr frames sm
)
(
  sid = sample_get(bank_pool, sample_index);
  sid > 0 && sample_count < sample_pool_capacity ? (
    nch = max(1, sample_channels(bank_pool, sid) | 0);
    sr = sample_srate(bank_pool, sid);
    frames = sample_len(bank_pool, sid) | 0;

    (nch > 0 && sr > 1000 && frames > 1) ? (
      sm = sample_meta_base + sample_count * SM_STRIDE;
      sm[SM_PTR]      = sid;
      sm[SM_NCH]      = nch;
      sm[SM_SR]       = sr;
      sm[SM_FRAMES]   = frames;
      sm[SM_LASTUSED] = -1000000;
      sm[SM_PEAK]     = sample_peak(bank_pool, sid);
      sm[SM_RMS]      = sample_rms(bank_pool, sid);
      analyze_sample(sm);
      sample_count += 1;
    );
  );
);

function refresh_bank_stats() local(
  i sm spread_step spread_root pitch_sum bright_sum sharp_sum
)
(
  bank_pitchiness = 0;
  bank_brightness = 0;
  bank_sharpness = 0;

  sample_count > 0 ? (
    spread_step = sample_count > 1 ? (ROOT_HIGH - ROOT_LOW) / (sample_count - 1) : 0;
    pitch_sum = 0;
    bright_sum = 0;
    sharp_sum = 0;
    i = 0;
    while (i < sample_count) (
      sm = sample_meta_base + i * SM_STRIDE;
      spread_root = ROOT_LOW + i * spread_step;
      sm[SM_ROOT] = sm[SM_PITCHCONF] > 0.55 ? clamp(sm[SM_PITCHNOTE], 0, 127) : spread_root;
      update_sample_cluster(sm);
      pitch_sum += sm[SM_PITCHCONF];
      bright_sum += sm[SM_BRIGHT];
      sharp_sum += sm[SM_SHARP];
      i += 1;
    );
    bank_pitchiness = clamp01(pitch_sum / sample_count);
    bank_brightness = bright_sum / sample_count;
    bank_sharpness = sharp_sum / sample_count;
  );

  bank_loaded = sample_count > 0;
);

function reanalyze_bank() local(i sm)
(
  i = 0;
  while (i < RECENT_LEN) (
    recent_base[i] = -1;
    i += 1;
  );
  reset_grain_histories();
  reset_weight_buffers();
  reset_clean_buffers();
  reset_room_buffers();
  reset_push_buffers();
  transient_guard_s = 0;
  seq_cursor = 0;
  last_sid = -1;

  i = 0;
  while (i < sample_count) (
    sm = sample_meta_base + i * SM_STRIDE;
    analyze_sample(sm);
    i += 1;
  );

  refresh_bank_stats();
  rescan_flash = 1;
);

function configure_memory_layout(selected_count) local(cap) (
  cap = max(SAMPLE_POOL_MIN, selected_count | 0);
  cap > SAMPLE_POOL_HARD_MAX ? cap = SAMPLE_POOL_HARD_MAX;
  sample_pool_capacity = cap;

  sample_meta_base = 0;
  voice_base = sample_meta_base + sample_pool_capacity * SM_STRIDE;
  recent_base = voice_base + MAX_VOICES * VC_STRIDE;
  grain_hist_sid_base = recent_base + RECENT_LEN + 32;
  grain_hist_pos_base = grain_hist_sid_base + MAX_VOICES * GRAIN_HIST_LEN;
  grain_hist_phase_base = grain_hist_pos_base + MAX_VOICES * GRAIN_HIST_LEN;
  sig_scratch_base = grain_hist_phase_base + MAX_VOICES * GRAIN_HIST_LEN + 32;
  onset_raw_base = sig_scratch_base + SIG_PEEK_WORDS + 64;
  onset_smooth_base = onset_raw_base + ONSET_SCRATCH_MAX;

  m2e_cc_age_base = onset_smooth_base + ONSET_SCRATCH_MAX + 32;
  m2e_cc_val_base = m2e_cc_age_base + 128;

  note_gate_base = m2e_cc_val_base + 128 + 64;

  weight_ap1_l_base = note_gate_base + NOTE_GATE_CELLS + 64;
  weight_ap1_r_base = weight_ap1_l_base + AP_BUF_LEN;
  weight_ap2_l_base = weight_ap1_r_base + AP_BUF_LEN;
  weight_ap2_r_base = weight_ap2_l_base + AP_BUF_LEN;
  weight_er_l_base  = weight_ap2_r_base + AP_BUF_LEN;
  weight_er_r_base  = weight_er_l_base + ER_BUF_LEN;

  clean_env_base   = weight_er_r_base + ER_BUF_LEN + 256;
  clean_floor_base = clean_env_base + CLEAN_BANDS;
  clean_gain_base  = clean_floor_base + CLEAN_BANDS;

  AUDIO_BASE  = clean_gain_base + CLEAN_BANDS + 256;
  MEM_LIMIT   = max(AUDIO_BASE + 1024, (__memtop() | 0) - 256);
);

function load_bank() local(
  selected loaded count i before_count
)
(
  sample_pool_set_mode(bank_pool, SAMPLE_MODE_RESIDENT);
  sample_pool_set_budget_mb(bank_pool, bank_budget_mb);
  sample_pool_commit(bank_pool);

  selected = max(0, sample_pool_selected(bank_pool) | 0);
  loaded = max(0, sample_pool_loaded(bank_pool) | 0);
  pool_state = sample_pool_state(bank_pool);
  pool_ram_mb = sample_pool_ram_mb(bank_pool);

  ((pool_state == SAMPLE_POOL_SCANNING || pool_state == SAMPLE_POOL_LOADING) && loaded <= 0 && sample_count > 0) ? (
    // Keep the previous generation playable while the worker builds the next one.
    bank_selected_count = selected;
    rescan_pending = 1;
  ) : (
    configure_memory_layout(max(selected, loaded));
    reset_bank_state();

    bank_selected_count = selected;
    bank_scan_count = loaded;
    bank_pool_capacity = sample_pool_capacity;
    bank_cap_limited = bank_selected_count > sample_pool_capacity ? 1 : 0;
    bank_memory_limited = sample_pool_failed(bank_pool) > 0 ? 1 : 0;

    count = min(sample_pool_capacity, loaded);
    i = 0;
    while (i < count) (
      before_count = sample_count;
      load_one_pool_sample(i);
      sample_count == before_count ? bank_skipped_count += 1;
      i += 1;
    );

    bank_skipped_count += max(0, selected - loaded);
    refresh_bank_stats();
    seq_cursor = 0;
    rescan_flash = 1;
    next_audio = AUDIO_BASE;
    freembuf(AUDIO_BASE);
  );
);

function compute_slot_signature() local(sig)
(
  sample_pool_set_mode(bank_pool, SAMPLE_MODE_RESIDENT);
  sample_pool_set_budget_mb(bank_pool, bank_budget_mb);
  sample_pool_commit(bank_pool);

  pool_state = sample_pool_state(bank_pool);
  pool_ram_mb = sample_pool_ram_mb(bank_pool);
  bank_selected_count = max(0, sample_pool_selected(bank_pool) | 0);

  sig = sample_pool_generation(bank_pool);
  sig += sample_pool_loaded(bank_pool) * 8191;
  sig += sample_pool_failed(bank_pool) * 131;
  sig += pool_state * 17;
  sig;
);

function schedule_rescan(sig force)
(
  pending_signature = sig;
  rescan_pending = 1;
  force ? rescan_force = 1;
);

function poll_slot(force) local(sig)
(
  sig = compute_slot_signature();
  force || sig != slot_signature_loaded ? schedule_rescan(sig, force);
);

function choose_sample(note velnorm) local(sid)
(
  sample_count <= 0 ? 0 : (
    selection_mode == 1 ? (
      sid = seq_cursor % max(sample_count, 1);
      seq_cursor = (seq_cursor + 1) % max(sample_count, 1);
      sid;
    ) : selection_mode == 2 ? (
      choose_walk_sample(note, velnorm);
    ) : (
      choose_random_sample(note, velnorm);
    );
  );
);

function choose_tail_donor(src_sid wideness) local(
  src sm i pick accum totalw score weight sid
  brighterr sharperr transerr lenerr pitcherr tailerr walkerr temp
)
(
  (sample_count <= 1 || src_sid < 0) ? src_sid : (
    src = sample_meta_base + src_sid * SM_STRIDE;
    temp = lerp(8.0, 2.4, clamp01(wideness));
    totalw = 0;

    i = 0;
    while (i < sample_count) (
      i != src_sid ? (
        sm = sample_meta_base + i * SM_STRIDE;
        brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
        sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
        transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
        lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
        tailerr   = abs((sm[SM_FRAMES] - sm[SM_TAILSTART]) - (src[SM_FRAMES] - src[SM_TAILSTART])) / max(src[SM_FRAMES], 1);

        pitcherr = 0;
        (src[SM_PITCHCONF] > 0.45 && sm[SM_PITCHCONF] > 0.45) ? (
          pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
        );

        score = brighterr * 1.10 + sharperr * 1.15 + transerr * 0.85 + lenerr * 0.42 + tailerr * 0.55;
        score += pitcherr * (0.20 + 0.70 * bank_pitchiness);
        walk_mode ? (
          walkerr = sample_descriptor_distance(src, sm, 1);
          score += walkerr * 0.22;
        );

        weight = 0.02 + exp(-score * temp);
        totalw += weight;
      );
      i += 1;
    );

    totalw <= 0 ? src_sid : (
      pick = rand(totalw);
      accum = 0;
      sid = src_sid;
      i = 0;
      while (i < sample_count) (
        i != src_sid ? (
          sm = sample_meta_base + i * SM_STRIDE;
          brighterr = abs(sm[SM_BRIGHT] - src[SM_BRIGHT]);
          sharperr  = abs(sm[SM_SHARP] - src[SM_SHARP]);
          transerr  = abs(sm[SM_FLAGS] - src[SM_FLAGS]);
          lenerr    = abs(log((sm[SM_LENMS] + 1) / (src[SM_LENMS] + 1)));
          tailerr   = abs((sm[SM_FRAMES] - sm[SM_TAILSTART]) - (src[SM_FRAMES] - src[SM_TAILSTART])) / max(src[SM_FRAMES], 1);

          pitcherr = 0;
          (src[SM_PITCHCONF] > 0.45 && sm[SM_PITCHCONF] > 0.45) ? (
            pitcherr = abs(sm[SM_ROOT] - src[SM_ROOT]) / 24;
          );

          score = brighterr * 1.10 + sharperr * 1.15 + transerr * 0.85 + lenerr * 0.42 + tailerr * 0.55;
          score += pitcherr * (0.20 + 0.70 * bank_pitchiness);
          walk_mode ? (
            walkerr = sample_descriptor_distance(src, sm, 1);
            score += walkerr * 0.22;
          );

          weight = 0.02 + exp(-score * temp);
          accum += weight;
          accum >= pick ? (
            sid = i;
            i = sample_count;
          ) : i += 1;
        ) : i += 1;
      );
      sid;
    );
  );
);


function alloc_voice() local(i v found best best_age)
(
  found = -1;
  best = 0;
  best_age = 100000000000;

  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] <= 0 ? (
      found = i;
      i = MAX_VOICES;
    ) : (
      v[VC_AGE] < best_age ? (
        best_age = v[VC_AGE];
        best = i;
      );
      i += 1;
    );
  );

  found >= 0 ? found : best;
);

function prepare_release_attack_bridge(note chan) local(
  i v env same_count any_count same_best any_best same_idx any_idx
  lo hi phase
)
(
  seam_bridge_env = 0;
  seam_bridge_idx = -1;
  seam_bridge_phase = -1;
  seam_bridge_same_note = 0;
  seam_bridge_note = note;
  seam_bridge_chan = chan;

  // Hybrid retrigger seam: if the previous sample is still in granular Release,
  // the next Attack begins from the equivalent envelope level instead of from 0.
  // Same-note releases are preferred; a single same-channel release can bridge too.
  (playback_mode == 2 && granular_amt > 0.0001) ? (
    same_count = 0;
    any_count = 0;
    same_best = 0;
    any_best = 0;
    same_idx = -1;
    any_idx = -1;

    i = 0;
    while (i < MAX_VOICES) (
      v = voice_base + i * VC_STRIDE;
      (v[VC_ACTIVE] > 0 && v[VC_STAGE] == ENV_RELEASE && v[VC_GMODE] > 0 && v[VC_GMIX] > 0.0001 && v[VC_CHAN] == chan) ? (
        env = clamp01(v[VC_ENV]);
        env > 0.0005 ? (
          (v[VC_NOTE] == note) ? (
            same_count += 1;
            env > same_best ? (
              same_best = env;
              same_idx = i;
            );
          ) : (
            any_count += 1;
            env > any_best ? (
              any_best = env;
              any_idx = i;
            );
          );
        );
      );
      i += 1;
    );

    same_count > 0 ? (
      seam_bridge_env = same_best;
      seam_bridge_idx = same_idx;
      seam_bridge_same_note = 1;
    ) : (any_count == 1 ? (
      seam_bridge_env = any_best;
      seam_bridge_idx = any_idx;
      seam_bridge_same_note = 0;
    ));

    seam_bridge_idx >= 0 ? (
      v = voice_base + seam_bridge_idx * VC_STRIDE;
      lo = max(0, floor(v[VC_BODYSTART]));
      hi = max(lo + 1, floor(v[VC_BODYEND]));
      phase = clamp01((v[VC_NEXTSRC] - lo) / max(1, hi - lo));
      seam_bridge_phase = phase;
    );
  );

  seam_bridge_env;
);

function apply_release_attack_bridge(skip_idx) local(i v use)
(
  seam_bridge_env > 0.0005 ? (
    i = 0;
    while (i < MAX_VOICES) (
      v = voice_base + i * VC_STRIDE;
      use = 0;
      (i != skip_idx && v[VC_ACTIVE] > 0 && v[VC_STAGE] == ENV_RELEASE && v[VC_GMODE] > 0 && v[VC_GMIX] > 0.0001 && v[VC_CHAN] == seam_bridge_chan) ? (
        seam_bridge_same_note ? (
          v[VC_NOTE] == seam_bridge_note ? use = 1;
        ) : (
          i == seam_bridge_idx ? use = 1;
        );
      );

      use ? (
        // Handoff, not a hard kill: the old release keeps granular continuity but
        // fades on a short seam budget so the new Attack can take over smoothly.
        v[VC_RSTEP] = min(v[VC_RSTEP], seam_bridge_release_coef);
        v[VC_RHLEFT] = min(v[VC_RHLEFT], seam_bridge_samps);
        // Once this release has been consumed by a new Attack, do not let the
        // old voice spawn fresh body grains. Existing grains can fade, but this
        // prevents the old sample from sounding like a second retrigger.
        v[VC_CANSPAWN] = 0;
        v[VC_GTIMER] = max(v[VC_GTIMER], seam_bridge_samps);
        (!env_slope_is_classic(v[VC_RCURVE], ENV_FALL)) ? (
          v[VC_EPHASE] = 0;
          v[VC_ESTART] = v[VC_ENV];
          v[VC_RLEN] = min(max(1, floor(v[VC_RLEN])), seam_bridge_samps);
        );
      );

      i += 1;
    );
  );
);

function fade_same_note_releases_for_retrigger(note chan skip_idx) local(i v)
(
  // Same-note retriggers should hand off; they should not leave an old Tape/Raw
  // release audibly trailing behind the new Attack. This is deliberately scoped
  // to already-releasing voices so normal polyphonic overlaps remain intact.
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (i != skip_idx && v[VC_ACTIVE] > 0 && v[VC_STAGE] == ENV_RELEASE && v[VC_NOTE] == note && v[VC_CHAN] == chan) ? (
      v[VC_RSTEP] = min(v[VC_RSTEP], seam_bridge_release_coef);
      v[VC_RHLEFT] = min(v[VC_RHLEFT], seam_bridge_samps);
      v[VC_CANSPAWN] = 0;
      v[VC_GTIMER] = max(v[VC_GTIMER], seam_bridge_samps);
      (!env_slope_is_classic(v[VC_RCURVE], ENV_FALL)) ? (
        v[VC_EPHASE] = 0;
        v[VC_ESTART] = v[VC_ENV];
        v[VC_RLEN] = min(max(1, floor(v[VC_RLEN])), seam_bridge_samps);
      );
    );
    i += 1;
  );
);

function start_voice(note vel chan) local(
  velnorm sid sm donor donor_sm voice_idx v
  srcsr norm gain env0 lively playmode voice_stretch voice_stretch_norm
  driftcents raw_rate base_rate
  transrich transprot translock hold_ms trans_hold_src trans_hold_out attack_preroll
  attack_norm pre_avail pre_keep align_guard align_jit
  j jmax pre startpos softskip gain_jit_db
  bodystart bodyend tailstart donor_tail min_body_span remain voice_hold_samps
)
(
  sample_count <= 0 ? 0 : (
    velnorm = vel / 127;
    sid = choose_sample(note, velnorm);
    sm = sample_meta_base + sid * SM_STRIDE;

    prepare_release_attack_bridge(note, chan);

    voice_idx = alloc_voice();
    v = voice_base + voice_idx * VC_STRIDE;
    note_gate_forget_voice(v);

    j = 0;
    while (j < VC_STRIDE) (
      v[j] = 0;
      j += 1;
    );
    grain_hist_clear_voice(voice_idx);

    note_counter += 1;
    last_note = note;
    last_sid = sid;

    lively = clamp01(slider9);
    playmode = playback_mode;
    playmode == 0 ? voice_stretch = 1 : voice_stretch = stretch_ratio;
    voice_stretch = max(1, voice_stretch);
    voice_stretch_norm = clamp01((voice_stretch - 1) / 3);

    srcsr = sm[SM_SR];
    norm  = sm[SM_NORM];
    gain  = (0.10 + 0.90 * (velnorm ^ 1.35)) * lerp(norm, 1, truth_mix);
    gain_jit_db = (rand(1) - 0.5) * lively * 0.8;
    gain *= db2amp(gain_jit_db);
    gain  = min(gain, 2.0);

    transrich = clamp01(sm[SM_FLAGS]);
    transprot = 0;
    transient_mode == 1 ? transprot = 1
    : transient_mode == 2 ? transprot = 0
    : transprot = clamp01((transrich - 0.38) / 0.44);
    translock = transprot >= 0.22 ? 1 : 0;

    driftcents = (rand(1) - 0.5) * (0.25 + lively * lively * 10.0);

    onset_mode_active ? (
      attack_norm = curve_norm(slider2, 0.1, 500, CURVE_TIME);
      pre_avail = max(0, sm[SM_ATTACK]);
      pre_keep = floor(pre_avail * attack_norm);

      translock ? (
        align_guard = min(pre_avail, max(0, floor(srcsr * (0.00020 + 0.00035 * transprot))));
        align_jit = floor(lively * (1 - transprot) * max(1, min(6, 1 + pre_avail * 0.035)));
        startpos = floor(sm[SM_ATTACK] - pre_keep - align_guard + (rand(1) - 0.5) * align_jit);
      ) : (
        pre  = min(pre_avail, floor(2 + attack_norm * min(64, 8 + pre_avail * 0.18)));
        jmax = floor((0.35 + lively * 2.05) * max(2, min(18, 2 + pre_avail * 0.08)));
        softskip = max(0, -slider7) * min(16, 2 + pre_avail * 0.06);
        startpos = floor(sm[SM_ATTACK] - max(pre_keep, pre) + (rand(1) - 0.5) * jmax + softskip);
      );
    ) : (
      translock ? (
        attack_preroll = min(sm[SM_ATTACK], max(0, floor(srcsr * (0.00035 + 0.00045 * transprot))));
        jmax = floor(lively * (1 - transprot) * min(4, 1 + sm[SM_ATTACK] * 0.02));
        startpos = floor(sm[SM_ATTACK] - attack_preroll + (rand(1) - 0.5) * jmax);
      ) : (
        pre  = min(sm[SM_ATTACK], 8 + lively * 8);
        jmax = floor((0.25 + lively * 1.75) * min(16, 2 + sm[SM_ATTACK] * 0.08));
        softskip = max(0, -slider7) * min(16, 2 + sm[SM_ATTACK] * 0.06);
        startpos = floor(sm[SM_ATTACK] - pre + (rand(1) - 0.5) * jmax + softskip);
      );
    );

    startpos = clamp(startpos, 0, max(0, sm[SM_FRAMES] - 2));
    raw_rate = (srcsr / srate) * midi_ratio(pitch_semi) * cents_ratio(driftcents);
    base_rate = raw_rate / voice_stretch;

    hold_ms = translock ? (lerp(3.5, 9.5, transprot) + voice_stretch_norm * lerp(0.0, 2.5, transprot)) : 0;
    hold_ms = min(hold_ms, sm[SM_LENMS] * 0.22);
    trans_hold_src = translock ? min(max(0, sm[SM_FRAMES] - 2 - startpos), floor(srcsr * hold_ms * 0.001)) : 0;
    trans_hold_out = translock ? clamp(floor(trans_hold_src / max(abs(raw_rate), 0.000001)), 0, 4096) : 0;

    bodystart = clamp(sm[SM_HEADEND], 0, max(0, sm[SM_FRAMES] - 2));
    tailstart = clamp(sm[SM_TAILSTART], bodystart + 1, max(bodystart + 1, sm[SM_FRAMES] - 2));
    remain = max(1, tailstart - bodystart);
    min_body_span = min(max(48, floor(max(srcsr * (0.020 + 0.016 * lively), hybrid_grain_samps * 0.85))), remain);
    remain < min_body_span ? (
      bodystart = max(sm[SM_HEADEND], tailstart - min_body_span);
      bodystart = clamp(bodystart, 0, max(0, tailstart - 1));
    );
    bodyend = max(bodystart + 1, tailstart);
    voice_hold_samps = max(0, hold_samps);

    donor = choose_region_donor(sid, 1, tail_borrow * (0.55 + 0.45 * lively), voice_idx);
    donor < 0 ? donor = sid;
    donor_sm = sample_meta_base + donor * SM_STRIDE;
    donor_tail = clamp(donor_sm[SM_TAILSTART], 0, max(0, donor_sm[SM_FRAMES] - 2));

    v[VC_ACTIVE] = 1;
    v[VC_NOTE]   = note;
    v[VC_CHAN]   = chan;
    v[VC_SAMPLE] = sid;
    v[VC_POS]    = startpos;
    v[VC_RATE]   = base_rate;
    v[VC_BASE]   = gain;
    env0 = (attack_samps <= 1 || (translock && attack_samps <= floor(0.010 * srate))) ? 1 : 0;
    (playmode == 2 && granular_amt > 0.0001 && seam_bridge_env > 0.0005) ? (
      // Attack begins from the current Release level, matching the Phase Plant-style
      // release-point -> equivalent-attack-point retrigger behavior. This overrides
      // the usual fast Punch/Gaussian env=1 shortcut, except for a true 1-sample attack.
      env0 = attack_samps <= 1 ? 1 : min(0.985, seam_bridge_env);
    );
    v[VC_ENV]    = env0;
    v[VC_ASTEP]  = attack_coef;
    v[VC_DSTEP]  = decay_coef;
    v[VC_RSTEP]  = release_coef;
    v[VC_HLEFT]  = voice_hold_samps;
    v[VC_STAGE]  = env0 >= 1 ? (voice_hold_samps > 0 ? ENV_HOLD : ENV_DECAY) : ENV_ATTACK;
    v[VC_AGE]    = note_counter;
    v[VC_EPHASE] = 0;
    v[VC_ESTART] = env0;
    v[VC_ALEN]   = attack_samps;
    v[VC_DLEN]   = decay_samps;
    v[VC_RLEN]   = release_samps;
    v[VC_ACURVE] = attack_slope_pct;
    v[VC_DCURVE] = decay_slope_pct;
    v[VC_RCURVE] = release_slope_pct;
    (playmode == 2 && granular_amt > 0.0001 && seam_bridge_env > 0.0005 && env0 < 1 && !env_slope_is_classic(attack_slope_pct, ENV_RISE)) ? (
      // For non-classic slopes, continue from the equivalent Attack curve point
      // instead of spending a full Attack time above the inherited Release level.
      v[VC_EPHASE] = env_slope_inv(env0, env_segment_slope(attack_slope_pct, ENV_RISE)) * max(1, attack_samps);
    );

    v[VC_GMODE]    = (playmode == 2) ? 1 : 0;
    v[VC_OHOP]     = hybrid_hop_samps;
    v[VC_GSIZE]    = hybrid_grain_samps;
    // Start the granular layer as soon as transient protection clears so the
    // OLA field can fill before the direct path runs out.
    v[VC_GTIMER]   = max(1, trans_hold_out + 1);
    v[VC_NEXTSRC]  = max(bodystart, min(startpos, bodyend - 1));
    (playmode == 2 && granular_amt > 0.0001 && seam_bridge_env > 0.0005 && seam_bridge_phase >= 0) ? (
      // The new Hybrid body cursor starts at the matching normalized body phase
      // of the releasing voice, while the direct head still uses Gaussian/onset alignment.
      v[VC_NEXTSRC] = clamp(bodystart + seam_bridge_phase * max(1, bodyend - bodystart - 1), bodystart, max(bodystart, bodyend - 1));
      v[VC_GTIMER] = min(v[VC_GTIMER], max(1, floor(hybrid_hop_samps * 0.25)));
    );
    v[VC_SRCHOP]   = max(0.25, abs(base_rate) * hybrid_hop_samps);
    v[VC_CANSPAWN] = (playmode == 2 && granular_amt > 0.0001) ? 1 : 0;
    v[VC_TLEFT]    = trans_hold_out;
    v[VC_TPROT]    = transprot;
    v[VC_DONOR]    = donor;
    v[VC_DONORPOS] = donor_tail;
    v[VC_BODYSTART]= bodystart;
    v[VC_TAILSTART]= tailstart;
    v[VC_BODYEND]  = bodyend;
    v[VC_GMIX]     = granular_amt;
    v[VC_TAILMIX]  = tail_borrow;
    v[VC_MODE]     = playmode;
    v[VC_STRETCH]  = voice_stretch;
    v[VC_THOLD]    = max(1, trans_hold_out);
    v[VC_RHLEFT]   = 0;
    v[VC_RHLEN]    = max(1, release_handoff_samps);

    apply_release_attack_bridge(voice_idx);
    fade_same_note_releases_for_retrigger(note, chan, voice_idx);

    sm[SM_LASTUSED] = note_counter;
    push_recent(sid);

    walk_prev_sid = walk_last_sid;
    walk_last_sid = sid;
    walk_steps += 1;
  );
);

function release_voice_internal(v) local(donor donor_sm donor_tail body_start body_end release_src)
(
  (v[VC_ACTIVE] > 0 && v[VC_STAGE] != ENV_RELEASE) ? (
    release_samps <= 1 ? (
      v[VC_ENV] = 0;
      v[VC_STAGE] = ENV_OFF;
      v[VC_ACTIVE] = 0;
    ) : (
      v[VC_STAGE] = ENV_RELEASE;
      v[VC_RSTEP] = release_coef;
      v[VC_HLEFT] = 0;
      v[VC_TLEFT] = 0;
      v[VC_EPHASE] = 0;
      v[VC_ESTART] = v[VC_ENV];
      v[VC_RLEN] = release_samps;
      v[VC_RCURVE] = release_slope_pct;
      (v[VC_GMODE] > 0) ? (
        // Release must continue from the current body/playback position, not
        // restart the body window. This prevents short one-shots from replaying
        // their body grain after the direct head has already finished.
        (v[VC_GMIX] > 0.0001) ? (
          body_start = max(0, floor(v[VC_BODYSTART]));
          body_end = max(body_start + 1, floor(v[VC_BODYEND]));
          release_src = clamp(max(v[VC_NEXTSRC], min(v[VC_POS], body_end - 1)), body_start, max(body_start, body_end - 1));
          v[VC_NEXTSRC] = release_src;
        );
        v[VC_CANSPAWN] = (v[VC_GMIX] > 0.0001 || v[VC_TAILMIX] > 0.0001) ? 1 : 0;
        v[VC_RHLEN] = max(1, release_handoff_samps);
        v[VC_RHLEFT] = v[VC_RHLEN];
        donor = v[VC_DONOR] | 0;
        donor_sm = sample_meta_base + donor * SM_STRIDE;
        donor_tail = clamp(donor_sm[SM_TAILSTART], 0, max(0, donor_sm[SM_FRAMES] - 2));
        v[VC_DONORPOS] < donor_tail ? v[VC_DONORPOS] = donor_tail;
        v[VC_GTIMER] = min(v[VC_GTIMER], 1);
      ) : (
        v[VC_CANSPAWN] = 0;
        v[VC_RHLEFT] = 0;
      );
    );
  );
);

function release_oldest_held_note_voice(note chan) local(i v best_idx best_age)
(
  best_idx = -1;
  best_age = 100000000000;

  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    (v[VC_ACTIVE] > 0 && v[VC_NOTE] == note && v[VC_CHAN] == chan && v[VC_STAGE] != ENV_RELEASE) ? (
      v[VC_AGE] < best_age ? (
        best_age = v[VC_AGE];
        best_idx = i;
      );
    );
    i += 1;
  );

  best_idx >= 0 ? (
    v = voice_base + best_idx * VC_STRIDE;
    release_voice_internal(v);
    1;
  ) : 0;
);

function release_voice(note chan) local(target held guard idx)
(
  // Reconcile active held voices to the MIDI gate count for this note/channel.
  // This fixes stuck one-voice states: an extra Note Off with no matching Note On
  // drives the target to zero and releases every held orphan instead of only one.
  idx = note_gate_idx(note, chan);
  target = clamp(note_gate_base[idx], 0, MAX_VOICES);
  held = count_held_note_voices(note, chan);
  guard = 0;

  while (held > target && guard < MAX_VOICES) (
    release_oldest_held_note_voice(note, chan) ? (
      held -= 1;
    ) : (
      held = target;
    );
    guard += 1;
  );
);

function release_all_voices_transport(hard) local(i v)
(
  i = 0;
  while (i < MAX_VOICES) (
    v = voice_base + i * VC_STRIDE;
    v[VC_ACTIVE] > 0 ? (
      hard ? (
        v[VC_ENV] = 0;
        v[VC_STAGE] = ENV_OFF;
        v[VC_ACTIVE] = 0;
      ) : (
        release_voice_internal(v);
      );
    );
    i += 1;
  );

  reset_note_gates();

  hard ? (
    reset_weight_buffers();
    reset_clean_buffers();
    reset_room_buffers();
    reset_push_buffers();
  );
);

function ui_button(id x y w h) local(hot clicked)
(
  clicked = 0;
  hot = pt_in(x, y, w, h);

  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_pressed && hot && ui_active < 0 ? ui_active = id;
  ui_active == id ? (
    !mouse_down ? (
      hot ? clicked = 1;
      ui_active = -1;
    );
  );

  (hot || ui_active == id) ? (
    gfx_r = 0.24; gfx_g = 0.51; gfx_b = 0.76; gfx_a = 1;
  ) : (
    gfx_r = 0.16; gfx_g = 0.20; gfx_b = 0.26; gfx_a = 1;
  );
  gfx_rect(x, y, w, h, 1);
  gfx_r = 0.34; gfx_g = 0.42; gfx_b = 0.52; gfx_a = 1;
  gfx_rect(x, y, w, h, 0);

  clicked;
);

function ui_knob(id x y r val vmin vmax defval wheel_step) local(hot norm ang px py vv dbl step_amt)
(
  hot = ((mouse_x - x) * (mouse_x - x) + (mouse_y - y) * (mouse_y - y)) <= r * r;
  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_rpressed && hot ? (
    abs(val - defval) > 0.0000001 ? (
      val = defval;
      ui_value_changed = 1;
    );
    ui_active == id ? ui_active = -1;
  );

  mouse_pressed && hot && ui_active < 0 ? (
    dbl = (ui_last_click_id == id) && ((ui_now - ui_last_click_t) < ui_dblclick_time);
    ui_last_click_id = id;
    ui_last_click_t = ui_now;

    dbl ? (
      abs(val - defval) > 0.0000001 ? (
        val = defval;
        ui_value_changed = 1;
      );
      ui_active = -1;
    ) : (
      ui_active = id;
      ui_down_y = mouse_y;
      ui_down_val = curve_norm(val, vmin, vmax, CURVE_LINEAR);
    );
  );

  hot && !ui_wheel_used && abs(ui_wheel) >= 1 && !ui_shift ? (
    step_amt = wheel_step * max(1, floor(abs(ui_wheel) / 120 + 0.5));
    norm = curve_norm(val, vmin, vmax, CURVE_LINEAR);
    norm = clamp01(norm + (ui_wheel > 0 ? step_amt : -step_amt));
    vv = curve_denorm(norm, vmin, vmax, CURVE_LINEAR);
    abs(vv - val) > 0.0000001 ? (
      val = vv;
      ui_value_changed = 1;
    );
    ui_wheel_used = 1;
  );

  ui_active == id ? (
    mouse_down ? (
      norm = clamp01(ui_down_val - (mouse_y - ui_down_y) / 150);
      vv = curve_denorm(norm, vmin, vmax, CURVE_LINEAR);
      abs(vv - val) > 0.0000001 ? (
        val = vv;
        ui_value_changed = 1;
      );
    ) : (
      ui_active = -1;
    );
  );

  gfx_r = 0.11; gfx_g = 0.14; gfx_b = 0.18; gfx_a = 1;
  gfx_circle(x, y, r, 1);
  gfx_r = 0.22; gfx_g = 0.28; gfx_b = 0.35; gfx_a = 1;
  gfx_circle(x, y, r, 0);

  norm = curve_norm(val, vmin, vmax, CURVE_LINEAR);
  ang = (-0.75 + norm * 1.5) * 3.14159265358979;
  px = x + cos(ang) * (r - 7);
  py = y + sin(ang) * (r - 7);

  gfx_r = hot || ui_active == id ? 0.85 : 0.68;
  gfx_g = hot || ui_active == id ? 0.92 : 0.78;
  gfx_b = 0.98;
  gfx_a = 1;
  gfx_line(x, y, px, py);

  (hot || ui_active == id) ? (
    gfx_r = 0.35; gfx_g = 0.60; gfx_b = 0.86; gfx_a = 1;
    gfx_circle(x, y, r + 2, 0);
  );

  val;
);

function ui_vslider(id x y w h val vmin vmax curve_mode defval wheel_step) local(hot norm py vv fillh dbl step_amt)
(
  hot = pt_in(x, y, w, h);
  (hot || ui_active == id) ? ui_hover_id = id;

  mouse_rpressed && hot ? (
    abs(val - defval) > 0.0000001 ? (
      val = defval;
      ui_value_changed = 1;
    );
    ui_active == id ? ui_active = -1;
  );

  mouse_pressed && hot && ui_active < 0 ? (
    dbl = (ui_last_click_id == id) && ((ui_now - ui_last_click_t) < ui_dblclick_time);
    ui_last_click_id = id;
    ui_last_click_t = ui_now;

    dbl ? (
      abs(val - defval) > 0.0000001 ? (
        val = defval;
        ui_value_changed = 1;
      );
      ui_active = -1;
    ) : (
      ui_active = id;
    );
  );

  hot && !ui_wheel_used && abs(ui_wheel) >= 1 && !ui_shift ? (
    step_amt = wheel_step * max(1, floor(abs(ui_wheel) / 120 + 0.5));
    norm = curve_norm(val, vmin, vmax, curve_mode);
    norm = clamp01(norm + (ui_wheel > 0 ? step_amt : -step_amt));
    vv = curve_denorm(norm, vmin, vmax, curve_mode);
    abs(vv - val) > 0.0000001 ? (
      val = vv;
      ui_value_changed = 1;
    );
    ui_wheel_used = 1;
  );

  ui_active == id ? (
    mouse_down ? (
      norm = clamp01(1 - ((mouse_y - y) / max(h, 1)));
      vv = curve_denorm(norm, vmin, vmax, curve_mode);
      abs(vv - val) > 0.0000001 ? (
        val = vv;
        ui_value_changed = 1;
      );
    ) : (
      ui_active = -1;
    );
  );

  gfx_r = 0.10; gfx_g = 0.13; gfx_b = 0.17; gfx_a = 1;
  gfx_rect(x, y, w, h, 1);
  gfx_r = 0.20; gfx_g = 0.25; gfx_b = 0.31; gfx_a = 1;
  gfx_rect(x, y, w, h, 0);

  norm = curve_norm(val, vmin, vmax, curve_mode);
  fillh = clamp01(norm) * h;
  gfx_r = 0.26; gfx_g = 0.56; gfx_b = 0.84; gfx_a = 0.88;
  gfx_rect(x + 2, y + h - fillh + 2, w - 4, max(0, fillh - 4), 1);

  py = y + h - norm * h;
  gfx_r = 0.90; gfx_g = 0.95; gfx_b = 1.0; gfx_a = 1;
  gfx_rect(x - 2, py - 3, w + 4, 6, 1);

  hot || ui_active == id ? (
    gfx_r = 0.34; gfx_g = 0.64; gfx_b = 0.90; gfx_a = 1;
    gfx_rect(x - 2, y - 2, w + 4, h + 4, 0);
  );

  val;
);

function ui_shift_wheel_slope(id val defval) local(step_amt)
(
  (ui_hover_id == id && ui_shift && !ui_wheel_used && abs(ui_wheel) >= 1) ? (
    step_amt = 5 * max(1, floor(abs(ui_wheel) / 120 + 0.5));
    val = clamp(val + (ui_wheel > 0 ? step_amt : -step_amt), -100, 100);
    ui_wheel_used = 1;
    ui_value_changed = 1;
  );

  val;
);

function draw_curve_line(x1 y1 x2 y2 mode) local(i steps t u px py nx ny)
(
  steps = 16;
  px = x1;
  py = y1;
  i = 1;
  while (i <= steps) (
    t = i / steps;
    u = env_slope_shape(t, mode);
    nx = x1 + (x2 - x1) * t;
    ny = y1 + (y2 - y1) * u;
    gfx_line(px, py, nx, ny);
    px = nx;
    py = ny;
    i += 1;
  );
);

function draw_center_buf(x y w) local(tw th)
(
  gfx_measurestr(#ui_buf, tw, th);
  gfx_x = x + max(0, (w - tw) * 0.5);
  gfx_y = y;
  gfx_drawstr(#ui_buf);
);

function draw_tooltip_box() local(tw1 th1 tw2 th2 tw th pad bx by bw bh)
(
  strlen(#tip_title) > 0 ? (
    pad = 10;

    gfx_setfont(1, "Arial", 14, 0);
    gfx_measurestr(#tip_title, tw1, th1);
    gfx_setfont(1, "Arial", 13, 0);
    gfx_measurestr(#tip_body, tw2, th2);

    tw = max(tw1, tw2);
    th = th1 + th2 + 6;
    bw = tw + pad * 2;
    bh = th + pad * 2;

    bx = clamp(mouse_x + 18, 8, gfx_w - bw - 8);
    by = clamp(mouse_y + 18, 8, gfx_h - bh - 8);

    gfx_r = 0.02; gfx_g = 0.03; gfx_b = 0.05; gfx_a = 0.65;
    gfx_rect(bx + 3, by + 4, bw, bh, 1);

    gfx_r = 0.085; gfx_g = 0.10; gfx_b = 0.135; gfx_a = 0.96;
    gfx_rect(bx, by, bw, bh, 1);
    gfx_r = 0.28; gfx_g = 0.48; gfx_b = 0.72; gfx_a = 1;
    gfx_rect(bx, by, bw, bh, 0);

    gfx_setfont(1, "Arial", 14, 0);
    gfx_r = 0.93; gfx_g = 0.96; gfx_b = 1.0; gfx_a = 1;
    gfx_x = bx + pad; gfx_y = by + pad - 1;
    gfx_drawstr(#tip_title);

    gfx_setfont(1, "Arial", 13, 0);
    gfx_r = 0.73; gfx_g = 0.80; gfx_b = 0.90; gfx_a = 1;
    gfx_x = bx + pad; gfx_y = by + pad + th1 + 3;
    gfx_drawstr(#tip_body);
  );
);

