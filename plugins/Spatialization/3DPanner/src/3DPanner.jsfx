gfx_printf("V6.12.0: Standalone by default; switch Mode to Manager to opt into manager-name routing.");

// --- Manager Link side tab + drawer overlay ---
// Tab is the only visible Manager affordance in standalone mode.
gfx_set(ui_drawer_open ? 0.16 : 0.12, ui_drawer_open ? 0.28 : 0.16, ui_drawer_open ? 0.38 : 0.22, 0.98);
gfx_rect(drawer_tab_x, drawer_tab_y, drawer_tab_w, drawer_tab_h);
gfx_roundrect(drawer_tab_x, drawer_tab_y, drawer_tab_w, drawer_tab_h, 10*ui_s, 1);
gfx_set(0.24,0.78,1.0, hover_drawer_tab ? 0.95 : 0.68);
gfx_roundrect(drawer_tab_x, drawer_tab_y, drawer_tab_w, drawer_tab_h, 10*ui_s, 0);
gfx_setfont(4,"Arial",fs4,'b');
gfx_set(0.76,0.88,0.98,1);
gfx_x = drawer_tab_x + 7*ui_s; gfx_y = drawer_tab_y + 16*ui_s; gfx_printf("MGR");
gfx_x = drawer_tab_x + 7*ui_s; gfx_y = drawer_tab_y + 34*ui_s; gfx_printf("LNK");
gfx_set(ui_link ? ok_r : mut_r, ui_link ? ok_g : mut_g, ui_link ? ok_b : mut_b, 1);
gfx_circle(drawer_tab_x + drawer_tab_w*0.5, drawer_tab_y + drawer_tab_h - 16*ui_s, 4.5*ui_s, 1, 1);

ui_drawer_open ? (
  // shadow
  gfx_set(0,0,0,0.38);
  gfx_rect(drawer_x + 5*ui_s, drawer_y + 5*ui_s, drawer_w, drawer_h);
  gfx_roundrect(drawer_x + 5*ui_s, drawer_y + 5*ui_s, drawer_w, drawer_h, 14*ui_s, 1);

  gfx_set(0.075,0.087,0.118,0.98);
  gfx_rect(drawer_x, drawer_y, drawer_w, drawer_h);
  gfx_roundrect(drawer_x, drawer_y, drawer_w, drawer_h, 14*ui_s, 1);
  gfx_set(0.24,0.78,1.0,0.74);
  gfx_roundrect(drawer_x, drawer_y, drawer_w, drawer_h, 14*ui_s, 0);

  gfx_setfont(2,"Arial",fs2,'b');
  gfx_set(txt_r,txt_g,txt_b,1);
  gfx_x = drawer_x + 14*ui_s; gfx_y = drawer_y + 12*ui_s; gfx_printf("Manager Link Drawer");
  gfx_setfont(4,"Arial",fs4);
  gfx_set(mut_r,mut_g,mut_b,1);
  gfx_x = drawer_x + 14*ui_s; gfx_y = drawer_y + 31*ui_s; gfx_printf("Name this source, choose a Manager, then switch Mode to Manager when wanted.");

  // Manager text box
  gfx_setfont(4,"Arial",fs4,'b');
  gfx_set(mut_r,mut_g,mut_b,1);
  gfx_x = field_x; gfx_y = bus_y - 12*ui_s; gfx_printf("Manager");
  gfx_set(0.050,0.062,0.086,1);
  gfx_rect(field_x,bus_y,field_w,box_h);
  gfx_set((hover_bus_box || ui_text_active==1) ? 0.47 : 0.28, (hover_bus_box || ui_text_active==1) ? 0.54 : 0.32, (hover_bus_box || ui_text_active==1) ? 0.68 : 0.40, 0.92);
  gfx_roundrect(field_x,bus_y,field_w,box_h,6*ui_s,0);
  gfx_set(0.90,0.93,0.98,1);
  gfx_setfont(4,"Arial",fs4);
  gfx_x = field_x + 6*ui_s; gfx_y = bus_y + 4*ui_s;
  ui_text_active == 1 ? gfx_drawstr(#p3d_edit_text) : gfx_drawstr(#target_manager);
  (ui_text_active == 1 && (floor(ui_text_frames/18)%2)==0) ? gfx_drawstr("_");
  gfx_set(hover_scene_btn || ui_scene_menu ? 0.22 : 0.13, hover_scene_btn || ui_scene_menu ? 0.28 : 0.17, hover_scene_btn || ui_scene_menu ? 0.38 : 0.24, 1);
  gfx_rect(scene_btn_x,bus_y,scene_btn_w,box_h); gfx_roundrect(scene_btn_x,bus_y,scene_btn_w,box_h,6*ui_s,1);
  gfx_set(txt_r,txt_g,txt_b,1); gfx_x = scene_btn_x + 6*ui_s; gfx_y = bus_y + 4*ui_s; gfx_printf("v");

  // Object Name text box
  gfx_setfont(4,"Arial",fs4,'b');
  gfx_set(mut_r,mut_g,mut_b,1);
  gfx_x = field_x; gfx_y = name_y - 12*ui_s; gfx_printf("Object Name");
  gfx_set(0.050,0.062,0.086,1);
  gfx_rect(field_x,name_y,field_w,box_h);
  gfx_set((hover_name_box || ui_text_active==2) ? 0.47 : 0.28, (hover_name_box || ui_text_active==2) ? 0.54 : 0.32, (hover_name_box || ui_text_active==2) ? 0.68 : 0.40, 0.92);
  gfx_roundrect(field_x,name_y,field_w,box_h,6*ui_s,0);
  gfx_set(0.90,0.93,0.98,1);
  gfx_setfont(4,"Arial",fs4);
  (ui_text_active == 2 && ui_text_select_all) ? (gfx_set(0.24,0.78,1.0,0.22); gfx_rect(field_x+4*ui_s,name_y+3*ui_s,field_w-8*ui_s,box_h-6*ui_s); gfx_set(txt_r,txt_g,txt_b,1););
  gfx_x = field_x + 6*ui_s; gfx_y = name_y + 4*ui_s;
  ui_text_active == 2 ? gfx_drawstr(#p3d_edit_text) : gfx_drawstr(#object_name);
  (ui_text_active == 2 && (floor(ui_text_frames/18)%2)==0) ? gfx_drawstr("_");

  // Object IDs and numeric manager slots are internal; visible routing is Mode + Name -> Manager.

  // Standalone/Manager toggle - explicit default OFF.
  gfx_setfont(4,"Arial",fs4,'b');
  gfx_set(mut_r,mut_g,mut_b,1);
  gfx_x = link_btn_x; gfx_y = link_btn_y - 14*ui_s; gfx_printf("Mode");
  gfx_set(ui_link ? ok_r : 0.18, ui_link ? ok_g : 0.21, ui_link ? ok_b : 0.28, hover_link_btn ? 0.95 : 0.86);
  gfx_rect(link_btn_x,link_btn_y,link_btn_w,link_btn_h); gfx_roundrect(link_btn_x,link_btn_y,link_btn_w,link_btn_h,9*ui_s,1);
  gfx_set(0.07,0.08,0.10,1);
  gfx_x = link_btn_x + 12*ui_s; gfx_y = link_btn_y + 8*ui_s;
  ui_link ? gfx_printf("MANAGER") : gfx_printf("STANDALONE");

  // Manager amount is intentionally internal: Manager Mode is a clear on/off user choice.
  gfx_setfont(4,"Arial",fs4);
  gfx_set(mut_r,mut_g,mut_b,1);
  gfx_x = link_btn_x; gfx_y = link_btn_y + link_btn_h + 8*ui_s;
  ui_link ? gfx_printf("Only the named Manager can move this panner.") : gfx_printf("Standalone ignores all Manager movement.");

  // Status/readout
  link_status_y = link_btn_y + link_btn_h + 28*ui_s;
  gfx_setfont(4,"Arial",fs4);
  gfx_set(last_manager_active ? ok_r : (ui_link ? warn_r : mut_r), last_manager_active ? ok_g : (ui_link ? warn_g : mut_g), last_manager_active ? ok_b : (ui_link ? warn_b : mut_b), 1);
  gfx_x = field_x; gfx_y = link_status_y;
  ui_link ? (last_manager_active ? gfx_printf("Manager active | Cam %+.1f deg", last_camera_rot) : gfx_printf("Manager mode: waiting for matching Name")) : gfx_printf("Standalone: manager ignored");
  gfx_set(mut_r,mut_g,mut_b,1);
  gfx_x = field_x; gfx_y = link_status_y + 17*ui_s; gfx_printf("World %+.0f | View %+.0f | Cue %+.0f", last_world_az, last_visual_az, last_cue_az);
  gfx_x = field_x; gfx_y = link_status_y + 34*ui_s; gfx_printf("Backspace/Delete edit text. Enter commits. Manager Mode must be enabled to follow.");

  // Available managers dropdown. Panners subscribe by Manager Name.
  ui_scene_menu ? (
    menu_rows = scene_rows_vis;
    menu_rows < 1 ? menu_rows = 1;
    menu_rows > 6 ? menu_rows = 6;
    menu_h = menu_rows * scene_row_h + 6*ui_s;
    gfx_set(0,0,0,0.42); gfx_rect(scene_menu_x+3*ui_s, scene_menu_y+3*ui_s, scene_menu_w, menu_h); gfx_roundrect(scene_menu_x+3*ui_s, scene_menu_y+3*ui_s, scene_menu_w, menu_h, 8*ui_s, 1);
    gfx_set(0.045,0.055,0.075,0.98); gfx_rect(scene_menu_x, scene_menu_y, scene_menu_w, menu_h); gfx_roundrect(scene_menu_x, scene_menu_y, scene_menu_w, menu_h, 8*ui_s, 1);
    gfx_set(0.24,0.78,1.0,0.65); gfx_roundrect(scene_menu_x, scene_menu_y, scene_menu_w, menu_h, 8*ui_s, 0);

    scene_real_count <= 0 ? (
      yy = scene_menu_y + 3*ui_s;
      gfx_set(0.08,0.10,0.14,1);
      gfx_rect(scene_menu_x + 4*ui_s, yy, scene_menu_w - 8*ui_s, scene_row_h-1*ui_s);
      gfx_setfont(4,"Arial",fs4,'b'); gfx_set(txt_r,txt_g,txt_b,1); gfx_x = scene_menu_x + 10*ui_s; gfx_y = yy + 3*ui_s; gfx_printf("Manager");
      gfx_set(mut_r,mut_g,mut_b,1); gfx_x = scene_menu_x + scene_menu_w - 86*ui_s; gfx_y = yy + 3*ui_s; gfx_printf("no manager");
    ) : (
      scene_drawn = 0;
      scene_i = 0;
      loop(P3D_MAX_SCENES,
        (scene_i < p3d_ui_scene_count && scene_drawn < 6) ? (
          yy = scene_menu_y + 3*ui_s + scene_drawn*scene_row_h;
          gfx_set(scene_hover_idx == scene_drawn ? 0.17 : 0.08, scene_hover_idx == scene_drawn ? 0.24 : 0.10, scene_hover_idx == scene_drawn ? 0.32 : 0.14, 1);
          gfx_rect(scene_menu_x + 4*ui_s, yy, scene_menu_w - 8*ui_s, scene_row_h-1*ui_s);
          p3d_ui_scene_copy_nth(scene_i, #p3d_scene_draw);
          gfx_setfont(4,"Arial",fs4); gfx_set(txt_r,txt_g,txt_b,1); gfx_x = scene_menu_x + 10*ui_s; gfx_y = yy + 3*ui_s; gfx_drawstr(#p3d_scene_draw);
          gfx_set(mut_r,mut_g,mut_b,1); gfx_x = scene_menu_x + scene_menu_w - 54*ui_s; gfx_y = yy + 3*ui_s; gfx_printf("live");
          scene_drawn += 1;
        );
        scene_i += 1;
      );
    );
  );
);

// --- hover tooltip card ---
(tooltip_show) ? (
  tip_w = 318*ui_s;
  tip_h = 88*ui_s;
  tip_w < 230 ? tip_w = 230;
  tip_h < 72 ? tip_h = 72;

  // Dock tooltip away from the active region. Near-cursor cards covered the next
  // lanes and made the controls feel offset even when the math was correct.
  mouse_x >= rx ? (
    // Hovering right-side controls: put help on the canvas side.
    tip_x = canvas_x + 16*ui_s;
    tip_y = canvas_y + canvas_h - tip_h - 16*ui_s;
  ) : (
    // Hovering the canvas/chips: put help in the lower-right info area.
    tip_x = rx;
    tip_y = c3y + c3h - tip_h - 8*ui_s;
    tip_y < c3y + 8*ui_s ? tip_y = c3y + 8*ui_s;
  );
  tip_x + tip_w > gfx_w - pad ? tip_x = gfx_w - pad - tip_w;
  tip_y + tip_h > gfx_h - pad ? tip_y = gfx_h - pad - tip_h;
  tip_x < pad ? tip_x = pad;
  tip_y < pad ? tip_y = pad;

  gfx_set(0,0,0,0.42);
  gfx_rect(tip_x + 4*ui_s, tip_y + 5*ui_s, tip_w, tip_h);
  gfx_roundrect(tip_x + 4*ui_s, tip_y + 5*ui_s, tip_w, tip_h, 10*ui_s, 1);

  gfx_set(0.065,0.075,0.098,0.97);
  gfx_rect(tip_x, tip_y, tip_w, tip_h);
  gfx_roundrect(tip_x, tip_y, tip_w, tip_h, 10*ui_s, 1);
  gfx_set(0.40,0.47,0.60,0.88);
  gfx_roundrect(tip_x, tip_y, tip_w, tip_h, 10*ui_s, 0);

  // Accent stripe by visual/control family.
  tip_id == 22 || tip_id == 107 ? gfx_set(bounce_r,bounce_g,bounce_b,0.96) :
  tip_id == 108 || tip_id == 29 ? gfx_set(occ_cr,occ_cg,occ_cb,0.96) :
  tip_id == 109 || tip_id == 28 ? gfx_set(ok_r,ok_g,ok_b,0.96) :
  tip_id == 103 || tip_id == 27 ? gfx_set(0.78,0.82,0.92,0.96) :
  tip_id == 106 || tip_id == 23 ? gfx_set(0.95,0.66,0.24,0.96) :
  gfx_set(src_cr,src_cg,src_cb,0.96);
  gfx_rect(tip_x, tip_y, 4*ui_s, tip_h);

  tip_tx = tip_x + 13*ui_s;
  tip_title_y = tip_y + 9*ui_s;
  tip_l1 = tip_y + 31*ui_s;
  tip_l2 = tip_y + 49*ui_s;
  tip_l3 = tip_y + 67*ui_s;

  gfx_setfont(2,"Arial",fs2,'b');
  gfx_set(txt_r,txt_g,txt_b,1);
  gfx_x = tip_tx; gfx_y = tip_title_y;
  tip_id == 20 ? gfx_printf("Source Object") :
  tip_id == 21 ? gfx_printf("Cue Ghost") :
  tip_id == 22 ? gfx_printf("Room Bounces") :
  tip_id == 23 ? gfx_printf("Push Out Shell") :
  tip_id == 24 ? gfx_printf("Stage Placement") :
  tip_id == 25 ? gfx_printf("Canvas Controls") :
  tip_id == 26 ? gfx_printf("Size Halo") :
  tip_id == 27 ? gfx_printf("Distance Rings") :
  tip_id == 28 ? gfx_printf("Motion Trail") :
  tip_id == 29 ? gfx_printf("Occlusion Wedge") :
  tip_id == 30 ? gfx_printf("Automation Safe") :
  tip_id >= 41 && tip_id <= 48 ? gfx_printf("Snap Placement") :
  tip_id == 101 ? gfx_printf("Lateral") :
  tip_id == 102 ? gfx_printf("Front / Rear") :
  tip_id == 103 ? gfx_printf("Distance") :
  tip_id == 104 ? gfx_printf("Spatial Throw") :
  tip_id == 105 ? gfx_printf("Size") :
  tip_id == 106 ? gfx_printf("Push Out") :
  tip_id == 107 ? gfx_printf("Room") :
  tip_id == 108 ? gfx_printf("Occlusion") :
  tip_id == 109 ? gfx_printf("Motion") :
  tip_id == 110 ? gfx_printf("Output Trim") :
  tip_id == 201 ? gfx_printf("Cue Curve") :
  tip_id == 202 ? gfx_printf("Motion Smooth") :
  tip_id == 203 ? gfx_printf("Room Size") : gfx_printf("Help");

  gfx_setfont(4,"Arial",fs4);
  gfx_set(0.82,0.86,0.93,1);

  tip_id == 20 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Drag to place the visual object.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Shift = fine, Alt = distance only.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Orange halo/cloud shows Size.");
  ) : tip_id == 21 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Effective DSP direction after Throw/Curve.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Solid orb = visual; ghost = cue target.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Visual %.0f deg | Cue %.0f deg", last_visual_az, last_cue_az);
  ) : tip_id == 22 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Cyan wall hits are early bounces.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Room raises bounce opacity and glow.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Room Size changes geometry timing.");
  ) : tip_id == 23 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Externalization cue around the listener.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Push Out helps leave the head.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Not distance, not gain.");
  ) : tip_id == 24 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("X = Lateral, Y = Front/Rear.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Wheel = Distance.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Right-click canvas = reset position.");
  ) : tip_id == 25 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Drag source/room to place object.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Ctrl-wheel = Spatial Throw.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Alt-wheel = Push Out.");
  ) : tip_id == 26 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Size means source extent/diffusion.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("It grows the orange halo/cloud.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("It is not Distance.");
  ) : tip_id == 27 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Distance is range from the listener.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Grey rings/dashes show close-to-far.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Wheel over canvas edits it.");
  ) : tip_id == 28 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Motion is tiny anti-collapse drift.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Green dots show the movement envelope.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Low values add life, not travel.");
  ) : tip_id == 29 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Occlusion means blocked/screened source.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Purple wedge marks the blocker cue.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Higher values darken the direct path.");
  ) : tip_id == 30 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Caps aggressive cue motion.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Use for fast drawn automation.");
    gfx_x = tip_tx; gfx_y = tip_l3; ui_safe ? gfx_printf("Currently ON.") : gfx_printf("Currently OFF.");
  ) : tip_id >= 41 && tip_id <= 48 ? (
    gfx_x = tip_tx; gfx_y = tip_l1;
    tip_id == 41 ? gfx_printf("Center front quick placement.") :
    tip_id == 42 ? gfx_printf("30 deg left-front quick placement.") :
    tip_id == 43 ? gfx_printf("45 deg left-front quick placement.") :
    tip_id == 44 ? gfx_printf("60 deg left-front quick placement.") :
    tip_id == 45 ? gfx_printf("30 deg right-front quick placement.") :
    tip_id == 46 ? gfx_printf("45 deg right-front quick placement.") :
    tip_id == 47 ? gfx_printf("60 deg right-front quick placement.") : gfx_printf("Centered rear quick placement.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Click to jump visual position.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Spatial Throw still controls intensity.");
  ) : tip_id == 101 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Left/right object coordinate. %.2f", ui_lat);
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Automation-safe replacement for azimuth.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Canvas X also edits this.");
  ) : tip_id == 102 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Front wall to rear wall placement. %.2f", ui_fb);
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("+ = front, 0 = side, - = rear.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Canvas Y also edits this.");
  ) : tip_id == 103 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Perceptual range: %.2f m | far %.0f%%", last_dist_m, last_far01*100);
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Grey rings/dashes show distance only.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Does not mean source Size.");
  ) : tip_id == 104 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Spatial cue intensity, not loudness.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Scales ITD, shadow, pinna, side cues.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Use lower values for mix-safe positions.");
  ) : tip_id == 105 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Apparent object size/diffusion.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Orange halo/cloud grows with Size.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Does not mean farther away.");
  ) : tip_id == 106 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Out-of-head externalization strength.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Shown as listener shell/separation rays.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Former Externalize control.");
  ) : tip_id == 107 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Early reflection and room cue amount.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Cyan bounces/wall glow scale with Room.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("More Room = less surgical, more external.");
  ) : tip_id == 108 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Blocked or screened source feel.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Darkens/smears direct sound.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Purple wedge shows blocker cue.");
  ) : tip_id == 109 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Tiny anti-collapse drift.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Green trail shows motion envelope.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Low values add life, not travel.");
  ) : tip_id == 110 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Final gain after spatial processing.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Use for level match, not distance.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Right-click resets to 0 dB.");
  ) : tip_id == 201 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Compresses moderate visual angles.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Higher = 45 deg sounds less extreme.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Right-click resets to 2.00.");
  ) : tip_id == 202 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Movement smoothing time in ms.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Automation Safe enforces a floor.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Right-click resets to 90 ms.");
  ) : tip_id == 203 ? (
    gfx_x = tip_tx; gfx_y = tip_l1; gfx_printf("Scales early-bounce geometry.");
    gfx_x = tip_tx; gfx_y = tip_l2; gfx_printf("Higher = larger room timing.");
    gfx_x = tip_tx; gfx_y = tip_l3; gfx_printf("Right-click resets to 0.55.");
  );
);
