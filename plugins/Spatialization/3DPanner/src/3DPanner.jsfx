gfx_set(0.70,0.58,0.85,1); gfx_rect(barx,b2y,barw*fb_n,barh);
gfx_set(0.08,0.08,0.10,0.65); gfx_line(barx+barw*0.5,b2y,barx+barw*0.5,b2y+barh);
gfx_set(1,1,1, hover_bar==2 ? 0.95 : 0.70); gfx_circle(barx + barw*fb_n, b2y + barh*0.5, 4.0*ui_s, 1, 1);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b2y-1*ui_s; gfx_printf("%+.2f", ui_fb);

// 3 Distance
gfx_set(0.92,0.94,0.97,1); gfx_x = barx; gfx_y = b3y-label_lift; gfx_printf("Distance");
gfx_set(0.18,0.20,0.24,1); gfx_rect(barx,b3y,barw,barh); gfx_roundrect(barx,b3y,barw,barh,6*ui_s,1);
gfx_set(0.78,0.81,0.90,1); gfx_rect(barx,b3y,barw*ui_dist_vis,barh);
gfx_set(1,1,1, hover_bar==3 ? 0.95 : 0.70); gfx_circle(barx + barw*ui_dist_vis, b3y + barh*0.5, 4.0*ui_s, 1, 1);
ui_link_view && last_effective_dist_n > 1 ? (
  gfx_set(0.24,0.78,1.0,0.85);
  gfx_line(barx+barw-2*ui_s,b3y-2*ui_s,barx+barw-2*ui_s,b3y+barh+2*ui_s);
);
gfx_set(mut_r,mut_g,mut_b,1); gfx_x = valx; gfx_y = b3y-1*ui_s; gfx_printf("%.1fm", last_dist_m);

// 4 Throw
