desc:Hyperreal 3D Panner V6.13.0 (Psychoacoustic Distance)

// #HELP: Headphone-focused 3D panner using softened perceptual placement, microdelay, head shadow, pinna cues, distance loss, occlusion, and room cues.
// #HELP: Drag the orange source in the stage canvas. X = Lateral, Y = Front/Rear. Mouse wheel changes Distance.
// #HELP: Spatial Throw controls how strongly the placement asserts itself without changing output gain.
// #HELP: Solid orange = visual object position. Ghost orange = effective cue position after Throw / Cue Curve compression.
// #HELP: Cyan wall markers are EARLY BOUNCES: first reflection hits used for out-of-head placement.
// #HELP: Automation Safe caps aggressive throw and lengthens smoothing for drawn automation.
// #HELP: Visual cues: Size = orange halo/cloud, Distance = grey range rings/dashes, Push Out = listener shell, Room = cyan bounces/wall glow, Motion = green trail.
// #HELP: Hover any canvas cue, snap chip, Automation Safe button, or quick-control lane for inline guidance. Tooltips use exact hit zones and dock away from controls.
// #HELP: Manager Link is opt-in. New instances start in Standalone mode and only follow a Manager after switching Mode to Manager.
// #HELP: V6.13.0 overhauls long-distance psychoacoustics: extended manager distances stay far/clear instead of just becoming reverby.
// #HELP: V6.2.2 stabilizes Occlusion by applying blocked-source coloration after localization, preventing opposite-ear flicker.
// #TOOLTIP: UI-only perceptual object panner. Main controls stay standalone-clean; Manager mode is explicit and opt-in.

options:want_all_kb
options:gfx_hz=60
options:idle=always
options:ownership=auto

in_pin:left input
in_pin:right input
out_pin:left output
out_pin:right output

// MANAGER / IPC
// #TOOLTIP: Manager name to follow. Choose a 3DPannerManager by its Name; routing IDs are internal.
slider1:#target_manager="Manager"<string>-Manager
// #TOOLTIP: Human-readable object/source name shown in the manager.
slider2:#object_name="Object"<string>-Name
// #TOOLTIP: Internal auto-assigned object ID. Visible object identity is the Name.
slider3:1<1,999,1>-Internal Object ID
// #TOOLTIP: Standalone ignores managers; Manager follows the selected 3DPannerManager Name. Defaults to Standalone so loading a manager cannot hijack this panner.
slider4:0<0,1,1{Standalone,Manager}>-Mode
// #TOOLTIP: Internal full-follow amount. Manager Mode is the only user-facing follow switch.
slider5:1<0,1,0.001>-Internal Manager Amount

// POSITION
// #TOOLTIP: Left/right object placement. Negative = left, positive = right.
slider6:0<-1,1,0.001>-Lateral
// #TOOLTIP: Physical distance throw. V6 uses a shorter, higher-resolution stage range than V5.
slider7:0.25<0,1,0.001>-Distance
// #TOOLTIP: Front/rear object placement. +1 = front wall, 0 = side plane, -1 = rear wall.
slider8:0.82<-1,1,0.001>-Depth Front/Rear

// FEEL
// #TOOLTIP: Spatial cue intensity. Higher = stronger ITD/head-shadow/pinna/side cues. Does not change loudness.
slider9:0.58<0,1,0.001>-Spatial Throw
// #TOOLTIP: Apparent source size. Lower = tighter point source; higher = wider / more diffuse image.
slider10:0.10<0,1,0.001>-Size
// #TOOLTIP: Out-of-head realism cue strength. Formerly Externalize.
slider11:0.42<0,1,0.001>-Push Out
// #TOOLTIP: Early reflection amount. Higher = more room cue and more externalization, less surgical precision.
slider12:0.30<0,1,0.001>-Room

// MATERIAL / MOTION
// #TOOLTIP: How blocked or hidden the source is. Higher = more muffled direct sound and more reflection dominance.
slider13:0<0,1,0.001>-Occlusion
// #TOOLTIP: Tiny motion added to keep static sources from collapsing inward on headphones.
slider14:0.04<0,1,0.001>-Micro Motion
// #TOOLTIP: Final output trim after spatial processing.
slider15:0<-18,12,0.1>-Output Trim (dB)

// AUTOMATION / ADVANCED
// #TOOLTIP: Caps aggressive spatial throw and uses safer smoothing for automation curves.
slider16:1<0,1,1>-Automation Safe
// #TOOLTIP: Perceptual compression curve. Higher values make moderate visual angles less extreme.
slider17:2.00<1,3,0.01>-Cue Curve
// #TOOLTIP: Movement smoothing in milliseconds. Automation Safe enforces a higher minimum.
slider18:90<5,250,1>-Motion Smooth (ms)
// #TOOLTIP: Geometric room scale for the bounce model. Higher = larger room and longer early reflection timing.
slider19:0.55<0,1,0.001>-Room Size
// #TOOLTIP: Internal cached manager slot. Panners route by Manager Name/IID, not this number.
slider20:1<1,64,1>-Internal Manager Slot

// V6.13.0 Manager model:
//   Sliders 6/8 store the object's fixed world placement.
//   Standalone mode ignores managers and does not appear as a linked object.
//   Manager mode subscribes by Manager Name and renders effective position = object world angle - camera yaw.

// V6 control model:
//   Lateral + Depth Front/Rear = visual object coordinate.
//   Distance                  = near/far physical distance.
//   Spatial Throw             = strength of the directional cue stack.
//   Push Out                  = outside-head realism / pinna-room emphasis.
//   Cue Curve                 = how much mid-angle positions are softened.

@init
za_idle_mode = 4;
za_keep_awake = 1;

function p3d_clamp(x, lo, hi) (
  x < lo ? lo : (x > hi ? hi : x);
);

function p3d_wrap_deg(a) (
  while (a > 180) ( a -= 360; );
  while (a < -180) ( a += 360; );
  a;
);

function p3d_distance_m_from_n(n) local(b e d2 d3 m) (
  // Perceptual meter mapping. Local Distance 0..1 resolves close-to-stage
  // placement up to about 10 m. Manager-linked topology can extend n beyond
  // 1.0 into a cinematic far field without feeding >1 values into the room
  // and cue-stack laws that expect normalized distance.
  n < 0 ? n = 0;
  n > 4 ? n = 4;
  b = n;
  b > 1 ? b = 1;
  d2 = b*b;
  d3 = d2*b;
  m = 0.20 + 9.80*(0.72*d2 + 0.28*d3);
  n > 1 ? (
    e = n - 1;
    m += 10.0*e + 9.0*e*e;
  );
  m;
);

function p3d_far01_from_m(m) local(v den) (
  // Log-distance perceptual weight. 10 m lands around mid-far; 100+ m is
  // very far. This drives spectral/detail cues without turning Room into a
  // giant wet/reverb multiplier.
  m < 0.20 ? m = 0.20;
  den = log(121.0) - log(1.20);
  v = (log(1.0 + m) - log(1.20)) / den;
  v < 0 ? v = 0;
  v > 1 ? v = 1;
  v;
);


function p3d_hash_string(s) local(i n c h) (
  // Stable ASCII bus hash. This is a second routing guard in addition to
  // comm_join/gmem_attach_size so Manager identity survives runtime namespace bugs.
  h = 5381;
  n = strlen(s);
  i = 0;
  loop(n,
    c = str_getchar(s, i);
    c < 0 ? c = 0;
    h = h * 33 + c;
    h = h - floor(h / 1000000007) * 1000000007;
    i += 1;
  );
  h <= 0 ? h = 1;
  h;
);

function p3d_scene_copy_to_string(slot, dest) local(base i n c) (
  strcpy(dest, "");
  slot >= 0 ? (
    base = P3D_SCENE_BASE + slot * P3D_SCENE_STRIDE;
    n = floor(gmem[base + P3D_SCENE_NAME_LEN_FIELD] + 0.5);
    n < 0 ? n = 0;
    n > P3D_SCENE_NAME_LEN ? n = P3D_SCENE_NAME_LEN;
    i = 0;
    loop(n,
      c = floor(gmem[base + P3D_SCENE_CHAR_BASE + i] + 0.5);
      (c >= 32 && c <= 126) ? (
        sprintf(#p3d_char_tmp, "%c", c);
        strcat(dest, #p3d_char_tmp);
      );
      i += 1;
    );
  );
);

function p3d_mgr_copy_scene_to_string(slot, dest) local(base i n c) (
  strcpy(dest, "");
  slot >= 0 ? (
    base = P3D_MGR_BASE + slot * P3D_MGR_STRIDE;
    n = floor(gmem[base + P3D_MGR_SCENE_NAME_LEN_FIELD] + 0.5);
    n < 0 ? n = 0;
    n > P3D_SCENE_NAME_LEN ? n = P3D_SCENE_NAME_LEN;
    i = 0;
    loop(n,
      c = floor(gmem[base + P3D_MGR_SCENE_CHAR_BASE + i] + 0.5);
      (c >= 32 && c <= 126) ? (
        sprintf(#p3d_char_tmp, "%c", c);
        strcat(dest, #p3d_char_tmp);
      );
      i += 1;
    );
  );
  strlen(dest) <= 0 ? strcpy(dest, "Manager");
);


function p3d_mgr_slot_valid_idx(idx) local(base h hb mid iid active n stale) (
  base = P3D_MGR_BASE + idx * P3D_MGR_STRIDE;
  h = gmem[base + P3D_MGR_BUS_HASH];
  hb = gmem[base + P3D_MGR_HB];
  mid = floor(gmem[base + P3D_MGR_CHANNEL] + 0.5);
  iid = gmem[base + P3D_MGR_IID];
  active = gmem[base + P3D_MGR_ENABLE];
  n = floor(gmem[base + P3D_MGR_SCENE_NAME_LEN_FIELD] + 0.5);
  stale = (iid <= 0) || (h <= 0) || ((p3d_bus_tick - hb) > P3D_STALE_TICKS) || (active < 0.5);
  (!stale && mid >= 1 && mid <= P3D_MAX_MANAGERS && n > 0) ? 1 : 0;
);

function p3d_scene_manager_alive(h, mid, miid) local(i base ok) (
  ok = 0;
  i = 0;
  loop(P3D_MAX_MANAGER_SLOTS,
    p3d_mgr_slot_valid_idx(i) ? (
      base = P3D_MGR_BASE + i * P3D_MGR_STRIDE;
      (abs(gmem[base + P3D_MGR_BUS_HASH] - h) < 0.5 && floor(gmem[base + P3D_MGR_CHANNEL] + 0.5) == mid && (miid <= 0 || abs(gmem[base + P3D_MGR_IID] - miid) < 0.5)) ? (
        ok = 1;
        i = P3D_MAX_MANAGER_SLOTS;
      );
    );
    i += 1;
  );
  ok;
);

function p3d_scene_slot_valid(idx) local(base h hb active n mid miid stale) (
  base = P3D_SCENE_BASE + idx * P3D_SCENE_STRIDE;
  h = gmem[base + P3D_SCENE_HASH];
  hb = gmem[base + P3D_SCENE_HB];
  active = gmem[base + P3D_SCENE_ACTIVE];
  n = floor(gmem[base + P3D_SCENE_NAME_LEN_FIELD] + 0.5);
  mid = floor(gmem[base + P3D_SCENE_MANAGER_ID] + 0.5);
  miid = gmem[base + P3D_SCENE_MANAGER_IID];
  stale = (h <= 0) || ((p3d_bus_tick - hb) > P3D_SCENE_STALE_TICKS) || (active < 0.5);
  (!stale && n > 0 && mid >= 1 && mid <= P3D_MAX_MANAGERS && p3d_scene_manager_alive(h, mid, miid)) ? 1 : 0;
);

function p3d_scene_slot_duplicate(idx) local(j base h mid miid b2 h2 mid2 miid2 dup) (
  dup = 0;
  base = P3D_SCENE_BASE + idx * P3D_SCENE_STRIDE;
  h = gmem[base + P3D_SCENE_HASH];
  mid = floor(gmem[base + P3D_SCENE_MANAGER_ID] + 0.5);
  miid = gmem[base + P3D_SCENE_MANAGER_IID];
  j = 0;
  loop(idx,
    p3d_scene_slot_valid(j) ? (
      b2 = P3D_SCENE_BASE + j * P3D_SCENE_STRIDE;
      h2 = gmem[b2 + P3D_SCENE_HASH];
      mid2 = floor(gmem[b2 + P3D_SCENE_MANAGER_ID] + 0.5);
      miid2 = gmem[b2 + P3D_SCENE_MANAGER_IID];
      (abs(h2 - h) < 0.5 && mid2 == mid && abs(miid2 - miid) < 0.5) ? dup = 1;
    );
    j += 1;
  );
  dup;
);


function p3d_scene_select_nth(order) local(i base seen mid picked) (
  seen = 0;
  picked = 0;
  i = 0;
  loop(P3D_MAX_SCENES,
    (p3d_scene_slot_valid(i) && !p3d_scene_slot_duplicate(i)) ? (
      seen == order ? (
        base = P3D_SCENE_BASE + i * P3D_SCENE_STRIDE;
        p3d_scene_copy_to_string(i, #target_manager);
        strlen(#target_manager) <= 0 ? strcpy(#target_manager, "Manager");
        strcpy(#p3d_edit_manager, #target_manager);
        mid = floor(gmem[base + P3D_SCENE_MANAGER_ID] + 0.5);
        mid < 1 ? mid = 1;
        mid > P3D_MAX_MANAGERS ? mid = P3D_MAX_MANAGERS;
        slider20 = mid;
        picked = 1;
        i = P3D_MAX_SCENES;
      );
      seen += 1;
    );
    i += 1;
  );
  picked == 0 ? (
    strcpy(#target_manager, "Manager");
    strcpy(#p3d_edit_manager, #target_manager);
    slider20 = 1;
  );
);

function p3d_scene_copy_nth(order, dest) local(i seen) (
  strcpy(dest, "");
  seen = 0;
  i = 0;
  loop(P3D_MAX_SCENES,
    (p3d_scene_slot_valid(i) && !p3d_scene_slot_duplicate(i)) ? (
      seen == order ? (
        p3d_scene_copy_to_string(i, dest);
        i = P3D_MAX_SCENES;
      );
      seen += 1;
    );
    i += 1;
  );
  strlen(dest) <= 0 ? strcpy(dest, "Manager");
);

function p3d_scene_count_active() local(i n) (
  n = 0;
  i = 0;
  loop(P3D_MAX_SCENES,
    (p3d_scene_slot_valid(i) && !p3d_scene_slot_duplicate(i)) ? n += 1;
    i += 1;
  );
  n;
);

function p3d_mgr_slot_duplicate(idx) local(j base h iid b2 h2 iid2 dup) (
  dup = 0;
  base = P3D_MGR_BASE + idx * P3D_MGR_STRIDE;
  h = gmem[base + P3D_MGR_BUS_HASH];
  iid = gmem[base + P3D_MGR_IID];
  j = 0;
  loop(idx,
    p3d_mgr_slot_valid_idx(j) ? (
      b2 = P3D_MGR_BASE + j * P3D_MGR_STRIDE;
      h2 = gmem[b2 + P3D_MGR_BUS_HASH];
      iid2 = gmem[b2 + P3D_MGR_IID];
      (abs(iid2 - iid) < 0.5 || abs(h2 - h) < 0.5) ? dup = 1;
    );
    j += 1;
  );
  dup;
);

function p3d_ui_scene_store(dst_idx, scene_idx) local(src dst i n c) (
  // The visible dropdown lists live managers by Manager Name. The legacy
  // *_SCENE_* field names are now just the manager-name text payload.
  src = P3D_MGR_BASE + scene_idx * P3D_MGR_STRIDE;
  dst = p3d_ui_scene_base + dst_idx * p3d_ui_scene_stride;
  n = floor(gmem[src + P3D_MGR_SCENE_NAME_LEN_FIELD] + 0.5);
  n < 0 ? n = 0;
  n > P3D_SCENE_NAME_LEN ? n = P3D_SCENE_NAME_LEN;
  dst[0] = n;
  dst[1] = floor(gmem[src + P3D_MGR_CHANNEL] + 0.5);
  dst[2] = gmem[src + P3D_MGR_IID];
  dst[3] = gmem[src + P3D_MGR_BUS_HASH];
  i = 0;
  loop(P3D_SCENE_NAME_LEN,
    c = i < n ? floor(gmem[src + P3D_MGR_SCENE_CHAR_BASE + i] + 0.5) : 0;
    dst[4 + i] = c;
    i += 1;
  );
);

function p3d_refresh_scene_ui_mirror() local(i out) (
  out = 0;
  i = 0;
  loop(P3D_MAX_MANAGER_SLOTS,
    (p3d_mgr_slot_valid_idx(i) && !p3d_mgr_slot_duplicate(i) && out < p3d_ui_scene_max) ? (
      p3d_ui_scene_store(out, i);
      out += 1;
    );
    i += 1;
  );
  p3d_ui_scene_count = out;
);

function p3d_ui_scene_count_active() (
  p3d_ui_scene_count;
);

function p3d_ui_scene_copy_nth(order, dest) local(base i n c) (
  strcpy(dest, "");
  (order >= 0 && order < p3d_ui_scene_count) ? (
    base = p3d_ui_scene_base + order * p3d_ui_scene_stride;
    n = floor(base[0] + 0.5);
    n < 0 ? n = 0;
    n > P3D_SCENE_NAME_LEN ? n = P3D_SCENE_NAME_LEN;
    i = 0;
    loop(n,
      c = floor(base[4 + i] + 0.5);
      (c >= 32 && c <= 126) ? (
        sprintf(#p3d_char_tmp, "%c", c);
        strcat(dest, #p3d_char_tmp);
      );
      i += 1;
    );
  );
  strlen(dest) <= 0 ? strcpy(dest, "Manager");
);

function p3d_ui_scene_manager_id(order) local(base mid) (
  mid = 1;
  (order >= 0 && order < p3d_ui_scene_count) ? (
    base = p3d_ui_scene_base + order * p3d_ui_scene_stride;
    mid = floor(base[1] + 0.5);
  );
  mid < 1 ? mid = 1;
  mid > P3D_MAX_MANAGERS ? mid = P3D_MAX_MANAGERS;
  mid;
);

function p3d_ui_scene_manager_iid(order) local(base iid) (
  iid = 0;
  (order >= 0 && order < p3d_ui_scene_count) ? (
    base = p3d_ui_scene_base + order * p3d_ui_scene_stride;
    iid = base[2];
  );
  iid;
);

function p3d_ui_scene_select_nth(order) local(mid) (
  (order >= 0 && order < p3d_ui_scene_count) ? (
    p3d_ui_scene_copy_nth(order, #target_manager);
    strcpy(#p3d_edit_manager, #target_manager);
    mid = p3d_ui_scene_manager_id(order);
    slider20 = mid;
    p3d_target_mgr_iid = p3d_ui_scene_manager_iid(order);
    sliderchange(-1.0);
  ) : (
    strcpy(#target_manager, "Manager");
    strcpy(#p3d_edit_manager, #target_manager);
    slider20 = 1;
    p3d_target_mgr_iid = 0;
    sliderchange(-1.0);
  );
);

function p3d_claim_object_slot() local(i idx sb sid hb stale best scan_start) (
  // Object slots are keyed by runtime instance, not Object ID. Multiple panners
  // can now share ID numbers on different buses without overwriting each other.
  (p3d_slot_index >= 0 && p3d_slot_index < P3D_MAX_OBJECTS) ? (
    sb = P3D_OBJ_BASE + p3d_slot_index * P3D_SLOT_STRIDE;
    gmem[sb + P3D_SLOT_IID] == p3d_iid ? best = p3d_slot_index : best = -1;
  ) : best = -1;

  best < 0 ? (
    i = 0;
    loop(P3D_MAX_OBJECTS,
      sb = P3D_OBJ_BASE + i * P3D_SLOT_STRIDE;
      gmem[sb + P3D_SLOT_IID] == p3d_iid ? (
        best = i;
        i = P3D_MAX_OBJECTS;
      );
      i += 1;
    );
  );

  best < 0 ? (
    // Start the stale/free scan at an IID-derived offset so newly inserted
    // panners do not all race for slot 1 in the same block.
    scan_start = floor(abs(p3d_iid) + 0.5);
    scan_start = scan_start - floor(scan_start / P3D_MAX_OBJECTS) * P3D_MAX_OBJECTS;
    i = 0;
    loop(P3D_MAX_OBJECTS,
      idx = scan_start + i;
      idx >= P3D_MAX_OBJECTS ? idx -= P3D_MAX_OBJECTS;
      sb = P3D_OBJ_BASE + idx * P3D_SLOT_STRIDE;
      sid = gmem[sb + P3D_SLOT_IID];
      hb = gmem[sb + P3D_SLOT_HB];
      stale = (sid <= 0) || ((p3d_bus_tick - hb) > P3D_STALE_TICKS);
      stale ? (
        best = idx;
        i = P3D_MAX_OBJECTS;
      );
      i += 1;
    );
  );

  best < 0 ? best = (p3d_obj_id - 1);
  p3d_slot_index = best;
  p3d_slot_index;
);

function p3d_find_manager_slot() local(i mb mhash mid miid best best_score hb score hash_match iid_match) (
  best = -1;
  best_score = -1;
  i = 0;
  loop(P3D_MAX_MANAGER_SLOTS,
    p3d_mgr_slot_valid_idx(i) ? (
      mb = P3D_MGR_BASE + i * P3D_MGR_STRIDE;
      mhash = gmem[mb + P3D_MGR_BUS_HASH];
      mid = floor(gmem[mb + P3D_MGR_CHANNEL] + 0.5);
      miid = gmem[mb + P3D_MGR_IID];
      hb = gmem[mb + P3D_MGR_HB];
      hash_match = abs(mhash - p3d_bus_hash) < 0.5 ? 1 : 0;
      iid_match = (p3d_target_mgr_iid > 0 && abs(miid - p3d_target_mgr_iid) < 0.5) ? 1 : 0;
      hash_match ? (
        // Manager Name is authoritative. The cached Manager IID only breaks
        // ties between same-name managers selected from the dropdown.
        score = hb + iid_match * 2000000;
        score > best_score ? (
          best = i;
          best_score = score;
          p3d_target_mgr = mid;
          slider20 = mid;
        );
      );
    );
    i += 1;
  );
  best;
);

function p3d_angle_from_lat_fb(lat, fb) local(r side front ang) (
  r = sqrt(lat*lat + fb*fb);
  r < 0.0001 ? (
    side = 0;
    front = 1;
  ) : (
    side = lat / r;
    front = fb / r;
  );
  ang = atan(side / (abs(front) + 0.000000000000000001)) * 180 / $pi;
  (front < 0) ? (
    side >= 0 ? ang = 180 - ang : ang = -180 - ang;
  );
  p3d_wrap_deg(ang);
);

function p3d_write_object_name(base, name) local(i n c) (
  n = strlen(name);
  n > P3D_OBJECT_NAME_LEN ? n = P3D_OBJECT_NAME_LEN;
  gmem[base + P3D_SLOT_NAME_LEN_FIELD] = n;
  i = 0;
  loop(P3D_OBJECT_NAME_LEN,
    c = i < n ? str_getchar(name, i) : 0;
    c < 0 ? c = 0;
    gmem[base + P3D_SLOT_NAME_CHAR_BASE + i] = c;
    i += 1;
  );
);

function p3d_ensure_bus_header() local(t) (
  ((gmem[P3D_BUS_MAGIC] != P3D_MAGIC) || (gmem[P3D_BUS_VERSION] != P3D_VERSION)) ? (
    gmem_zero(0, P3D_GMEM_SIZE);
    gmem[P3D_BUS_MAGIC] = P3D_MAGIC;
    gmem[P3D_BUS_VERSION] = P3D_VERSION;
    gmem[P3D_BUS_TICK] = 0;
  );
  // Followers do not advance global time. The manager owns P3D_BUS_TICK, so
  // stale thresholds remain stable regardless of how many panners are loaded.
  t = gmem[P3D_BUS_TICK];
  t < 0 ? t = 0;
  p3d_bus_tick = t;
);

function p3d_publish_slot() local(sb) (
  p3d_claim_object_slot();
  p3d_obj_id = p3d_slot_index + 1;
  p3d_obj_id < 1 ? p3d_obj_id = 1;
  p3d_obj_id > 999 ? p3d_obj_id = 999;
  slider3 = p3d_obj_id;
  last_object_id = p3d_obj_id;
  sb = P3D_OBJ_BASE + p3d_slot_index * P3D_SLOT_STRIDE;

  gmem[sb + P3D_SLOT_IID] = p3d_iid;
  gmem[sb + P3D_SLOT_HB] = p3d_bus_tick;
  gmem[sb + P3D_SLOT_SEQ] = p3d_seq;
  gmem[sb + P3D_SLOT_LINK] = p3d_link_enabled;
  gmem[sb + P3D_SLOT_OBJ_ID] = p3d_obj_id;
  gmem[sb + P3D_SLOT_WORLD_ANG] = p3d_world_ang;
  gmem[sb + P3D_SLOT_WORLD_DIST_N] = p3d_world_dist_n;
  gmem[sb + P3D_SLOT_WORLD_LAT] = p3d_world_lat;
  gmem[sb + P3D_SLOT_WORLD_FB] = p3d_world_fb;
  gmem[sb + P3D_SLOT_EFF_ANG] = p3d_effective_ang;
  gmem[sb + P3D_SLOT_EFF_LAT] = p3d_effective_lat;
  gmem[sb + P3D_SLOT_EFF_FB] = p3d_effective_fb;
  // Use slider-backed values here so manager discovery still works while the
  // audio engine has the instance asleep and only @gfx is ticking.
  gmem[sb + P3D_SLOT_DIST_M] = last_dist_m;
  gmem[sb + P3D_SLOT_SIZE] = slider10;
  gmem[sb + P3D_SLOT_PUSH] = slider11;
  gmem[sb + P3D_SLOT_ROOM] = slider12;
  gmem[sb + P3D_SLOT_OCC] = slider13;
  gmem[sb + P3D_SLOT_MANAGER_AMT] = p3d_manager_amt;
  // Keep the registry slot active so the Manager can list this panner even
  // while it is standalone. P3D_SLOT_LINK is the hard opt-in gate for camera control.
  gmem[sb + P3D_SLOT_ACTIVE] = 1;
  gmem[sb + P3D_SLOT_TARGET_MGR] = p3d_target_mgr;
  gmem[sb + P3D_SLOT_BUS_HASH] = p3d_bus_hash;
  gmem[sb + P3D_SLOT_TARGET_MGR_IID] = p3d_manager_iid;
  p3d_write_object_name(sb, #object_name);
);


function p3d_service_registry() local(mb wr depth_delta side_delta topology dist_scale base_n d2 d3 ext_dist mgr_hb mgr_iid) (
  // Shared-state service. @block calls the full path; @slider calls it with
  // message sending disabled so name/position edits publish without waiting for
  // an audio block.
  p3d_ensure_bus_header();
  p3d_refresh_scene_ui_mirror();
  p3d_iid = instance_id();
  p3d_link_enabled = slider4 >= 0.5 ? 1 : 0;
  p3d_obj_id = floor(slider3 + 0.5);
  p3d_obj_id < 1 ? p3d_obj_id = 1;
  p3d_obj_id > 999 ? p3d_obj_id = 999;
  p3d_manager_amt = p3d_clamp(slider5, 0, 1);
  p3d_target_mgr = floor(slider20 + 0.5);
  p3d_target_mgr < 1 ? p3d_target_mgr = 1;
  p3d_target_mgr > P3D_MAX_MANAGERS ? p3d_target_mgr = P3D_MAX_MANAGERS;
  p3d_target_mgr_iid < 0 ? p3d_target_mgr_iid = 0;

  p3d_bus_hash = p3d_hash_string(#target_manager);
  p3d_bus_hash != p3d_last_bus_hash ? (
    p3d_last_bus_hash = p3d_bus_hash;
    p3d_mgr_hold = 0;
    p3d_cached_manager_hb = -1;
    p3d_cached_manager_iid = 0;
    p3d_target_mgr_iid = 0;
    p3d_mgr_slot = -1;
    p3d_slot_index = -1;
  );

  p3d_link_enabled ? (
    p3d_mgr_slot = p3d_find_manager_slot();
  ) : (
    p3d_mgr_slot = -1;
    p3d_mgr_hold = 0;
    p3d_cached_manager_hb = -1;
    p3d_cached_manager_iid = 0;
    p3d_cached_manager_enabled = 0;
    p3d_cached_camera_rot = 0;
    p3d_cached_distance_scale = 1;
  );
  p3d_mgr_slot >= 0 ? (
    mb = P3D_MGR_BASE + p3d_mgr_slot * P3D_MGR_STRIDE;
    mgr_hb = gmem[mb + P3D_MGR_HB];
    mgr_iid = gmem[mb + P3D_MGR_IID];
    (abs(mgr_iid - p3d_cached_manager_iid) >= 0.5) ? p3d_cached_manager_hb = -1;
    (mgr_hb != p3d_cached_manager_hb) ? (
      p3d_cached_manager_hb = mgr_hb;
      p3d_cached_manager_iid = mgr_iid;
      p3d_target_mgr_iid = p3d_cached_manager_iid;
      p3d_cached_manager_enabled = gmem[mb + P3D_MGR_ENABLE] >= 0.5 ? 1 : 0;
      p3d_cached_camera_rot = gmem[mb + P3D_MGR_CAMERA_ROT] * gmem[mb + P3D_MGR_ROT_SCALE];
      p3d_cached_distance_scale = gmem[mb + P3D_MGR_DIST_SCALE];
      p3d_cached_distance_scale <= 0 ? p3d_cached_distance_scale = 1;
      p3d_cached_distance_scale = p3d_clamp(p3d_cached_distance_scale, 0.25, 16.0);
      p3d_mgr_hold = P3D_MANAGER_HOLD_BLOCKS;
    ) : (
      p3d_mgr_hold > 0 ? p3d_mgr_hold -= 1;
    );
  ) : (
    p3d_mgr_hold > 0 ? p3d_mgr_hold -= 1;
  );

  p3d_manager_iid = p3d_cached_manager_iid;
  p3d_manager_enabled = p3d_cached_manager_enabled;
  p3d_manager_alive = p3d_mgr_hold > 0 ? 1 : 0;
  p3d_link_active = (p3d_link_enabled && p3d_manager_alive && p3d_manager_enabled && (p3d_manager_amt > 0.0001)) ? 1 : 0;
  p3d_camera_rot = p3d_cached_camera_rot;
  p3d_distance_scale = p3d_cached_distance_scale;

  p3d_world_lat = p3d_clamp(slider6, -1, 1);
  p3d_world_fb = p3d_clamp(slider8, -1, 1);
  p3d_world_dist_n = p3d_clamp(slider7, 0, 1);
  wr = sqrt(p3d_world_lat*p3d_world_lat + p3d_world_fb*p3d_world_fb);
  wr > 1 ? wr = 1;
  p3d_world_ang = p3d_angle_from_lat_fb(p3d_world_lat, p3d_world_fb);
  p3d_effective_ang = p3d_world_ang;
  p3d_effective_lat = p3d_world_lat;
  p3d_effective_fb = p3d_world_fb;
  last_effective_dist_n = p3d_world_dist_n;

  p3d_link_active ? (
    p3d_effective_ang = p3d_wrap_deg(p3d_world_ang - p3d_camera_rot * p3d_manager_amt);
    p3d_effective_lat = sin(p3d_effective_ang * $pi / 180) * wr;
    p3d_effective_fb  = cos(p3d_effective_ang * $pi / 180) * wr;
    depth_delta = p3d_effective_fb - p3d_world_fb;
    side_delta = abs(p3d_effective_lat) - abs(p3d_world_lat);
    topology = 1 - 0.42 * depth_delta * p3d_manager_amt + 0.10 * side_delta * p3d_manager_amt;
    topology < 0.25 ? topology = 0.25;
    topology > 4.00 ? topology = 4.00;
    dist_scale = 1 + (p3d_distance_scale - 1) * p3d_manager_amt;
    last_effective_dist_n = p3d_world_dist_n * dist_scale * topology;
    last_effective_dist_n < 0 ? last_effective_dist_n = 0;
    last_effective_dist_n > 4.0 ? last_effective_dist_n = 4.0;
  );

  last_manager_link = p3d_link_enabled;
  last_manager_active = p3d_link_active;
  last_manager_id = p3d_manager_iid;
  last_object_id = p3d_obj_id;
  last_world_az = p3d_world_ang;
  last_effective_az = p3d_effective_ang;
  last_effective_lat = p3d_effective_lat;
  last_effective_fb = p3d_effective_fb;
  last_camera_rot = p3d_camera_rot;

  base_n = last_effective_dist_n;
  base_n < 0 ? base_n = 0;
  base_n > 4 ? base_n = 4;
  last_dist_m = p3d_distance_m_from_n(base_n);
  last_far01 = p3d_far01_from_m(last_dist_m);

  p3d_seq += 1;
  p3d_publish_slot();
  p3d_allow_msg ? (p3d_link_enabled ? msg_send(#p3d_registry_bus, P3D_OP_PANNER_HEART, p3d_iid, p3d_obj_id, p3d_world_ang, p3d_effective_ang););
);




// --- 3DPannerManager shared bus protocol ---
P3D_MAGIC = 30260611;
P3D_VERSION = 10;
P3D_MAX_OBJECTS = 128;
P3D_BUS_MAGIC = 0;
P3D_BUS_VERSION = 1;
P3D_BUS_TICK = 2;
P3D_BUS_MANAGER_IID = 3;
P3D_BUS_MANAGER_HB = 4;
P3D_BUS_MANAGER_ENABLE = 5;
P3D_BUS_CAMERA_ROT = 6;
P3D_BUS_ROT_SCALE = 7;
P3D_BUS_DIST_SCALE = 8;
P3D_BUS_SMOOTH_MS = 9;
P3D_BUS_COORD_MODE = 10;
P3D_BUS_LINKED_COUNT = 11;
P3D_BUS_MANAGER_SEQ = 12;
P3D_OBJ_BASE = 64;
P3D_SLOT_STRIDE = 64;
P3D_SLOT_IID = 0;
P3D_SLOT_HB = 1;
P3D_SLOT_SEQ = 2;
P3D_SLOT_LINK = 3;
P3D_SLOT_OBJ_ID = 4;
P3D_SLOT_WORLD_ANG = 5;
P3D_SLOT_WORLD_DIST_N = 6;
P3D_SLOT_WORLD_LAT = 7;
P3D_SLOT_WORLD_FB = 8;
P3D_SLOT_EFF_ANG = 9;
P3D_SLOT_EFF_LAT = 10;
P3D_SLOT_EFF_FB = 11;
P3D_SLOT_DIST_M = 12;
P3D_SLOT_SIZE = 13;
P3D_SLOT_PUSH = 14;
P3D_SLOT_ROOM = 15;
P3D_SLOT_OCC = 16;
P3D_SLOT_MANAGER_AMT = 17;
P3D_SLOT_ACTIVE = 18;
P3D_STALE_TICKS = 240;
P3D_MANAGER_HOLD_BLOCKS = 90;
P3D_SLOT_TARGET_MGR = 19;
P3D_SLOT_BUS_HASH = 20;
P3D_SLOT_TARGET_MGR_IID = 21;
P3D_SLOT_NAME_LEN_FIELD = 22;
P3D_SLOT_NAME_CHAR_BASE = 24;
P3D_OBJECT_NAME_LEN = 24;
P3D_MAX_MANAGERS = 64;
P3D_MAX_MANAGER_SLOTS = 64;
P3D_MGR_BASE = P3D_OBJ_BASE + P3D_MAX_OBJECTS * P3D_SLOT_STRIDE;
P3D_MGR_STRIDE = 64;
P3D_MGR_IID = 0;
P3D_MGR_HB = 1;
P3D_MGR_ENABLE = 2;
P3D_MGR_CAMERA_ROT = 3;
P3D_MGR_ROT_SCALE = 4;
P3D_MGR_DIST_SCALE = 5;
P3D_MGR_SMOOTH_MS = 6;
P3D_MGR_SEQ = 7;
P3D_MGR_TRACKER = 8;
P3D_MGR_BUS_HASH = 9;
P3D_MGR_CHANNEL = 10;
P3D_MGR_SCENE_NAME_LEN_FIELD = 11;
P3D_MGR_SCENE_CHAR_BASE = 12;
P3D_MAX_SCENES = 32;
P3D_SCENE_NAME_LEN = 36;
P3D_SCENE_BASE = P3D_MGR_BASE + P3D_MAX_MANAGER_SLOTS * P3D_MGR_STRIDE;
P3D_SCENE_STRIDE = 48;
P3D_SCENE_HASH = 0;
P3D_SCENE_HB = 1;
P3D_SCENE_MANAGER_ID = 2;
P3D_SCENE_MANAGER_IID = 3;
P3D_SCENE_ACTIVE = 4;
P3D_SCENE_NAME_LEN_FIELD = 5;
P3D_SCENE_CHAR_BASE = 8;
P3D_SCENE_STALE_TICKS = 240;
P3D_GMEM_SIZE = P3D_SCENE_BASE + P3D_MAX_SCENES * P3D_SCENE_STRIDE + 64;
P3D_OP_MANAGER_STATE = 3101;
P3D_OP_PANNER_HEART = 3102;

strlen(#target_manager) <= 0 ? strcpy(#target_manager, "Manager");
strlen(#object_name) <= 0 ? strcpy(#object_name, "Object");
strcpy(#p3d_registry_bus, "ZorakAudio.3DPanner.Registry");
comm_join(#p3d_registry_bus);
instance_set_name(#object_name);
instance_uid(#p3d_uid);
msg_subscribe(#p3d_registry_bus);
msg_advertise(#p3d_registry_bus, 1);
gmem_attach_size(#p3d_registry_bus, P3D_GMEM_SIZE);

p3d_iid = instance_id();
p3d_seq = 0;
p3d_bus_tick = 0;
p3d_link_enabled = 0;
p3d_link_active = 0;
p3d_manager_alive = 0;
p3d_manager_iid = 0;
p3d_manager_amt = 1;
p3d_camera_rot = 0;
p3d_effective_ang = 0;
p3d_world_ang = 0;
p3d_last_manager_msg = 0;
p3d_rx_manager_seq = 0;
p3d_slot_index = -1;
p3d_bus_hash = p3d_hash_string(#target_manager);
p3d_last_bus_hash = p3d_bus_hash;
p3d_mgr_slot = -1;
p3d_mgr_hold = 0;
p3d_cached_manager_iid = 0;
p3d_cached_manager_enabled = 0;
p3d_cached_manager_hb = -1;
p3d_cached_camera_rot = 0;
p3d_cached_distance_scale = 1;
p3d_cached_rot_scale = 1;
p3d_target_mgr_iid = 0;
p3d_ui_scene_base = 65536;
p3d_ui_scene_stride = 48;
p3d_ui_scene_max = P3D_MAX_SCENES;
p3d_ui_scene_count = 0;

// --- delay buffers ---
er_bufsize = 32768;
er_mask = er_bufsize - 1;
er_wpos = 0;

erbuf = 0;
itd_bufsize = 4096;
itd_mask = itd_bufsize - 1;
itd_wpos = 0;
itdbuf = erbuf + er_bufsize;
// Keep UI mirror memory out of the audio delay lines.
p3d_ui_scene_base = itdbuf + itd_bufsize + 4096;

loop_cnt = 0;
loop(er_bufsize,
  erbuf[loop_cnt] = 0;
  loop_cnt += 1;
);

loop_cnt = 0;
loop(itd_bufsize,
  itdbuf[loop_cnt] = 0;
  loop_cnt += 1;
);

// --- smoothing ---
// V6 recalculates smooth_k / coeff_k from the Motion Smooth slider in @block.
smooth_k = 1 - exp(-1/(0.090*srate));
coeff_k  = 1 - exp(-1/(0.140*srate));
meter_k  = 1 - exp(-1/(0.050*srate));

// --- filters / splits ---
split_fc = 1000;
split_a = exp(-2*$pi*split_fc/srate);

occ_split_fc = 650;
occ_split_a = exp(-2*$pi*occ_split_fc/srate);

band1_fc = 320;
band2_fc = 1800;
band1_a = exp(-2*$pi*band1_fc/srate);
band2_a = exp(-2*$pi*band2_fc/srate);

// --- reflection defaults ---
er_a1 = exp(-2*$pi*12500/srate);
er_a2 = exp(-2*$pi*9800/srate);
er_a3 = exp(-2*$pi*8000/srate);
er_a4 = exp(-2*$pi*6400/srate);
er_a5 = exp(-2*$pi*5200/srate);
er_a6 = exp(-2*$pi*4200/srate);
er_a7 = exp(-2*$pi*3200/srate);
er_a8 = exp(-2*$pi*2600/srate);

// --- smoothed params ---
// sm_az is the softened/cue-scaled azimuth, not the visual placement angle.
sm_az = 0;
sm_depth = 0.25;
sm_far = 0;
sm_width = 0.10;
sm_ext = 0.42;
sm_room = 0.30;
sm_rsize = 0.55;
sm_occ = 0;
sm_motion = 0.04;
sm_trim = 1;

// --- smoothed derived ---
sm_direct_g = 1;
sm_er_g = 0;
sm_air_a = 0.2;
sm_occ_a = 0.5;

sm_er1_d = 250;
sm_er2_d = 420;
sm_er3_d = 620;
sm_er4_d = 920;
sm_er5_d = 1300;
sm_er6_d = 1800;
sm_er7_d = 2450;
sm_er8_d = 3300;

// --- states ---
air_state = 0;
occ_lp = 0;
occ_low_mem = 0;
occ_ap_x1 = 0;
occ_ap_y1 = 0;

// Stable per-ear occlusion states.
// V6.2.2 localizes first, then colors each ear, so occlusion does not create
// a delayed/smeared mono event that can flicker in the opposite ear.
occ_dir_lp_l = 0;
occ_dir_lp_r = 0;
occ_dir_low_l = 0;
occ_dir_low_r = 0;

// head-shadow split states
l_low = 0;
r_low = 0;

// perceptual band split states
l_band1 = 0;
l_band2 = 0;
r_band1 = 0;
r_band2 = 0;

// ER filter states
er_lp1 = 0;
er_lp2 = 0;
er_lp3 = 0;
er_lp4 = 0;
er_lp5 = 0;
er_lp6 = 0;
er_lp7 = 0;
er_lp8 = 0;

// ER decorrelation allpass (per channel)
er_ap_x1_l = 0; er_ap_y1_l = 0;
er_ap_x1_r = 0; er_ap_y1_r = 0;

// Pinna (biquad) states
pn_x1_l = 0; pn_x2_l = 0; pn_y1_l = 0; pn_y2_l = 0;
pn_x1_r = 0; pn_x2_r = 0; pn_y1_r = 0; pn_y2_r = 0;

// Pinna coeffs (smoothed)
pn_b0_l = 1; pn_b1_l = 0; pn_b2_l = 0; pn_a1_l = 0; pn_a2_l = 0;
pn_b0_r = 1; pn_b1_r = 0; pn_b2_r = 0; pn_a1_r = 0; pn_a2_r = 0;

// Pinna coeff targets
pn_t_b0_l = 1; pn_t_b1_l = 0; pn_t_b2_l = 0; pn_t_a1_l = 0; pn_t_a2_l = 0;
pn_t_b0_r = 1; pn_t_b1_r = 0; pn_t_b2_r = 0; pn_t_a1_r = 0; pn_t_a2_r = 0;

// Rear tint (very mild)
rear_lp_l = 0;
rear_lp_r = 0;
rear_a = exp(-2*$pi*18000/srate);
rear_t_a = rear_a;
rear_mix = 0;
rear_t_mix = 0;

// Motion LFO
ph1 = 0;
ph2 = 0;

// meters / readouts
meter_direct = 0;
meter_er = 0;
last_itd_ms = 0;
last_air_fc = 18000;
last_dist_m = 0.3;
last_far01 = 0;
last_ext_db = 0;
last_rear = 0;
last_focus = 1;
last_shadow = 0;
last_front = 1;
last_side = 0;
last_back = 0;
last_room_w = 4.8;
last_room_d = 5.6;

// V6 perceptual placement readouts
last_visual_az = 0;
last_cue_az = 0;
last_throw = 0.58;
last_throw_dsp = 0.58;
last_lat = 0;
last_fb = 0.82;
last_smooth_ms = 90;
last_cue_curve_eff = 1;
last_automation_safe = 1;

// UI interaction
ui_mode = 0;
ui_prev_l = 0;
ui_prev_r = 0;
ui_drag_start_x = 0;
ui_drag_start_y = 0;
ui_drag_start_v1 = 0;
ui_drag_start_v2 = 0;
ui_drag_start_v3 = 0;
ui_drag_bar = 0;

// V6.12 UI-only state. Main DSP controls are hidden; Manager/Name/Mode remain
// host-visible while GFX widgets edit the same slider-backed state.
ui_text_active = 0; // 0 none, 1 Manager, 2 Object Name
ui_text_frames = 0;
ui_text_select_all = 0;
ui_drawer_open = 0; // Manager Link side drawer; closed by default so standalone use stays clean.
ui_scene_menu = 0;
strcpy(#p3d_edit_text, "");
strcpy(#p3d_keychar, "");
strcpy(#p3d_edit_manager, #target_manager);
strcpy(#p3d_edit_name, #object_name);

slider_show(1,1); slider_show(2,1); slider_show(3,0); slider_show(4,1); slider_show(5,0);
slider_show(6,0); slider_show(7,0); slider_show(8,0); slider_show(9,0); slider_show(10,0);
slider_show(11,0); slider_show(12,0); slider_show(13,0); slider_show(14,0); slider_show(15,0);
slider_show(16,0); slider_show(17,0); slider_show(18,0); slider_show(19,0); slider_show(20,0);


@slider
strlen(#target_manager) <= 0 ? strcpy(#target_manager, "Manager");
strlen(#object_name) <= 0 ? strcpy(#object_name, "Object");
slider5 = 1;
strcpy(#p3d_registry_bus, "ZorakAudio.3DPanner.Registry");
comm_join(#p3d_registry_bus);
instance_set_name(#object_name);
msg_subscribe(#p3d_registry_bus);
msg_advertise(#p3d_registry_bus, 1);
gmem_attach_size(#p3d_registry_bus, P3D_GMEM_SIZE);
p3d_rebind_pending = 0;
p3d_bus_hash = p3d_hash_string(#target_manager);
p3d_bus_hash != p3d_last_bus_hash ? (
  p3d_last_bus_hash = p3d_bus_hash;
  p3d_mgr_hold = 0;
  p3d_cached_manager_hb = -1;
  p3d_cached_manager_iid = 0;
  p3d_target_mgr_iid = 0;
  p3d_mgr_slot = -1;
  p3d_slot_index = -1;
);
ui_text_active == 0 ? (
  strcpy(#p3d_edit_manager, #target_manager);
  strcpy(#p3d_edit_name, #object_name);
);
p3d_iid = instance_id();
p3d_seq += 1;
p3d_allow_msg = 0;
p3d_service_registry();

@block
strlen(#target_manager) <= 0 ? strcpy(#target_manager, "Manager");
strlen(#object_name) <= 0 ? strcpy(#object_name, "Object");
slider5 = 1;
p3d_rebind_pending ? (
  strcpy(#p3d_registry_bus, "ZorakAudio.3DPanner.Registry");
  comm_join(#p3d_registry_bus);
  instance_set_name(#object_name);
  msg_subscribe(#p3d_registry_bus);
  msg_advertise(#p3d_registry_bus, 1);
  gmem_attach_size(#p3d_registry_bus, P3D_GMEM_SIZE);
  p3d_rebind_pending = 0;
);
// V6 perceptual-position mapping.
// User-facing position is a stage coordinate; DSP receives a softened cue azimuth.

// --- Manager bus state ---
p3d_ensure_bus_header();
p3d_refresh_scene_ui_mirror();
p3d_iid = instance_id();
p3d_link_enabled = slider4 >= 0.5 ? 1 : 0;
p3d_obj_id = floor(slider3 + 0.5);
p3d_obj_id < 1 ? p3d_obj_id = 1;
p3d_obj_id > 999 ? p3d_obj_id = 999;
p3d_manager_amt = p3d_clamp(slider5, 0, 1);

p3d_target_mgr = floor(slider20 + 0.5);
p3d_target_mgr < 1 ? p3d_target_mgr = 1;
p3d_target_mgr > P3D_MAX_MANAGERS ? p3d_target_mgr = P3D_MAX_MANAGERS;
p3d_target_mgr_iid < 0 ? p3d_target_mgr_iid = 0;

p3d_bus_hash = p3d_hash_string(#target_manager);
p3d_bus_hash != p3d_last_bus_hash ? (
  p3d_last_bus_hash = p3d_bus_hash;
  p3d_mgr_hold = 0;
  p3d_cached_manager_hb = -1;
  p3d_cached_manager_iid = 0;
  p3d_target_mgr_iid = 0;
  p3d_mgr_slot = -1;
  p3d_slot_index = -1;
);

// Dynamic Manager lookup: visible Manager Name hash, with IID only as a same-name tie-breaker. This prevents
// routing from falling back to an unrelated numeric manager index. Standalone
// mode does not subscribe to, cache, or consume any manager transform.
p3d_link_enabled ? (
  p3d_mgr_slot = p3d_find_manager_slot();
) : (
  p3d_mgr_slot = -1;
  p3d_mgr_hold = 0;
  p3d_cached_manager_hb = -1;
  p3d_cached_manager_iid = 0;
  p3d_cached_manager_enabled = 0;
  p3d_cached_camera_rot = 0;
  p3d_cached_distance_scale = 1;
);
p3d_mgr_slot >= 0 ? (
  p3d_mgr_base = P3D_MGR_BASE + p3d_mgr_slot * P3D_MGR_STRIDE;
  p3d_mgr_hb = gmem[p3d_mgr_base + P3D_MGR_HB];
  p3d_mgr_iid_now = gmem[p3d_mgr_base + P3D_MGR_IID];
  (abs(p3d_mgr_iid_now - p3d_cached_manager_iid) >= 0.5) ? p3d_cached_manager_hb = -1;
  (p3d_mgr_hb != p3d_cached_manager_hb) ? (
    p3d_cached_manager_hb = p3d_mgr_hb;
    p3d_cached_manager_iid = p3d_mgr_iid_now;
    p3d_target_mgr_iid = p3d_cached_manager_iid;
    p3d_cached_manager_enabled = gmem[p3d_mgr_base + P3D_MGR_ENABLE] >= 0.5 ? 1 : 0;
    p3d_cached_camera_rot = gmem[p3d_mgr_base + P3D_MGR_CAMERA_ROT] * gmem[p3d_mgr_base + P3D_MGR_ROT_SCALE];
    p3d_cached_distance_scale = gmem[p3d_mgr_base + P3D_MGR_DIST_SCALE];
    p3d_cached_distance_scale <= 0 ? p3d_cached_distance_scale = 1;
    p3d_cached_distance_scale = p3d_clamp(p3d_cached_distance_scale, 0.25, 16.0);
    p3d_mgr_hold = P3D_MANAGER_HOLD_BLOCKS;
  ) : (
    p3d_mgr_hold > 0 ? p3d_mgr_hold -= 1;
  );
) : (
  p3d_mgr_hold > 0 ? p3d_mgr_hold -= 1;
);

p3d_manager_iid = p3d_cached_manager_iid;
p3d_manager_enabled = p3d_cached_manager_enabled;
p3d_manager_alive = p3d_mgr_hold > 0 ? 1 : 0;
p3d_link_active = (p3d_link_enabled && p3d_manager_alive && p3d_manager_enabled && (p3d_manager_amt > 0.0001)) ? 1 : 0;

p3d_camera_rot = p3d_cached_camera_rot;
p3d_distance_scale = p3d_cached_distance_scale;

while (msg_recv(#p3d_registry_bus, p3d_msg_src, p3d_msg_tag, p3d_msg_a, p3d_msg_b, p3d_msg_c, p3d_msg_d)) (
  (p3d_msg_tag == P3D_OP_MANAGER_STATE) && (p3d_msg_src != p3d_iid) ? (
    p3d_last_manager_msg = p3d_msg_src;
    p3d_rx_manager_seq = p3d_msg_d;
  );
);

// --- raw UI targets ---
tgt_lat = slider6;
tgt_lat < -1 ? tgt_lat = -1;
tgt_lat > 1 ? tgt_lat = 1;

tgt_dist_n = slider7;
tgt_dist_n < 0 ? tgt_dist_n = 0;
tgt_dist_n > 1 ? tgt_dist_n = 1;

tgt_fb = slider8;
tgt_fb < -1 ? tgt_fb = -1;
tgt_fb > 1 ? tgt_fb = 1;

tgt_throw = slider9;
tgt_throw < 0 ? tgt_throw = 0;
tgt_throw > 1 ? tgt_throw = 1;

tgt_width = slider10;
tgt_width < 0 ? tgt_width = 0;
tgt_width > 1 ? tgt_width = 1;

tgt_ext = slider11;
tgt_ext < 0 ? tgt_ext = 0;
tgt_ext > 1 ? tgt_ext = 1;

tgt_room = slider12;
tgt_room < 0 ? tgt_room = 0;
tgt_room > 1 ? tgt_room = 1;

tgt_occ = slider13;
tgt_occ < 0 ? tgt_occ = 0;
tgt_occ > 1 ? tgt_occ = 1;

tgt_motion = slider14;
tgt_motion < 0 ? tgt_motion = 0;
tgt_motion > 1 ? tgt_motion = 1;

tgt_trim = 10^(slider15/20);

auto_safe = slider16 >= 0.5 ? 1 : 0;
last_automation_safe = auto_safe;

cue_curve_user = slider17;
cue_curve_user < 1 ? cue_curve_user = 1;
cue_curve_user > 3 ? cue_curve_user = 3;

smooth_ms = slider18;
smooth_ms < 5 ? smooth_ms = 5;
auto_safe && smooth_ms < 90 ? smooth_ms = 90;
last_smooth_ms = smooth_ms;
smooth_k = 1 - exp(-1/((smooth_ms*0.001)*srate));
coeff_ms = smooth_ms * 1.55;
coeff_ms < 15 ? coeff_ms = 15;
coeff_k = 1 - exp(-1/((coeff_ms*0.001)*srate));
meter_k  = 1 - exp(-1/(0.050*srate));

tgt_rsize = slider19;
tgt_rsize < 0 ? tgt_rsize = 0;
tgt_rsize > 1 ? tgt_rsize = 1;

// --- Manager camera transform ---
// Sliders retain the fixed world position. Linked mode only changes the temporary render target.
p3d_world_lat = tgt_lat;
p3d_world_fb = tgt_fb;
p3d_world_dist_n = tgt_dist_n;
p3d_world_r = sqrt(p3d_world_lat*p3d_world_lat + p3d_world_fb*p3d_world_fb);
p3d_world_r > 1 ? p3d_world_r = 1;
p3d_world_ang = p3d_angle_from_lat_fb(p3d_world_lat, p3d_world_fb);
p3d_effective_ang = p3d_world_ang;
p3d_effective_lat = p3d_world_lat;
p3d_effective_fb = p3d_world_fb;

p3d_link_active ? (
  // Rotation uses fixed object world coordinates. Distance is recalculated from
  // the transformed topology instead of only multiplying the old Distance knob.
  p3d_effective_ang = p3d_wrap_deg(p3d_world_ang - p3d_camera_rot * p3d_manager_amt);
  tgt_lat = sin(p3d_effective_ang * $pi / 180) * p3d_world_r;
  tgt_fb  = cos(p3d_effective_ang * $pi / 180) * p3d_world_r;

  // Topology-aware distance: when a camera turn pulls a rear/side object toward
  // the front plane it feels less distant; when it pushes the object rearward it
  // feels farther. Manager Distance Scale can exaggerate this well beyond 2x.
  p3d_depth_delta = tgt_fb - p3d_world_fb;
  p3d_side_delta = abs(tgt_lat) - abs(p3d_world_lat);
  p3d_topology_dist = 1 - 0.42 * p3d_depth_delta * p3d_manager_amt + 0.10 * p3d_side_delta * p3d_manager_amt;
  p3d_topology_dist < 0.25 ? p3d_topology_dist = 0.25;
  p3d_topology_dist > 4.00 ? p3d_topology_dist = 4.00;
  tgt_dist_n = p3d_world_dist_n * (1 + (p3d_distance_scale - 1) * p3d_manager_amt) * p3d_topology_dist;
  tgt_dist_n < 0 ? tgt_dist_n = 0;
  tgt_dist_n > 4.0 ? tgt_dist_n = 4.0;

  p3d_effective_lat = tgt_lat;
  p3d_effective_fb = tgt_fb;
);

last_manager_link = p3d_link_enabled;
last_manager_active = p3d_link_active;
last_manager_id = p3d_manager_iid;
last_object_id = p3d_obj_id;
last_world_az = p3d_world_ang;
last_effective_az = p3d_effective_ang;
last_effective_lat = p3d_effective_lat;
last_effective_fb = p3d_effective_fb;
last_effective_dist_n = tgt_dist_n;
last_camera_rot = p3d_camera_rot;

// --- visual coordinate normalization ---
pos_r = sqrt(tgt_lat*tgt_lat + tgt_fb*tgt_fb);
(pos_r > 1) ? (
  vis_lat = tgt_lat / pos_r;
  vis_fb = tgt_fb / pos_r;
  pos_r = 1;
) : (
  vis_lat = tgt_lat;
  vis_fb = tgt_fb;
);

// If object is dead-center, treat it as front-center so cue math stays stable.
pos_r < 0.0001 ? (
  raw_side = 0;
  raw_front = 1;
) : (
  raw_side = vis_lat / pos_r;
  raw_front = vis_fb / pos_r;
);

// Visual angle readout, preserving V5 convention: negative = left, positive = right.
vis_ang = atan(raw_side / (abs(raw_front) + 0.000000000000000001)) * 180 / $pi;
(raw_front < 0) ? (
  raw_side >= 0 ? vis_ang = 180 - vis_ang : vis_ang = -180 - vis_ang;
);
last_visual_az = vis_ang;
last_lat = vis_lat;
last_fb = vis_fb;

// Spatial Throw becomes the cue-stack intensity. Automation Safe caps it.
throw_dsp = tgt_throw;
auto_safe && throw_dsp > 0.72 ? throw_dsp = 0.72;
last_throw = tgt_throw;
last_throw_dsp = throw_dsp;

// Perceptual compression: 45 degrees visual no longer equals 70% max side cue by default.
// Throw 100% returns to raw/V5-like side cueing. Lower throw both compresses and scales.
curve_eff = 1 + (1 - throw_dsp) * (cue_curve_user - 1);
last_cue_curve_eff = curve_eff;
side_abs = abs(raw_side);
cue_side = side_abs^curve_eff;
raw_side < 0 ? cue_side = -cue_side;
cue_side *= 0.50 + 0.50*throw_dsp;
cue_side > 0.999 ? cue_side = 0.999;
cue_side < -0.999 ? cue_side = -0.999;
cue_front_abs = sqrt(1 - cue_side*cue_side);
cue_front = raw_front < 0 ? -cue_front_abs : cue_front_abs;

cue_ang = atan(cue_side / (abs(cue_front) + 0.000000000000000001)) * 180 / $pi;
(cue_front < 0) ? (
  cue_side >= 0 ? cue_ang = 180 - cue_ang : cue_ang = -180 - cue_ang;
);
tgt_az = cue_ang;
last_cue_az = cue_ang;

// Distance mapping: local UI stays high-resolution; Manager-linked topology can extend effective distance beyond the local 0..1 range.
// V6.13 separates perceptual meters from normalized DSP distance. The room, width and nearfield laws stay 0..1;
// far-field cues use a log-distance weight so 10 m reads distant and 80+ m stays clear instead of just wet.
tgt_dist_calc = tgt_dist_n;
tgt_dist_calc < 0 ? tgt_dist_calc = 0;
tgt_dist_calc > 4 ? tgt_dist_calc = 4;
tgt_depth = tgt_dist_calc;
tgt_depth > 1 ? tgt_depth = 1;
_depth2 = tgt_depth*tgt_depth;
_depth3 = _depth2*tgt_depth;
dist_m = p3d_distance_m_from_n(tgt_dist_calc);
last_dist_m = dist_m;
tgt_far01 = p3d_far01_from_m(dist_m);
last_far01 = tgt_far01;

// Direct gain vs distance/occlusion. Allow real far-field attenuation below the old -18 dB floor.
_direct_g = 1 / (1 + 0.18*dist_m + 0.0035*dist_m*dist_m);
_direct_g *= 1 - 0.28*tgt_occ;
_direct_floor = 0.014 + 0.096*(1 - tgt_far01)*(1 - tgt_far01);
_direct_g < _direct_floor ? _direct_g = _direct_floor;
tgt_direct_g = _direct_g;

// Room gain vs distance + occlusion. Far distance is carried by level/spectrum/detail, not by runaway wetness.
_er_far_trim = 1 - 0.58*tgt_far01;
_er_far_trim < 0.38 ? _er_far_trim = 0.38;
_er_g = tgt_room * (0.035 + 0.14*tgt_depth + 0.06*_depth2);
_er_g *= _er_far_trim;
_er_g *= 1 + 0.60*tgt_occ;
tgt_er_g = _er_g;

// Air absorption cutoff: log-distance driven, so 10 m is clear-but-far and 80 m is darkened without turning into mud.
air_fc = 19000 * (1 - 0.68*tgt_far01) / (1 + 1.25*tgt_occ);
air_fc < 2800 ? air_fc = 2800;
air_fc > 19000 ? air_fc = 19000;
last_air_fc = air_fc;
tgt_air_a = exp(-2*$pi*air_fc/srate);

// Occlusion cutoff
occ_fc = 13000 / (1 + 18*tgt_occ*tgt_occ);
occ_fc < 450 ? occ_fc = 450;
occ_fc > 13000 ? occ_fc = 13000;
tgt_occ_a = exp(-2*$pi*occ_fc/srate);

// Room geometry (for early reflections + UI readout)
room_curve = tgt_rsize*tgt_rsize*(0.72 + 0.28*tgt_rsize);
room_w = 2.8 + 9.8*room_curve;
room_d = 3.3 + 12.2*room_curve;
last_room_w = room_w;
last_room_d = room_d;

// Reflection delays from a simple image-source style room.
// Uses visual object coordinate, not compressed cue angle, so the room picture remains honest.
src_nx = 0.74 * vis_lat;
src_ny = 0.74 * vis_fb;

hw = room_w * 0.5;
hd = room_d * 0.5;

direct_geom = sqrt((src_nx*hw)*(src_nx*hw) + (src_ny*hd)*(src_ny*hd));
direct_geom < 0.08 ? direct_geom = 0.08;

len_l  = sqrt(((-2 - src_nx)*hw)*((-2 - src_nx)*hw) + ((src_ny)*hd)*((src_ny)*hd));
len_r  = sqrt((( (2 - src_nx)*hw))*(((2 - src_nx)*hw)) + ((src_ny)*hd)*((src_ny)*hd));
len_f  = sqrt(((src_nx*hw)*(src_nx*hw)) + (((2 - src_ny)*hd)*((2 - src_ny)*hd)));
len_b  = sqrt(((src_nx*hw)*(src_nx*hw)) + (((-2 - src_ny)*hd)*((-2 - src_ny)*hd)));
len_fl = sqrt(((-2 - src_nx)*hw)*((-2 - src_nx)*hw) + (((2 - src_ny)*hd)*((2 - src_ny)*hd)));
len_fr = sqrt((((2 - src_nx)*hw))*(((2 - src_nx)*hw)) + (((2 - src_ny)*hd)*((2 - src_ny)*hd)));
len_bl = sqrt(((-2 - src_nx)*hw)*((-2 - src_nx)*hw) + (((-2 - src_ny)*hd)*((-2 - src_ny)*hd)));
len_br = sqrt((((2 - src_nx)*hw))*(((2 - src_nx)*hw)) + (((-2 - src_ny)*hd)*((-2 - src_ny)*hd)));

ms_scale = 1000/343;
base_ms = 0.8 + 1.4*tgt_depth + 1.4*tgt_far01 + 0.6*tgt_room;

d1 = base_ms + max(1.0, (len_l  - direct_geom) * ms_scale);
d2 = base_ms + max(1.0, (len_r  - direct_geom) * ms_scale);
d3 = base_ms + max(1.0, (len_f  - direct_geom) * ms_scale);
d4 = base_ms + max(1.2, (len_b  - direct_geom) * ms_scale);
d5 = base_ms + max(1.5, (len_fl - direct_geom) * ms_scale);
d6 = base_ms + max(1.5, (len_fr - direct_geom) * ms_scale);
d7 = base_ms + max(1.8, (len_bl - direct_geom) * ms_scale);
d8 = base_ms + max(1.8, (len_br - direct_geom) * ms_scale);

tgt_er1_d = d1 * srate * 0.001;
tgt_er2_d = d2 * srate * 0.001;
tgt_er3_d = d3 * srate * 0.001;
tgt_er4_d = d4 * srate * 0.001;
tgt_er5_d = d5 * srate * 0.001;
tgt_er6_d = d6 * srate * 0.001;
tgt_er7_d = d7 * srate * 0.001;
tgt_er8_d = d8 * srate * 0.001;

// Reflection LPFs get darker with perceived distance + occlusion, but not linearly with meters.
hf_scale = (1 - 0.55*tgt_far01) / (1 + 1.1*tgt_occ);

c1 = 11800*hf_scale; c2 = 11800*hf_scale; c3 = 10200*hf_scale; c4 = 7200*hf_scale;
c5 = 7600*hf_scale;  c6 = 7600*hf_scale;  c7 = 5200*hf_scale; c8 = 5200*hf_scale;

c1 < 1500 ? c1=1500; c2 < 1500 ? c2=1500; c3 < 1500 ? c3=1500; c4 < 1500 ? c4=1500;
c5 < 1500 ? c5=1500; c6 < 1500 ? c6=1500; c7 < 1500 ? c7=1500; c8 < 1500 ? c8=1500;

c1 > 18000 ? c1=18000; c2 > 18000 ? c2=18000; c3 > 18000 ? c3=18000; c4 > 18000 ? c4=18000;
c5 > 18000 ? c5=18000; c6 > 18000 ? c6=18000; c7 > 18000 ? c7=18000; c8 > 18000 ? c8=18000;

er_a1 = exp(-2*$pi*c1/srate);
er_a2 = exp(-2*$pi*c2/srate);
er_a3 = exp(-2*$pi*c3/srate);
er_a4 = exp(-2*$pi*c4/srate);
er_a5 = exp(-2*$pi*c5/srate);
er_a6 = exp(-2*$pi*c6/srate);
er_a7 = exp(-2*$pi*c7/srate);
er_a8 = exp(-2*$pi*c8/srate);

// --- Pinna externalize biquad (negative peaking EQ = notch hint) ---
az_rad = tgt_az * $pi / 180;
az_s = sin(az_rad);
az_c = cos(az_rad);
az_abs = abs(az_s);
front = max(0, az_c);
rear = max(0, -az_c);
side = 1 - abs(az_c);
side < 0 ? side = 0;
last_rear = rear;
last_front = front;
last_side = side;
last_back = rear;

focus = 1 - 0.74*tgt_width;
focus < 0.18 ? focus = 0.18;
last_focus = focus;
last_shadow = az_abs * focus;

// semantic zone weighting:
// front = cleaner / tighter
// side  = stronger lateral lock
// back  = darker / more notch / wider reflections
zone_notch = 0.70 + 0.55*side + 0.85*rear;
dist_focus = 1 - 0.34*tgt_far01;
dist_focus < 0.58 ? dist_focus = 0.58;
notch_db = -6.8 * tgt_ext * (0.18 + 0.82*az_abs) * zone_notch * focus * dist_focus;
last_ext_db = notch_db;

Q = 3.0 + 2.6*tgt_ext;

base_fc = 7150 + 220*front - 650*side - 1250*rear;
span_fc = (1700 + 450*side + 250*rear) * focus;

fc_l = base_fc - span_fc*az_s;
fc_r = base_fc + span_fc*az_s;

fc_l < 2200 ? fc_l = 2200; fc_l > 11200 ? fc_l = 11200;
fc_r < 2200 ? fc_r = 2200; fc_r > 11200 ? fc_r = 11200;

abs(notch_db) < 0.001 ? (
  pn_t_b0_l = 1; pn_t_b1_l = 0; pn_t_b2_l = 0; pn_t_a1_l = 0; pn_t_a2_l = 0;
  pn_t_b0_r = 1; pn_t_b1_r = 0; pn_t_b2_r = 0; pn_t_a1_r = 0; pn_t_a2_r = 0;
) : (
  A = 10^(notch_db/40);

  // Left
  w0 = 2*$pi*fc_l/srate;
  cs = cos(w0);
  sn = sin(w0);
  alpha = sn/(2*Q);
  b0 = 1 + alpha*A;
  b1 = -2*cs;
  b2 = 1 - alpha*A;
  a0 = 1 + alpha/A;
  a1 = -2*cs;
  a2 = 1 - alpha/A;
  b0 /= a0; b1 /= a0; b2 /= a0; a1 /= a0; a2 /= a0;
  pn_t_b0_l = b0; pn_t_b1_l = b1; pn_t_b2_l = b2; pn_t_a1_l = a1; pn_t_a2_l = a2;

  // Right
  w0 = 2*$pi*fc_r/srate;
  cs = cos(w0);
  sn = sin(w0);
  alpha = sn/(2*Q);
  b0 = 1 + alpha*A;
  b1 = -2*cs;
  b2 = 1 - alpha*A;
  a0 = 1 + alpha/A;
  a1 = -2*cs;
  a2 = 1 - alpha/A;
  b0 /= a0; b1 /= a0; b2 /= a0; a1 /= a0; a2 /= a0;
  pn_t_b0_r = b0; pn_t_b1_r = b1; pn_t_b2_r = b2; pn_t_a1_r = a1; pn_t_a2_r = a2;
);

// Rear tint targets (very gentle, only when push out is up)
rear_t_mix = (0.08*side + 0.34*rear) * tgt_ext;
rear_fc = 18000 / (1 + 1.2*side*tgt_ext + 2.8*rear*tgt_ext);
rear_fc < 2300 ? rear_fc = 2300;
rear_fc > 18000 ? rear_fc = 18000;
rear_t_a = exp(-2*$pi*rear_fc/srate);

p3d_seq += 1;
p3d_publish_slot();
p3d_link_enabled ? msg_send(#p3d_registry_bus, P3D_OP_PANNER_HEART, p3d_iid, p3d_obj_id, p3d_world_ang, p3d_effective_ang);

@sample
// --- input to mono ---
mono_in = (spl0 + spl1) * 0.5;

// --- smooth user params ---
sm_az     += (tgt_az     - sm_az)     * smooth_k;
sm_depth  += (tgt_depth  - sm_depth)  * smooth_k;
sm_far    += (tgt_far01  - sm_far)    * smooth_k;
sm_width  += (tgt_width  - sm_width)  * smooth_k;
sm_ext    += (tgt_ext    - sm_ext)    * smooth_k;
sm_room   += (tgt_room   - sm_room)   * smooth_k;
sm_rsize  += (tgt_rsize  - sm_rsize)  * smooth_k;
sm_occ    += (tgt_occ    - sm_occ)    * smooth_k;
sm_motion += (tgt_motion - sm_motion) * smooth_k;
sm_trim   += (tgt_trim   - sm_trim)   * smooth_k;

// --- smooth derived ---
sm_direct_g += (tgt_direct_g - sm_direct_g) * smooth_k;
sm_er_g     += (tgt_er_g     - sm_er_g)     * smooth_k;
sm_air_a    += (tgt_air_a    - sm_air_a)    * coeff_k;
sm_occ_a    += (tgt_occ_a    - sm_occ_a)    * coeff_k;

sm_er1_d += (tgt_er1_d - sm_er1_d) * smooth_k;
sm_er2_d += (tgt_er2_d - sm_er2_d) * smooth_k;
sm_er3_d += (tgt_er3_d - sm_er3_d) * smooth_k;
sm_er4_d += (tgt_er4_d - sm_er4_d) * smooth_k;
sm_er5_d += (tgt_er5_d - sm_er5_d) * smooth_k;
sm_er6_d += (tgt_er6_d - sm_er6_d) * smooth_k;
sm_er7_d += (tgt_er7_d - sm_er7_d) * smooth_k;
sm_er8_d += (tgt_er8_d - sm_er8_d) * smooth_k;

// Smooth pinna biquad coefficients
pn_b0_l += (pn_t_b0_l - pn_b0_l) * coeff_k;
pn_b1_l += (pn_t_b1_l - pn_b1_l) * coeff_k;
pn_b2_l += (pn_t_b2_l - pn_b2_l) * coeff_k;
pn_a1_l += (pn_t_a1_l - pn_a1_l) * coeff_k;
pn_a2_l += (pn_t_a2_l - pn_a2_l) * coeff_k;

pn_b0_r += (pn_t_b0_r - pn_b0_r) * coeff_k;
pn_b1_r += (pn_t_b1_r - pn_b1_r) * coeff_k;
pn_b2_r += (pn_t_b2_r - pn_b2_r) * coeff_k;
pn_a1_r += (pn_t_a1_r - pn_a1_r) * coeff_k;
pn_a2_r += (pn_t_a2_r - pn_a2_r) * coeff_k;

rear_a   += (rear_t_a   - rear_a)   * coeff_k;
rear_mix += (rear_t_mix - rear_mix) * coeff_k;

// --- optional micro motion ---
ph1 += (2*$pi*(0.12 + 0.08*sm_motion))/srate;
ph2 += (2*$pi*(0.20 + 0.10*sm_motion))/srate;
(ph1 > 2*$pi) ? ph1 -= 2*$pi;
(ph2 > 2*$pi) ? ph2 -= 2*$pi;

mot_deg = 2.3 * sm_motion;
az_eff = sm_az + mot_deg*(sin(ph1) + 0.55*sin(ph2));
az_eff > 180 ? az_eff = 180;
az_eff < -180 ? az_eff = -180;

// --- distance / air absorption ---
air_state = (1-sm_air_a)*mono_in + sm_air_a*air_state;

// --- stable occlusion source model ---
// Build a mono blocked-source color for reflections, but keep the direct
// localization feed clean. Applying the occlusion smear before ITD made the
// delayed/far ear hear the blocker as a separate moving cue.
occ_lp = (1-sm_occ_a)*air_state + sm_occ_a*occ_lp;
occ_low_mem = (1-occ_split_a)*occ_lp + occ_split_a*occ_low_mem;
occ_high = occ_lp - occ_low_mem;

occ_low_g  = 1 + 0.24*sm_occ;
occ_high_g = 1 - 0.86*sm_occ;
occ_high_g < 0.10 ? occ_high_g = 0.10;
occ_sig = occ_low_mem*occ_low_g + occ_high*occ_high_g;

// Reflection-only phase smear. The direct path gets per-ear coloration later,
// after localization, which prevents opposite-ear occlusion flicker.
ap_a = 0.38 + 0.16*sm_occ;
ap_y = -ap_a*occ_sig + occ_ap_x1 + ap_a*occ_ap_y1;
occ_ap_x1 = occ_sig;
occ_ap_y1 = ap_y;
occ_er_sig = occ_sig*(1 - 0.30*sm_occ) + ap_y*(0.30*sm_occ);

// Direct path is localized first; reflections are less occluded and may smear.
direct_feed = air_state;
er_feed = air_state*(1 - 0.28*sm_occ) + occ_er_sig*(0.28*sm_occ);

// --- ITD delay line ---
itdbuf[itd_wpos] = direct_feed;

az_rad = az_eff * $pi / 180;
az_sin = sin(az_rad);
az_cos = cos(az_rad);
az_abs = abs(az_sin);
az_sign = az_eff >= 0 ? 1 : -1;

focus = 1 - 0.74*sm_width;
focus *= 1 - 0.20*sm_far;
focus < 0.14 ? focus = 0.14;

itd_ms = 0.68 * az_sin * focus;
last_itd_ms = itd_ms;
itd_spl = abs(itd_ms) * 0.001 * srate;
itd_i = floor(itd_spl);
itd_f = itd_spl - itd_i;
idx0 = (itd_wpos - itd_i) & itd_mask;
idx1 = (itd_wpos - itd_i - 1) & itd_mask;
far_sig = itdbuf[idx0]*(1-itd_f) + itdbuf[idx1]*itd_f;

az_eff < 0 ? (
  sig_l = direct_feed;
  sig_r = far_sig;
) : (
  sig_l = far_sig;
  sig_r = direct_feed;
);

itd_wpos = (itd_wpos + 1) & itd_mask;

// --- perceptual band split (rough critical-band inspired weighting) ---
l_band1 = (1-band1_a)*sig_l + band1_a*l_band1;
l_rem1 = sig_l - l_band1;
l_band2 = (1-band2_a)*l_rem1 + band2_a*l_band2;
l_lowb = l_band1;
l_midb = l_band2;
l_hib = l_rem1 - l_band2;

r_band1 = (1-band1_a)*sig_r + band1_a*r_band1;
r_rem1 = sig_r - r_band1;
r_band2 = (1-band2_a)*r_rem1 + band2_a*r_band2;
r_lowb = r_band1;
r_midb = r_band2;
r_hib = r_rem1 - r_band2;

// --- frequency-shaped directional weighting ---
front = max(0, az_cos);
rear = max(0, -az_cos);
side = 1 - abs(az_cos);
side < 0 ? side = 0;
shadow = az_abs * focus;
nearfield = 1 - sm_depth;
nearfield < 0 ? nearfield = 0;

// semantic field zones
front_tight = 1 + 0.12*front;
side_lock   = 1 + 0.28*side;
rear_diff   = 1 + 0.30*rear;

// low band = mostly ITD, mild level asymmetry
low_near_g = 1 + 0.03*shadow;
low_far_g  = 1 - 0.10*shadow;
low_far_g < 0.84 ? low_far_g = 0.84;

// mid band = stronger direction + slight proximity push
mid_shape = (1 + 0.10*sm_ext*front - 0.16*sm_ext*rear) * (1 + 0.10*side);
mid_near_g = (1 + 0.10*shadow*side_lock + 0.05*nearfield) * mid_shape;
mid_far_g  = (1 - 0.36*shadow*side_lock - 0.05*rear) * (1 - 0.05*sm_ext*rear);
mid_far_g < 0.30 ? mid_far_g = 0.30;

// high band = strongest head shadow + front/back character
hi_shape = (1 + 0.08*sm_ext*front - 0.24*sm_ext*rear) * (1 + 0.08*side);
hi_near_g = (1 + 0.18*shadow*side_lock + 0.05*nearfield + 0.05*sm_ext*front) * hi_shape;
hi_far_g  = (1 - 0.92*shadow*side_lock - 0.22*sm_ext*rear);
hi_far_g < 0.08 ? hi_far_g = 0.08;

az_eff < 0 ? (
  dir_l = l_lowb*low_near_g + l_midb*mid_near_g + l_hib*hi_near_g;
  dir_r = r_lowb*low_far_g  + r_midb*mid_far_g  + r_hib*hi_far_g;
) : (
  dir_l = l_lowb*low_far_g  + l_midb*mid_far_g  + l_hib*hi_far_g;
  dir_r = r_lowb*low_near_g + r_midb*mid_near_g + r_hib*hi_near_g;
);

// Additional broad-band split for a gentle low/high pan contour
l_low = (1-split_a)*dir_l + split_a*l_low;
r_low = (1-split_a)*dir_r + split_a*r_low;
l_high = dir_l - l_low;
r_high = dir_r - r_low;

shadow_h = shadow;
shadow_l = shadow * 0.25;

near_low_g = 1 + 0.03*shadow_l;
far_low_g  = 1 - 0.14*shadow_l;
near_hi_g  = 1 + 0.06*shadow_h;
far_hi_g   = 1 - 0.28*shadow_h;
far_hi_g < 0.70 ? far_hi_g = 0.70;

az_eff < 0 ? (
  dir_l = l_low*near_low_g + l_high*near_hi_g;
  dir_r = r_low*far_low_g  + r_high*far_hi_g;
) : (
  dir_l = l_low*far_low_g  + l_high*far_hi_g;
  dir_r = r_low*near_low_g + r_high*near_hi_g;
);

// Width = blur toward center, more at distance
center_blend = sm_width * (0.22 + 0.10*sm_depth + 0.10*rear) + 0.035*sm_far*(1 + 0.35*rear);
center_blend > 0.48 ? center_blend = 0.48;
dir_l = dir_l*(1-center_blend) + direct_feed*center_blend;
dir_r = dir_r*(1-center_blend) + direct_feed*center_blend;

// --- stable per-ear occlusion coloration ---
// Color the already-localized left/right direct path instead of feeding a
// pre-occluded mono signal into ITD. This keeps the blocker attached to the
// object and stops far-ear flicker when Occlusion is high.
occ_dir_lp_l = (1-sm_occ_a)*dir_l + sm_occ_a*occ_dir_lp_l;
occ_dir_low_l = (1-occ_split_a)*occ_dir_lp_l + occ_split_a*occ_dir_low_l;
occ_dir_high_l = occ_dir_lp_l - occ_dir_low_l;
occ_dir_col_l = occ_dir_low_l*occ_low_g + occ_dir_high_l*occ_high_g;

occ_dir_lp_r = (1-sm_occ_a)*dir_r + sm_occ_a*occ_dir_lp_r;
occ_dir_low_r = (1-occ_split_a)*occ_dir_lp_r + occ_split_a*occ_dir_low_r;
occ_dir_high_r = occ_dir_lp_r - occ_dir_low_r;
occ_dir_col_r = occ_dir_low_r*occ_low_g + occ_dir_high_r*occ_high_g;

occ_blend = sm_occ;
dir_l = dir_l*(1-occ_blend) + occ_dir_col_l*occ_blend;
dir_r = dir_r*(1-occ_blend) + occ_dir_col_r*occ_blend;

// --- pinna externalize hint ---
pn_y = pn_b0_l*dir_l + pn_b1_l*pn_x1_l + pn_b2_l*pn_x2_l - pn_a1_l*pn_y1_l - pn_a2_l*pn_y2_l;
pn_x2_l = pn_x1_l; pn_x1_l = dir_l;
pn_y2_l = pn_y1_l; pn_y1_l = pn_y;
dir_l = pn_y;

pn_y = pn_b0_r*dir_r + pn_b1_r*pn_x1_r + pn_b2_r*pn_x2_r - pn_a1_r*pn_y1_r - pn_a2_r*pn_y2_r;
pn_x2_r = pn_x1_r; pn_x1_r = dir_r;
pn_y2_r = pn_y1_r; pn_y1_r = pn_y;
dir_r = pn_y;

// --- rear tint ---
rear_lp_l = (1-rear_a)*dir_l + rear_a*rear_lp_l;
rear_lp_r = (1-rear_a)*dir_r + rear_a*rear_lp_r;
dir_l = dir_l*(1-rear_mix) + rear_lp_l*rear_mix;
dir_r = dir_r*(1-rear_mix) + rear_lp_r*rear_mix;
dir_l *= front_tight;
dir_r *= front_tight;
rear_scale = 1 - 0.05*rear;
dir_l *= rear_scale + 0.05*front;
dir_r *= rear_scale + 0.05*front;

// apply distance gain after spectral cues
dir_l *= sm_direct_g;
dir_r *= sm_direct_g;

// --- Early reflections buffer ---
erbuf[er_wpos] = er_feed;

er_l = 0;
er_r = 0;
rear_wide = 1 + 0.32*rear;
front_focus = 1 - 0.20*front;
side_wide = 1 + 0.18*side;

// Tap 1: left wall
rd = sm_er1_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp1 = (1-er_a1)*tap + er_a1*er_lp1;
er_l += er_lp1 * 0.45 * 1.22 * front_focus;
er_r += er_lp1 * 0.45 * 0.74 * front_focus;

// Tap 2: right wall
rd = sm_er2_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp2 = (1-er_a2)*tap + er_a2*er_lp2;
er_l += er_lp2 * 0.45 * 0.74 * front_focus;
er_r += er_lp2 * 0.45 * 1.22 * front_focus;

// Tap 3: front wall
rd = sm_er3_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp3 = (1-er_a3)*tap + er_a3*er_lp3;
er_l += er_lp3 * 0.34 * (0.98 + 0.05*side);
er_r += er_lp3 * 0.34 * (0.98 + 0.05*side);

// Tap 4: back wall
rd = sm_er4_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp4 = (1-er_a4)*tap + er_a4*er_lp4;
er_l += er_lp4 * 0.26 * rear_wide * 1.04;
er_r += er_lp4 * 0.26 * rear_wide * 1.04;

// Tap 5: front-left corner
rd = sm_er5_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp5 = (1-er_a5)*tap + er_a5*er_lp5;
er_l += er_lp5 * 0.20 * 1.16;
er_r += er_lp5 * 0.20 * 0.86;

// Tap 6: front-right corner
rd = sm_er6_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp6 = (1-er_a6)*tap + er_a6*er_lp6;
er_l += er_lp6 * 0.20 * 0.86;
er_r += er_lp6 * 0.20 * 1.16;

// Tap 7: back-left corner
rd = sm_er7_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp7 = (1-er_a7)*tap + er_a7*er_lp7;
er_l += er_lp7 * 0.13 * 1.14 * rear_wide;
er_r += er_lp7 * 0.13 * 0.82 * rear_wide;

// Tap 8: back-right corner
rd = sm_er8_d;
rdi = floor(rd); rdf = rd - rdi;
idx0 = (er_wpos - rdi) & er_mask; idx1 = (er_wpos - rdi - 1) & er_mask;
tap = erbuf[idx0]*(1-rdf) + erbuf[idx1]*rdf;
er_lp8 = (1-er_a8)*tap + er_a8*er_lp8;
er_l += er_lp8 * 0.13 * 0.82 * rear_wide;
er_r += er_lp8 * 0.13 * 1.14 * rear_wide;

// ER decorrelation
apL = 0.53;
apR = 0.69;

er_ap_y = -apL*er_l + er_ap_x1_l + apL*er_ap_y1_l;
er_ap_x1_l = er_l;
er_ap_y1_l = er_ap_y;
er_l = er_ap_y;

er_ap_y = -apR*er_r + er_ap_x1_r + apR*er_ap_y1_r;
er_ap_x1_r = er_r;
er_ap_y1_r = er_ap_y;
er_r = er_ap_y;

// Distance / occlusion push more energy into the room.
// V6.2.2 moderates the occlusion room boost so the opposite ear does not
// read reflections as a second blocker position.
er_push = 0.70 + 0.45*sm_depth + 0.10*sm_far + 0.30*sm_occ + 0.12*side + 0.18*rear;
er_l *= sm_er_g * er_push;
er_r *= sm_er_g * er_push;

// Mix out
out_l = (dir_l + er_l) * sm_trim;
out_r = (dir_r + er_r) * sm_trim;

spl0 = out_l;
spl1 = out_r;
// advance ER buffer
er_wpos = (er_wpos + 1) & er_mask;

// meters
meter_direct += (max(abs(dir_l), abs(dir_r)) - meter_direct) * meter_k;
meter_er     += (max(abs(er_l),  abs(er_r))  - meter_er)     * meter_k;


@gfx 820 500
// V6.5 perceptual-position UI: standalone-clean main surface plus opt-in Manager Link side drawer.

winflags = gfx_getchar(65536);
strlen(#target_manager) <= 0 ? strcpy(#target_manager, "Manager");
strlen(#object_name) <= 0 ? strcpy(#object_name, "Object");
// IPC setup and shared-state publication are @block-only in DSP-JSFX.
// Keep the panner awake via options:idle=always, then let @block own Manager discovery.
// @gfx only edits local UI state and reads the last block-published values.
noop = 0;

// --- layout ---
base_w = 820; base_h = 500;
ui_s = min(gfx_w/base_w, gfx_h/base_h);
ui_s < 0.56 ? ui_s = 0.56;
ui_s > 1.45 ? ui_s = 1.45;

pad = 16*ui_s;
pad < 10 ? pad = 10;
title_h = 48*ui_s;
title_h < 36 ? title_h = 36;
foot_h = 34*ui_s;
foot_h < 28 ? foot_h = 28;

right_w = gfx_w * 0.34;
right_w < 250*ui_s ? right_w = 250*ui_s;
right_w > gfx_w*0.42 ? right_w = gfx_w*0.42;

left_w = gfx_w - right_w - pad*3;
left_w < 265*ui_s ? (
  right_w = gfx_w*0.36;
  left_w = gfx_w - right_w - pad*3;
);
left_w < 245*ui_s ? left_w = 245*ui_s;

field_h = gfx_h - title_h - foot_h - pad*2;
field_h < 230*ui_s ? field_h = 230*ui_s;

canvas_x = pad;
canvas_y = title_h + pad;
canvas_w = left_w;
canvas_h = field_h;

rx = canvas_x + canvas_w + pad;
ry = canvas_y;
rw = gfx_w - rx - pad;
rw < 230*ui_s ? rw = 230*ui_s;
rh = field_h;

cx = canvas_x + canvas_w*0.50;
cy = canvas_y + canvas_h*0.52;

room_hw = canvas_w * 0.39;
room_hd = canvas_h * 0.31;
room_hw < 86*ui_s ? room_hw = 86*ui_s;
room_hd < 70*ui_s ? room_hd = 70*ui_s;
room_hw *= 0.88 + 0.12*slider19;
room_hd *= 0.86 + 0.14*slider19;

room_l = cx - room_hw;
room_r = cx + room_hw;
room_t = cy - room_hd;
room_b = cy + room_hd;

// --- sliders / readouts ---
ui_base_lat = slider6;
ui_base_dist = slider7;
ui_base_fb = slider8;
ui_link_view = (slider4 >= 0.5 && last_manager_active) ? 1 : 0;
ui_lat = ui_link_view ? last_effective_lat : ui_base_lat;
ui_dist = ui_link_view ? last_effective_dist_n : ui_base_dist;
ui_fb = ui_link_view ? last_effective_fb : ui_base_fb;
ui_dist_vis = ui_dist;
ui_dist_vis < 0 ? ui_dist_vis = 0;
ui_dist_vis > 1 ? ui_dist_vis = 1;
ui_throw = slider9;
ui_size = slider10;
ui_push = slider11;
ui_room = slider12;
ui_occ = slider13;
ui_motion = slider14;
ui_trim = slider15;
ui_safe = slider16 >= 0.5 ? 1 : 0;
ui_curve = slider17;
ui_smooth = slider18;
ui_rsize = slider19;
ui_link = slider4 >= 0.5 ? 1 : 0;
ui_obj_id = floor(slider3 + 0.5);
ui_mgr_amt = slider5;
ui_target_mgr = floor(slider20 + 0.5);

pos_r = sqrt(ui_lat*ui_lat + ui_fb*ui_fb);
pos_r > 1 ? (
  draw_lat = ui_lat / pos_r;
  draw_fb = ui_fb / pos_r;
  draw_r = 1;
) : (
  draw_lat = ui_lat;
  draw_fb = ui_fb;
  draw_r = pos_r;
);

sx = cx + draw_lat * room_hw * 0.82;
sy = cy - draw_fb  * room_hd * 0.82;

dot_r = 8.5*ui_s + 4.5*ui_s*ui_size;
// Tooltip hit-tests need these before the drawing pass.
ghost_r = dot_r*0.72;
head_r = 17*ui_s;

cue_rad = last_cue_az * $pi/180;
ghost_x = sin(cue_rad) * draw_r;
ghost_y = cos(cue_rad) * draw_r;
gsx = cx + ghost_x * room_hw * 0.82;
gsy = cy - ghost_y * room_hd * 0.82;

frontness = max(0, draw_fb / (draw_r + 0.000000000000000001));
backness = max(0, -draw_fb / (draw_r + 0.000000000000000001));
sideness = abs(draw_lat / (draw_r + 0.000000000000000001));
draw_r < 0.0001 ? (frontness = 1; backness = 0; sideness = 0;);

// Precompute bounce points before mouse hit-testing so Room tooltips align this frame.
src_nx = draw_lat * 0.82;
src_ny = draw_fb * 0.82;
tL = (-1 - src_nx) / (-2 - src_nx + 0.000000000000000001);
bLx = -1;
bLy = src_ny + tL * (0 - src_ny);
tR = (1 - src_nx) / (2 - src_nx + 0.000000000000000001);
bRx = 1;
bRy = src_ny + tR * (0 - src_ny);
tF = (1 - src_ny) / (2 - src_ny + 0.000000000000000001);
bFx = src_nx + tF * (0 - src_nx);
bFy = 1;
tB = (-1 - src_ny) / (-2 - src_ny + 0.000000000000000001);
bBx = src_nx + tB * (0 - src_nx);
bBy = -1;
bpLx = cx + bLx * room_hw; bpLy = cy - bLy * room_hd;
bpRx = cx + bRx * room_hw; bpRy = cy - bRy * room_hd;
bpFx = cx + bFx * room_hw; bpFy = cy - bFy * room_hd;
bpBx = cx + bBx * room_hw; bpBy = cy - bBy * room_hd;

// --- cards / bars ---
card_gap = 10*ui_s;
card_gap < 6 ? card_gap = 6;

card1_h = rh * 0.18;
card2_h = rh * 0.60;
min_c1 = 96*ui_s;
min_c2 = 265*ui_s;
min_c3 = 112*ui_s;
card1_h < min_c1 ? card1_h = min_c1;
card2_h < min_c2 ? card2_h = min_c2;
card3_h = rh - card1_h - card2_h - card_gap*2;
card3_h < min_c3 ? (
  deficit = min_c3 - card3_h;
  card2_h -= deficit;
  card2_h < 232*ui_s ? card2_h = 232*ui_s;
  card3_h = rh - card1_h - card2_h - card_gap*2;
);
card3_h < 58*ui_s ? card3_h = 58*ui_s;

c1x = rx; c1y = ry; c1w = rw; c1h = card1_h;
c2x = rx; c2y = c1y + c1h + card_gap; c2w = rw; c2h = card2_h;
c3x = rx; c3y = c2y + c2h + card_gap; c3w = rw; c3h = card3_h;

bar_pad_x = 14*ui_s;
value_gutter = 62*ui_s;
value_gutter < 48 ? value_gutter = 48;
barx = c2x + bar_pad_x;
barw = c2w - bar_pad_x*2 - value_gutter;
barw < 96*ui_s ? barw = 96*ui_s;
valx = barx + barw + 8*ui_s;

bars_top = c2y + 44*ui_s;
bars_bottom = c2y + c2h - 10*ui_s;
row_h = (bars_bottom - bars_top) / 10;
row_h < 22*ui_s ? row_h = 22*ui_s;
barh = row_h * 0.32;
barh > 11*ui_s ? barh = 11*ui_s;
barh < 7*ui_s ? barh = 7*ui_s;
label_lift = row_h * 0.42;

b1y = bars_top + row_h*0.50 - barh*0.50;
b2y = bars_top + row_h*1.50 - barh*0.50;
b3y = bars_top + row_h*2.50 - barh*0.50;
b4y = bars_top + row_h*3.50 - barh*0.50;
b5y = bars_top + row_h*4.50 - barh*0.50;
b6y = bars_top + row_h*5.50 - barh*0.50;
b7y = bars_top + row_h*6.50 - barh*0.50;
b8y = bars_top + row_h*7.50 - barh*0.50;
b9y = bars_top + row_h*8.50 - barh*0.50;
b10y = bars_top + row_h*9.50 - barh*0.50;

// --- mouse / hover ---
mouse_l = mouse_cap & 1;
mouse_r = mouse_cap & 2;
mouse_shift = mouse_cap & 8;
mouse_ctrl = mouse_cap & 4;
mouse_alt = mouse_cap & 16;

inside_canvas = mouse_x >= canvas_x && mouse_x <= canvas_x + canvas_w && mouse_y >= canvas_y && mouse_y <= canvas_y + canvas_h;
inside_room = mouse_x >= room_l && mouse_x <= room_r && mouse_y >= room_t && mouse_y <= room_b;
near_src = ((mouse_x-sx)*(mouse_x-sx) + (mouse_y-sy)*(mouse_y-sy)) <= ((dot_r+8*ui_s)*(dot_r+8*ui_s));

hover_bar = 0;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b1y && mouse_y <= b1y+barh) ? hover_bar = 1;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b2y && mouse_y <= b2y+barh) ? hover_bar = 2;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b3y && mouse_y <= b3y+barh) ? hover_bar = 3;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b4y && mouse_y <= b4y+barh) ? hover_bar = 4;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b5y && mouse_y <= b5y+barh) ? hover_bar = 5;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b6y && mouse_y <= b6y+barh) ? hover_bar = 6;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b7y && mouse_y <= b7y+barh) ? hover_bar = 7;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b8y && mouse_y <= b8y+barh) ? hover_bar = 8;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b9y && mouse_y <= b9y+barh) ? hover_bar = 9;
(mouse_x >= barx && mouse_x <= barx+barw && mouse_y >= b10y && mouse_y <= b10y+barh) ? hover_bar = 10;

// Tooltip lane targeting must match the actual slider hitbox exactly.
// V6.2 used widened row hitboxes, which made help trigger above the visible bar
// and made the slider feel visually offset. Keep tooltip hover tied to hover_bar.
hover_tip_bar = hover_bar;

safe_x = c1x + c1w - 112*ui_s;
safe_y = c1y + 10*ui_s;
safe_w = 96*ui_s;
safe_h = 22*ui_s;
hover_safe = mouse_x >= safe_x && mouse_x <= safe_x+safe_w && mouse_y >= safe_y && mouse_y <= safe_y+safe_h;

// Optional Manager Link side drawer. Closed by default so the panner stays clean
// for standalone use. Hitboxes are inactive unless the drawer is open.
drawer_w = 282*ui_s;
drawer_w < 220 ? drawer_w = 220;
drawer_w > gfx_w*0.42 ? drawer_w = gfx_w*0.42;
drawer_x = gfx_w - pad - drawer_w;
drawer_y = canvas_y;
drawer_h = field_h;
drawer_x < canvas_x + 120*ui_s ? drawer_x = canvas_x + 120*ui_s;
drawer_tab_w = 32*ui_s;
drawer_tab_h = 122*ui_s;
drawer_tab_x = gfx_w - drawer_tab_w - 3*ui_s;
drawer_tab_y = canvas_y + 82*ui_s;
hover_drawer_tab = mouse_x >= drawer_tab_x && mouse_x <= drawer_tab_x+drawer_tab_w && mouse_y >= drawer_tab_y && mouse_y <= drawer_tab_y+drawer_tab_h;
inside_drawer = ui_drawer_open && mouse_x >= drawer_x && mouse_x <= drawer_x+drawer_w && mouse_y >= drawer_y && mouse_y <= drawer_y+drawer_h;

box_h = 18*ui_s;
box_h < 15 ? box_h = 15;
link_pad = 14*ui_s;
field_x = drawer_x + link_pad;
field_w = drawer_w - link_pad*2;
bus_y = drawer_y + 70*ui_s;
name_y = drawer_y + 112*ui_s;
id_y = drawer_y + 154*ui_s;

drawer_active = ui_drawer_open || ui_text_active > 0;
scene_btn_w = 22*ui_s;
scene_btn_w < 18 ? scene_btn_w = 18;
scene_btn_x = field_x + field_w - scene_btn_w;
hover_scene_btn = drawer_active && mouse_x >= scene_btn_x && mouse_x <= scene_btn_x+scene_btn_w && mouse_y >= bus_y && mouse_y <= bus_y+box_h;
hover_bus_box = drawer_active && mouse_x >= field_x && mouse_x <= scene_btn_x-3*ui_s && mouse_y >= bus_y && mouse_y <= bus_y+box_h;
hover_name_box = drawer_active && mouse_x >= field_x && mouse_x <= field_x+field_w && mouse_y >= name_y && mouse_y <= name_y+box_h;

scene_menu_x = field_x;
scene_menu_y = bus_y + box_h + 3*ui_s;
scene_row_h = 18*ui_s;
scene_row_h < 15 ? scene_row_h = 15;
scene_menu_w = field_w;
scene_hover_idx = -1;
// Manager dropdown shows active 3DPannerManager names only. If none exist, it shows one local fallback row.
scene_real_count = p3d_ui_scene_count_active();
scene_count = scene_real_count > 0 ? scene_real_count : 1;
scene_rows_vis = scene_count;
scene_rows_vis > 5 ? scene_rows_vis = 5;
scene_menu_h = scene_rows_vis * scene_row_h;
scene_hover_idx = -1;
inside_scene_menu = ui_scene_menu && mouse_x >= scene_menu_x && mouse_x <= scene_menu_x+scene_menu_w && mouse_y >= scene_menu_y && mouse_y <= scene_menu_y + scene_menu_h;
inside_scene_menu ? (
  scene_hover_idx = floor((mouse_y - scene_menu_y) / scene_row_h);
  scene_hover_idx < 0 ? scene_hover_idx = -1;
  scene_hover_idx >= scene_rows_vis ? scene_hover_idx = -1;
);

id_minus_x = field_x + 54*ui_s; id_minus_y = id_y; id_btn_w = 21*ui_s; id_btn_h = box_h;
id_plus_x = id_minus_x + id_btn_w + 42*ui_s; id_plus_y = id_y;
hover_id_minus = 0;
hover_id_plus = 0;

mgr_id_y = drawer_y + 188*ui_s;
mgr_id_minus_x = field_x + 88*ui_s; mgr_id_minus_y = mgr_id_y;
mgr_id_plus_x = mgr_id_minus_x + id_btn_w + 42*ui_s; mgr_id_plus_y = mgr_id_y;
hover_mgr_id_minus = 0;
hover_mgr_id_plus = 0;

link_btn_x = field_x; link_btn_y = drawer_y + 158*ui_s; link_btn_w = field_w; link_btn_h = 28*ui_s;
hover_link_btn = drawer_active && mouse_x >= link_btn_x && mouse_x <= link_btn_x+link_btn_w && mouse_y >= link_btn_y && mouse_y <= link_btn_y+link_btn_h;
amt_x = field_x; amt_y = link_btn_y + 58*ui_s; amt_w = field_w; amt_h = 10*ui_s;
hover_mgr_amt = 0;
hover_textbox = hover_bus_box || hover_name_box;

// GFX-only advanced slider widgets in the bottom card.
adv_barx = c3x + 14*ui_s;
adv_barw = c3w - 76*ui_s;
adv_valx = adv_barx + adv_barw + 7*ui_s;
adv_barw < 74*ui_s ? adv_barw = 74*ui_s;
adv_h = 9*ui_s; adv_h < 7 ? adv_h = 7;
adv1y = c3y + 36*ui_s;
adv2y = c3y + 61*ui_s;
adv3y = c3y + 86*ui_s;
hover_adv = 0;
(mouse_x >= adv_barx && mouse_x <= adv_barx+adv_barw && mouse_y >= adv1y && mouse_y <= adv1y+adv_h) ? hover_adv = 1;
(mouse_x >= adv_barx && mouse_x <= adv_barx+adv_barw && mouse_y >= adv2y && mouse_y <= adv2y+adv_h) ? hover_adv = 2;
(mouse_x >= adv_barx && mouse_x <= adv_barx+adv_barw && mouse_y >= adv3y && mouse_y <= adv3y+adv_h) ? hover_adv = 3;

// Snap chips
chip_h = 22*ui_s;
chip_y = canvas_y + canvas_h - chip_h - 11*ui_s;
chip_gap = 6*ui_s;
chip_x = canvas_x + 14*ui_s;
chip_w = (canvas_w - 28*ui_s - chip_gap*7) / 8;
chip_w > 54*ui_s ? chip_w = 54*ui_s;
chip_w < 34*ui_s ? chip_w = 34*ui_s;
chip1x = chip_x;
chip2x = chip1x + chip_w + chip_gap;
chip3x = chip2x + chip_w + chip_gap;
chip4x = chip3x + chip_w + chip_gap;
chip5x = chip4x + chip_w + chip_gap;
chip6x = chip5x + chip_w + chip_gap;
chip7x = chip6x + chip_w + chip_gap;
chip8x = chip7x + chip_w + chip_gap;

hover_chip = 0;
(mouse_y >= chip_y && mouse_y <= chip_y+chip_h) ? (
  mouse_x >= chip1x && mouse_x <= chip1x+chip_w ? hover_chip = 1;
  mouse_x >= chip2x && mouse_x <= chip2x+chip_w ? hover_chip = 2;
  mouse_x >= chip3x && mouse_x <= chip3x+chip_w ? hover_chip = 3;
  mouse_x >= chip4x && mouse_x <= chip4x+chip_w ? hover_chip = 4;
  mouse_x >= chip5x && mouse_x <= chip5x+chip_w ? hover_chip = 5;
  mouse_x >= chip6x && mouse_x <= chip6x+chip_w ? hover_chip = 6;
  mouse_x >= chip7x && mouse_x <= chip7x+chip_w ? hover_chip = 7;
  mouse_x >= chip8x && mouse_x <= chip8x+chip_w ? hover_chip = 8;
);

// --- tooltip target routing ---
// Numeric IDs keep this JSFX-safe:
// 20s canvas/visual cues, 30 Auto Safe, 40s snap chips, 100s lanes.
tip_id = 0;
tip_hot = (!mouse_l && !mouse_r && ui_mode == 0 && ui_text_active == 0 && !hover_drawer_tab && !inside_drawer && !inside_scene_menu);

tip_hot ? (
  hover_tip_bar > 0 ? tip_id = 100 + hover_tip_bar;
  hover_adv > 0 ? tip_id = 200 + hover_adv;
  hover_safe ? tip_id = 30;
  hover_chip > 0 ? tip_id = 40 + hover_chip;

  // Recompute visible-cue hit zones from the current object/canvas geometry.
  src_dx = mouse_x - sx;
  src_dy = mouse_y - sy;
  src_d2 = src_dx*src_dx + src_dy*src_dy;
  near_src = src_d2 <= ((dot_r+8*ui_s)*(dot_r+8*ui_s));

  ghost_dx = mouse_x - gsx;
  ghost_dy = mouse_y - gsy;
  near_ghost = (ghost_dx*ghost_dx + ghost_dy*ghost_dy) <= ((ghost_r+9*ui_s)*(ghost_r+9*ui_s));

  mouse_rad = sqrt((mouse_x-cx)*(mouse_x-cx) + (mouse_y-cy)*(mouse_y-cy));
  room_edge_hot = inside_canvas && (abs(mouse_x-room_l) < 8*ui_s || abs(mouse_x-room_r) < 8*ui_s || abs(mouse_y-room_t) < 8*ui_s || abs(mouse_y-room_b) < 8*ui_s);
  listener_shell_r = head_r + (10 + 52*ui_push)*ui_s;
  shell_hot = inside_room && ui_push > 0.04 && abs(mouse_rad - listener_shell_r) <= 10*ui_s;

  size_hot_r = dot_r + (8 + 46*(ui_size^0.72))*ui_s;
  size_hot = inside_room && ui_size > 0.06 && !near_src && src_d2 <= size_hot_r*size_hot_r;

  range_min_tip = min(room_hw, room_hd);
  range_active_tip = range_min_tip * (0.18 + 0.70*ui_dist_vis);
  range_hot = inside_room && abs(mouse_rad - range_active_tip) <= 9*ui_s;

  motion_hot_r = (4 + 28*ui_motion)*ui_s + 8*ui_s;
  motion_hot = inside_room && ui_motion > 0.04 && !near_src && src_d2 <= motion_hot_r*motion_hot_r;

  occ_tip_x = cx + (sx-cx)*0.46;
  occ_tip_y = cy + (sy-cy)*0.46;
  occ_hot_r = 18*ui_s + 26*ui_s*ui_occ;
  occ_hot = inside_room && ui_occ > 0.04 && ((mouse_x-occ_tip_x)*(mouse_x-occ_tip_x) + (mouse_y-occ_tip_y)*(mouse_y-occ_tip_y)) <= occ_hot_r*occ_hot_r;

  bounce_hot_r = 2.5*ui_s + 5.2*ui_s*ui_room + 8*ui_s;
  bounce_hot = ui_room > 0.035 && (
    ((mouse_x-bpLx)*(mouse_x-bpLx) + (mouse_y-bpLy)*(mouse_y-bpLy)) <= bounce_hot_r*bounce_hot_r ||
    ((mouse_x-bpRx)*(mouse_x-bpRx) + (mouse_y-bpRy)*(mouse_y-bpRy)) <= bounce_hot_r*bounce_hot_r ||
    ((mouse_x-bpFx)*(mouse_x-bpFx) + (mouse_y-bpFy)*(mouse_y-bpFy)) <= bounce_hot_r*bounce_hot_r ||
    ((mouse_x-bpBx)*(mouse_x-bpBx) + (mouse_y-bpBy)*(mouse_y-bpBy)) <= bounce_hot_r*bounce_hot_r
  );

  head_hot = ((mouse_x-cx)*(mouse_x-cx) + (mouse_y-cy)*(mouse_y-cy)) <= ((head_r+11*ui_s)*(head_r+11*ui_s));

  tip_id == 0 && near_src ? tip_id = 20;
  tip_id == 0 && near_ghost ? tip_id = 21;
  tip_id == 0 && occ_hot ? tip_id = 29;
  tip_id == 0 && bounce_hot ? tip_id = 22;
  tip_id == 0 && shell_hot ? tip_id = 23;
  tip_id == 0 && size_hot ? tip_id = 26;
  tip_id == 0 && motion_hot ? tip_id = 28;
  tip_id == 0 && range_hot ? tip_id = 27;
  tip_id == 0 && room_edge_hot ? tip_id = 22;
  tip_id == 0 && head_hot ? tip_id = 24;
  tip_id == 0 && inside_room ? tip_id = 24;
  tip_id == 0 && inside_canvas ? tip_id = 25;
);

// Small hover delay: prevents flashing while passing over dense controls.
tip_id == tooltip_last_id ? (
  tooltip_frames += 1;
) : (
  tooltip_last_id = tip_id;
  tooltip_frames = 0;
);
tooltip_show = tip_id > 0 && tooltip_frames >= 5;

// --- UI-only text entry ---
// Click Object Name to select the whole current value. The next typed character replaces it.
ui_text_active > 0 ? (
  ui_text_frames += 1;
  while ((key = gfx_getchar()) > 0) (
    key == 13 ? (
      ui_text_active == 1 ? (
        strcpy(#target_manager, #p3d_edit_text);
        strlen(#target_manager) <= 0 ? strcpy(#target_manager, "Manager");
        strcpy(#p3d_edit_manager, #target_manager);
        ui_scene_menu = 0;
        p3d_rebind_pending = 1;
        p3d_bus_hash = p3d_hash_string(#target_manager);
        p3d_mgr_hold = 0;
        p3d_cached_manager_hb = -1;
        p3d_cached_manager_iid = 0;
        p3d_target_mgr_iid = 0;
        p3d_mgr_slot = -1;
        p3d_slot_index = -1;
      ) : ui_text_active == 2 ? (
        strcpy(#object_name, #p3d_edit_text);
        strlen(#object_name) <= 0 ? strcpy(#object_name, "Object");
        strcpy(#p3d_edit_name, #object_name);
        p3d_rebind_pending = 1;
      );
      ui_text_active = 0;
      ui_text_select_all = 0;
      sliderchange(-1.0);
    ) : key == 27 ? (
      ui_text_active = 0;
      ui_text_select_all = 0;
      strcpy(#p3d_edit_text, "");
    ) : (key == 8 || key == 127) ? (
      ui_text_select_all ? (
        strcpy(#p3d_edit_text, "");
        ui_text_select_all = 0;
      ) : (
        tlen = strlen(#p3d_edit_text);
        tlen > 0 ? str_setchar(#p3d_edit_text, tlen-1, 0);
      );
    ) : ((key == 32) || (key >= 33 && key <= 126 && key != 34 && key != 92)) ? (
      ui_text_select_all ? (
        strcpy(#p3d_edit_text, "");
        ui_text_select_all = 0;
      );
      tlen = strlen(#p3d_edit_text);
      tlen < 72 ? (
        key == 32 ? (
          strcpy(#p3d_keychar, "_");
        ) : (
          sprintf(#p3d_keychar, "%c", key);
        );
        strcat(#p3d_edit_text, #p3d_keychar);
      );
    );
  );
) : (
  ui_text_frames = 0;
  ui_text_select_all = 0;
);
// --- wheel controls ---
mouse_wheel != 0 ? (
  wstep = mouse_wheel / 120;
  wheel_scale = mouse_shift ? 0.25 : 1.0;

  ui_text_active > 0 ? (
    noop = 0;
  ) : hover_adv == 1 ? (
    slider17 += wstep * 0.035 * wheel_scale;
    slider17 < 1 ? slider17 = 1; slider17 > 3 ? slider17 = 3;
    sliderchange(-1.0);
  ) : hover_adv == 2 ? (
    slider18 += wstep * 5 * wheel_scale;
    slider18 < 5 ? slider18 = 5; slider18 > 250 ? slider18 = 250;
    sliderchange(-1.0);
  ) : hover_adv == 3 ? (
    slider19 += wstep * 0.035 * wheel_scale;
    slider19 < 0 ? slider19 = 0; slider19 > 1 ? slider19 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 1 ? (
    slider6 += wstep * 0.045 * wheel_scale;
    slider6 < -1 ? slider6 = -1; slider6 > 1 ? slider6 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 2 ? (
    slider8 += wstep * 0.045 * wheel_scale;
    slider8 < -1 ? slider8 = -1; slider8 > 1 ? slider8 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 3 ? (
    slider7 += wstep * 0.035 * wheel_scale;
    slider7 < 0 ? slider7 = 0; slider7 > 1 ? slider7 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 4 ? (
    slider9 += wstep * 0.035 * wheel_scale;
    slider9 < 0 ? slider9 = 0; slider9 > 1 ? slider9 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 5 ? (
    slider10 += wstep * 0.030 * wheel_scale;
    slider10 < 0 ? slider10 = 0; slider10 > 1 ? slider10 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 6 ? (
    slider11 += wstep * 0.035 * wheel_scale;
    slider11 < 0 ? slider11 = 0; slider11 > 1 ? slider11 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 7 ? (
    slider12 += wstep * 0.035 * wheel_scale;
    slider12 < 0 ? slider12 = 0; slider12 > 1 ? slider12 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 8 ? (
    slider13 += wstep * 0.035 * wheel_scale;
    slider13 < 0 ? slider13 = 0; slider13 > 1 ? slider13 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 9 ? (
    slider14 += wstep * 0.030 * wheel_scale;
    slider14 < 0 ? slider14 = 0; slider14 > 1 ? slider14 = 1;
    sliderchange(-1.0);
  ) : hover_bar == 10 ? (
    slider15 += wstep * 0.4 * wheel_scale;
    slider15 < -18 ? slider15 = -18; slider15 > 12 ? slider15 = 12;
    sliderchange(-1.0);
  ) : inside_canvas ? (
    mouse_ctrl ? (
      slider9 += wstep * 0.035 * wheel_scale;
      slider9 < 0 ? slider9 = 0; slider9 > 1 ? slider9 = 1;
    ) : mouse_alt ? (
      slider11 += wstep * 0.035 * wheel_scale;
      slider11 < 0 ? slider11 = 0; slider11 > 1 ? slider11 = 1;
    ) : (
      slider7 += wstep * 0.035 * wheel_scale;
      slider7 < 0 ? slider7 = 0; slider7 > 1 ? slider7 = 1;
    );
    sliderchange(-1.0);
  );
  mouse_wheel = 0;
);

// --- press actions ---
(!ui_prev_r && mouse_r) ? (
  inside_canvas ? (
    slider6 = 0;
    slider7 = 0.25;
    slider8 = 0.82;
    sliderchange(-1.0);
  ) : hover_bar == 1 ? (slider6 = 0; sliderchange(-1.0);) :
  hover_bar == 2 ? (slider8 = 0.82; sliderchange(-1.0);) :
  hover_bar == 3 ? (slider7 = 0.25; sliderchange(-1.0);) :
  hover_bar == 4 ? (slider9 = 0.58; sliderchange(-1.0);) :
  hover_bar == 5 ? (slider10 = 0.10; sliderchange(-1.0);) :
  hover_bar == 6 ? (slider11 = 0.42; sliderchange(-1.0);) :
  hover_bar == 7 ? (slider12 = 0.30; sliderchange(-1.0);) :
  hover_bar == 8 ? (slider13 = 0.00; sliderchange(-1.0);) :
  hover_bar == 9 ? (slider14 = 0.04; sliderchange(-1.0);) :
  hover_bar == 10 ? (slider15 = 0.0; sliderchange(-1.0);) :
  hover_adv == 1 ? (slider17 = 2.0; sliderchange(-1.0);) :
  hover_adv == 2 ? (slider18 = 90; sliderchange(-1.0);) :
  hover_adv == 3 ? (slider19 = 0.55; sliderchange(-1.0););
);

(!ui_prev_l && mouse_l) ? (
  ui_scene_menu && scene_hover_idx >= 0 ? (
    scene_real_count > 0 ? (
      p3d_ui_scene_select_nth(scene_hover_idx);
    ) : (
      strcpy(#target_manager, "Manager");
      slider20 = 1;
      p3d_target_mgr_iid = 0;
    );
    strlen(#target_manager) <= 0 ? strcpy(#target_manager, "Manager");
    strcpy(#p3d_edit_manager, #target_manager);
    p3d_bus_hash = p3d_hash_string(#target_manager);
    p3d_mgr_hold = 0;
    p3d_cached_manager_hb = -1;
    p3d_cached_manager_iid = 0;
    p3d_cached_manager_enabled = 0;
    p3d_cached_camera_rot = 0;
    p3d_cached_distance_scale = 1;
    p3d_target_mgr_iid = 0;
    p3d_manager_iid = 0;
    p3d_mgr_slot = -1;
    p3d_slot_index = -1;
    ui_scene_menu = 0;
    ui_text_active = 0;
    p3d_rebind_pending = 1;
    sliderchange(-1.0);
  ) : (hover_scene_btn || hover_bus_box) ? (
    ui_scene_menu = 1 - ui_scene_menu;
    ui_text_active = 0;
    p3d_allow_msg = 0;
    p3d_service_registry();
    sliderchange(-1.0);
  ) : hover_drawer_tab ? (
    ui_drawer_open = 1 - ui_drawer_open;
    ui_text_active = 0;
    ui_scene_menu = 0;
    p3d_allow_msg = 0;
    p3d_service_registry();
    sliderchange(-1.0);
  ) : hover_name_box ? (
    ui_text_active = 2;
    ui_text_frames = 0;
    ui_text_select_all = 1;
    strcpy(#p3d_edit_text, #object_name);
  ) : ui_scene_menu && !inside_scene_menu ? (
    ui_scene_menu = 0;
  ) : ui_text_active > 0 ? (
    ui_text_active == 1 ? (
      strcpy(#target_manager, #p3d_edit_text);
      strlen(#target_manager) <= 0 ? strcpy(#target_manager, "Manager");
      strcpy(#p3d_edit_manager, #target_manager);
      ui_scene_menu = 0;
      p3d_rebind_pending = 1;
      p3d_bus_hash = p3d_hash_string(#target_manager);
      p3d_mgr_hold = 0;
      p3d_mgr_slot = -1;
      p3d_slot_index = -1;
    ) : ui_text_active == 2 ? (
      strcpy(#object_name, #p3d_edit_text);
      strlen(#object_name) <= 0 ? strcpy(#object_name, "Object");
      strcpy(#p3d_edit_name, #object_name);
      p3d_rebind_pending = 1;
    );
    ui_text_active = 0;
    ui_text_select_all = 0;
    sliderchange(-1.0);
  ) : hover_link_btn ? (
    slider4 = 1 - slider4;
    p3d_mgr_hold = 0;
    p3d_cached_manager_hb = -1;
    p3d_cached_manager_iid = 0;
    p3d_cached_manager_enabled = 0;
    p3d_cached_camera_rot = 0;
    p3d_cached_distance_scale = 1;
    p3d_rebind_pending = 1;
    p3d_allow_msg = 0;
    p3d_service_registry();
    sliderchange(-1.0);
  ) : hover_adv > 0 ? (
    ui_mode = 200 + hover_adv;
    ui_drag_start_x = mouse_x;
    ui_drag_start_v1 = hover_adv == 1 ? slider17 : hover_adv == 2 ? slider18 : slider19;
  ) : hover_safe ? (
    slider16 = 1 - slider16;
    sliderchange(-1.0);
  ) : hover_chip > 0 ? (
    snap_r = 0.78;
    hover_chip == 1 ? (slider6 = 0; slider8 = 0.82;) :
    hover_chip == 2 ? (a = -30*$pi/180; slider6 = sin(a)*snap_r; slider8 = cos(a)*snap_r;) :
    hover_chip == 3 ? (a = -45*$pi/180; slider6 = sin(a)*snap_r; slider8 = cos(a)*snap_r;) :
    hover_chip == 4 ? (a = -60*$pi/180; slider6 = sin(a)*snap_r; slider8 = cos(a)*snap_r;) :
    hover_chip == 5 ? (a = 30*$pi/180; slider6 = sin(a)*snap_r; slider8 = cos(a)*snap_r;) :
    hover_chip == 6 ? (a = 45*$pi/180; slider6 = sin(a)*snap_r; slider8 = cos(a)*snap_r;) :
    hover_chip == 7 ? (a = 60*$pi/180; slider6 = sin(a)*snap_r; slider8 = cos(a)*snap_r;) :
                         (slider6 = 0; slider8 = -0.82;);
    sliderchange(-1.0);
  ) : (near_src || inside_room) ? (
    ui_mode = 1;
    ui_drag_start_x = mouse_x;
    ui_drag_start_y = mouse_y;
    ui_drag_start_v1 = slider6;
    ui_drag_start_v2 = slider8;
    ui_drag_start_v3 = slider7;
  ) : hover_bar > 0 ? (
    ui_mode = 100 + hover_bar;
    ui_drag_bar = hover_bar;
    ui_drag_start_x = mouse_x;
    ui_drag_start_y = mouse_y;
    ui_drag_start_v1 =
      hover_bar == 1 ? slider6 :
      hover_bar == 2 ? slider8 :
      hover_bar == 3 ? slider7 :
      hover_bar == 4 ? slider9 :
      hover_bar == 5 ? slider10 :
      hover_bar == 6 ? slider11 :
      hover_bar == 7 ? slider12 :
      hover_bar == 8 ? slider13 :
      hover_bar == 9 ? slider14 : slider15;
  );
);

// --- drag actions ---
(mouse_l && ui_mode == 1) ? (
  mouse_alt ? (
    slider7 = ui_drag_start_v3 - (mouse_y - ui_drag_start_y) * 0.0028 / ui_s;
    slider7 < 0 ? slider7 = 0;
    slider7 > 1 ? slider7 = 1;
  ) : mouse_ctrl ? (
    slider6 = ui_drag_start_v1 + (mouse_x - ui_drag_start_x) * 0.0040 / ui_s;
    slider6 < -1 ? slider6 = -1;
    slider6 > 1 ? slider6 = 1;
  ) : mouse_shift ? (
    slider6 = ui_drag_start_v1 + (mouse_x - ui_drag_start_x) * 0.00135 / ui_s;
    slider8 = ui_drag_start_v2 - (mouse_y - ui_drag_start_y) * 0.00135 / ui_s;
    slider6 < -1 ? slider6 = -1; slider6 > 1 ? slider6 = 1;
    slider8 < -1 ? slider8 = -1; slider8 > 1 ? slider8 = 1;
    rr = sqrt(slider6*slider6 + slider8*slider8);
    rr > 1 ? (slider6 /= rr; slider8 /= rr;);
  ) : (
    dxn = (mouse_x - cx) / (room_hw*0.82);
    dyn = (cy - mouse_y) / (room_hd*0.82);
    rr = sqrt(dxn*dxn + dyn*dyn);
    rr > 1 ? (
      dxn /= rr;
      dyn /= rr;
    );
    slider6 = dxn;
    slider8 = dyn;
  );
  sliderchange(-1.0);
);

(mouse_l && ui_mode >= 101 && ui_mode < 200) ? (
  sid = ui_mode - 100;
  sid == 1 ? (mn=-1; mx=1;) :
  sid == 2 ? (mn=-1; mx=1;) :
  sid == 3 ? (mn=0; mx=1;) :
  sid == 4 ? (mn=0; mx=1;) :
  sid == 5 ? (mn=0; mx=1;) :
  sid == 6 ? (mn=0; mx=1;) :
  sid == 7 ? (mn=0; mx=1;) :
  sid == 8 ? (mn=0; mx=1;) :
  sid == 9 ? (mn=0; mx=1;) :
             (mn=-18; mx=12;);

  mouse_shift ? (
    v = ui_drag_start_v1 + (mouse_x - ui_drag_start_x) / barw * (mx - mn) * 0.25;
    v < mn ? v = mn;
    v > mx ? v = mx;
  ) : (
    nrm = (mouse_x - barx) / barw;
    nrm < 0 ? nrm = 0;
    nrm > 1 ? nrm = 1;
    v = mn + nrm * (mx - mn);
  );

  sid == 1 ? slider6 = v :
  sid == 2 ? slider8 = v :
  sid == 3 ? slider7 = v :
  sid == 4 ? slider9 = v :
  sid == 5 ? slider10 = v :
  sid == 6 ? slider11 = v :
  sid == 7 ? slider12 = v :
  sid == 8 ? slider13 = v :
  sid == 9 ? slider14 = v : slider15 = v;

  sliderchange(-1.0);
);

(mouse_l && ui_mode >= 201 && ui_mode < 300) ? (
  sid = ui_mode - 200;
  sid == 1 ? (mn=1; mx=3;) : sid == 2 ? (mn=5; mx=250;) : (mn=0; mx=1;);
  mouse_shift ? (
    v = ui_drag_start_v1 + (mouse_x - ui_drag_start_x) / adv_barw * (mx - mn) * 0.25;
  ) : (
    nrm = (mouse_x - adv_barx) / adv_barw;
    nrm < 0 ? nrm = 0; nrm > 1 ? nrm = 1;
    v = mn + nrm * (mx - mn);
  );
  v < mn ? v = mn; v > mx ? v = mx;
  sid == 1 ? slider17 = v : sid == 2 ? slider18 = v : slider19 = v;
  sliderchange(-1.0);
);


// finalize drag
(!mouse_l && ui_prev_l && ui_mode) ? (
  ui_mode = 0;
  ui_drag_bar = 0;
  sliderchange(-1.0);
);

ui_prev_l = mouse_l;
ui_prev_r = mouse_r;

// refresh for drawing after interaction
ui_base_lat = slider6;
ui_base_dist = slider7;
ui_base_fb = slider8;
ui_link_view = (slider4 >= 0.5 && last_manager_active) ? 1 : 0;
ui_lat = ui_link_view ? last_effective_lat : ui_base_lat;
ui_dist = ui_link_view ? last_effective_dist_n : ui_base_dist;
ui_fb = ui_link_view ? last_effective_fb : ui_base_fb;
ui_dist_vis = ui_dist;
ui_dist_vis < 0 ? ui_dist_vis = 0;
ui_dist_vis > 1 ? ui_dist_vis = 1;
ui_throw = slider9;
ui_size = slider10;
ui_push = slider11;
ui_room = slider12;
ui_occ = slider13;
ui_motion = slider14;
ui_trim = slider15;
ui_safe = slider16 >= 0.5 ? 1 : 0;
ui_curve = slider17;
ui_smooth = slider18;
ui_rsize = slider19;
ui_link = slider4 >= 0.5 ? 1 : 0;
ui_obj_id = floor(slider3 + 0.5);
ui_mgr_amt = slider5;
ui_target_mgr = floor(slider20 + 0.5);

pos_r = sqrt(ui_lat*ui_lat + ui_fb*ui_fb);
pos_r > 1 ? (
  draw_lat = ui_lat / pos_r;
  draw_fb = ui_fb / pos_r;
  draw_r = 1;
) : (
  draw_lat = ui_lat;
  draw_fb = ui_fb;
  draw_r = pos_r;
);
sx = cx + draw_lat * room_hw * 0.82;
sy = cy - draw_fb  * room_hd * 0.82;
cue_rad = last_cue_az * $pi/180;
ghost_x = sin(cue_rad) * draw_r;
ghost_y = cos(cue_rad) * draw_r;
gsx = cx + ghost_x * room_hw * 0.82;
gsy = cy - ghost_y * room_hd * 0.82;

// bounce points on room walls, visual coordinate
src_nx = draw_lat * 0.82;
src_ny = draw_fb * 0.82;

tL = (-1 - src_nx) / (-2 - src_nx + 0.000000000000000001);
bLx = -1;
bLy = src_ny + tL * (0 - src_ny);

tR = (1 - src_nx) / (2 - src_nx + 0.000000000000000001);
bRx = 1;
bRy = src_ny + tR * (0 - src_ny);

tF = (1 - src_ny) / (2 - src_ny + 0.000000000000000001);
bFx = src_nx + tF * (0 - src_nx);
bFy = 1;

tB = (-1 - src_ny) / (-2 - src_ny + 0.000000000000000001);
bBx = src_nx + tB * (0 - src_nx);
bBy = -1;

bpLx = cx + bLx * room_hw; bpLy = cy - bLy * room_hd;
bpRx = cx + bRx * room_hw; bpRy = cy - bRy * room_hd;
bpFx = cx + bFx * room_hw; bpFy = cy - bFy * room_hd;
bpBx = cx + bBx * room_hw; bpBy = cy - bBy * room_hd;

// --- colors ---
bg_r=0.056; bg_g=0.064; bg_b=0.078;
panel_r=0.100; panel_g=0.112; panel_b=0.140;
card_r=0.126; card_g=0.140; card_b=0.174;
line_r=0.235; line_g=0.260; line_b=0.320;
txt_r=0.94; txt_g=0.95; txt_b=0.98;
mut_r=0.56; mut_g=0.61; mut_b=0.69;
src_cr=0.97; src_cg=0.67; src_cb=0.16;
bounce_r=0.33; bounce_g=0.80; bounce_b=0.98;
occ_cr=0.83; occ_cg=0.38; occ_cb=0.96;
ok_r=0.58; ok_g=0.78; ok_b=0.51;
warn_r=0.96; warn_g=0.48; warn_b=0.18;

// --- background ---
gfx_set(bg_r,bg_g,bg_b,1); gfx_rect(0,0,gfx_w,gfx_h,1);

// fonts
fs1 = floor(18*ui_s); fs2 = floor(12*ui_s); fs3 = floor(10*ui_s); fs4 = floor(9*ui_s);
fs1 < 12 ? fs1 = 12; fs2 < 10 ? fs2 = 10; fs3 < 9 ? fs3 = 9; fs4 < 8 ? fs4 = 8;

// title
gfx_setfont(1,"Arial",fs1,'b');
gfx_set(txt_r,txt_g,txt_b,1);
gfx_x = pad; gfx_y = pad*0.45; gfx_printf("Hyperreal 3D Panner V6.13.0");

gfx_setfont(2,"Arial",fs2);
gfx_set(mut_r,mut_g,mut_b,1);
gfx_x = pad; gfx_y = pad*0.45 + fs1 + 1*ui_s;
gfx_printf("UI-only GFX controls | standalone by default | opt-in Manager Mode | runtime IPC");

(ui_link) ? (
  gfx_set(last_manager_active ? ok_r : warn_r, last_manager_active ? ok_g : warn_g, last_manager_active ? ok_b : warn_b, 0.95);
  gfx_x = gfx_w - 286*ui_s; gfx_y = pad*0.45 + 2*ui_s;
  last_manager_active ? gfx_printf("MANAGER  Obj %02.0f  Cam %+.1f deg", last_object_id, last_camera_rot) : gfx_printf("MANAGER ARMED  Obj %02.0f", last_object_id);
);

// main surfaces
gfx_set(panel_r,panel_g,panel_b,1);
gfx_rect(canvas_x, canvas_y, canvas_w, canvas_h);
gfx_roundrect(canvas_x, canvas_y, canvas_w, canvas_h, 14*ui_s, 1);
gfx_rect(c1x, c1y, c1w, c1h);
gfx_roundrect(c1x, c1y, c1w, c1h, 12*ui_s, 1);
gfx_rect(c2x, c2y, c2w, c2h);
gfx_roundrect(c2x, c2y, c2w, c2h, 12*ui_s, 1);
gfx_rect(c3x, c3y, c3w, c3h);
gfx_roundrect(c3x, c3y, c3w, c3h, 12*ui_s, 1);

// canvas inner
gfx_set(0.082,0.090,0.112,1);
gfx_rect(canvas_x+8*ui_s, canvas_y+8*ui_s, canvas_w-16*ui_s, canvas_h-16*ui_s);
gfx_roundrect(canvas_x+8*ui_s, canvas_y+8*ui_s, canvas_w-16*ui_s, canvas_h-16*ui_s, 12*ui_s, 1);

// stage room
gfx_set(0.112,0.124,0.158,1);
gfx_rect(room_l, room_t, room_hw*2, room_hd*2);
gfx_roundrect(room_l, room_t, room_hw*2, room_hd*2, 10*ui_s, 1);
gfx_set(0.38,0.43,0.52,0.95);
gfx_roundrect(room_l, room_t, room_hw*2, room_hd*2, 10*ui_s, 0);

// grid
gfx_set(0.23,0.26,0.33,0.55);
gfx_line(cx-room_hw, cy, cx+room_hw, cy);
gfx_line(cx, cy-room_hd, cx, cy+room_hd);
gfx_line(cx-room_hw*0.5, room_t, cx-room_hw*0.5, room_b);
gfx_line(cx+room_hw*0.5, room_t, cx+room_hw*0.5, room_b);
gfx_line(room_l, cy-room_hd*0.5, room_r, cy-room_hd*0.5);
gfx_line(room_l, cy+room_hd*0.5, room_r, cy+room_hd*0.5);

// snap rays
gfx_set(0.30,0.34,0.42,0.35);
a=-60*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=-45*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=-30*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=30*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=45*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);
a=60*$pi/180; gfx_line(cx,cy,cx+sin(a)*room_hw*0.82,cy-cos(a)*room_hd*0.82);

// room labels
gfx_setfont(3,"Arial",fs3,'b');
gfx_set(0.73,0.79,0.87,0.95);
gfx_x = cx - 30*ui_s; gfx_y = room_t - 16*ui_s; gfx_printf("FRONT");
gfx_x = room_l - 18*ui_s; gfx_y = cy - 5*ui_s; gfx_printf("L");
gfx_x = room_r + 10*ui_s; gfx_y = cy - 5*ui_s; gfx_printf("R");
gfx_set(0.70,0.58,0.85,0.95);
gfx_x = cx - 24*ui_s; gfx_y = room_b + 5*ui_s; gfx_printf("REAR");

// --- visual cue: Distance = range rings + air dashes, not a bigger source ---
range_min = min(room_hw, room_hd);
range_r1 = range_min * 0.25;
range_r2 = range_min * 0.50;
range_r3 = range_min * 0.75;
range_active = range_min * (0.18 + 0.70*ui_dist_vis);

// static reference rings
gfx_set(0.70,0.74,0.84,0.10); gfx_circle(cx,cy,range_r1,0,1);
gfx_set(0.70,0.74,0.84,0.08); gfx_circle(cx,cy,range_r2,0,1);
gfx_set(0.70,0.74,0.84,0.06); gfx_circle(cx,cy,range_r3,0,1);

// active distance ring brightens and expands with Distance
gfx_set(0.78,0.82,0.92,0.13 + 0.14*ui_dist_vis);
gfx_circle(cx,cy,range_active,0,1);

// small distance tick marks along the placement ray
seg_n = 5;
seg_i = 1;
loop(seg_n,
  seg_t = seg_i / (seg_n + 1);
  seg_x = cx + (sx-cx) * seg_t;
  seg_y = cy + (sy-cy) * seg_t;
  seg_a = (0.05 + 0.18*ui_dist_vis) * seg_t;
  gfx_set(0.78,0.82,0.92,seg_a);
  gfx_circle(seg_x, seg_y, (1.5 + 2.8*ui_dist_vis)*ui_s, 1, 1);
  seg_i += 1;
);

gfx_setfont(4,"Arial",fs4);
gfx_set(0.70,0.74,0.84,0.48);
gfx_x = room_l + 8*ui_s; gfx_y = room_b - 18*ui_s; gfx_printf("CLOSE");
gfx_x = cx - 10*ui_s; gfx_y = room_b - 18*ui_s; gfx_printf("MID");
gfx_x = room_r - 28*ui_s; gfx_y = room_b - 18*ui_s; gfx_printf("FAR");

// --- visual cue: Room = wall glow strength ---
(ui_room > 0.001) ? (
  glow_i = 0;
  loop(3,
    glow_o = (glow_i + 1) * 2.0*ui_s;
    glow_a = ui_room * (0.20 - glow_i*0.045);
    gfx_set(bounce_r,bounce_g,bounce_b,glow_a);
    gfx_roundrect(room_l-glow_o, room_t-glow_o, room_hw*2+glow_o*2, room_hd*2+glow_o*2, 10*ui_s+glow_o, 0);
    glow_i += 1;
  );
);

// direct visual path
gfx_set(src_cr,src_cg,src_cb,0.58 + 0.20*(1-ui_dist_vis));
gfx_line(cx, cy, sx, sy);

// cue ghost path
gfx_set(src_cr,src_cg,src_cb,0.22 + 0.12*ui_throw);
gfx_line(cx, cy, gsx, gsy);

// --- visual cue: Room = cyan early-bounce paths and wall-hit markers ---
bounce_a = 0.04 + 0.72*ui_room;
gfx_set(bounce_r,bounce_g,bounce_b,bounce_a);
gfx_line(sx, sy, bpLx, bpLy); gfx_line(bpLx, bpLy, cx, cy);
gfx_line(sx, sy, bpRx, bpRy); gfx_line(bpRx, bpRy, cx, cy);
gfx_line(sx, sy, bpFx, bpFy); gfx_line(bpFx, bpFy, cx, cy);
gfx_line(sx, sy, bpBx, bpBy); gfx_line(bpBx, bpBy, cx, cy);

// secondary stronger trace at high Room, gives a thicker-looking reflection web
(ui_room > 0.55) ? (
  gfx_set(bounce_r,bounce_g,bounce_b,(ui_room-0.55)*0.55);
  gfx_line(sx+1*ui_s, sy, bpLx+1*ui_s, bpLy); gfx_line(bpLx+1*ui_s, bpLy, cx+1*ui_s, cy);
  gfx_line(sx-1*ui_s, sy, bpRx-1*ui_s, bpRy); gfx_line(bpRx-1*ui_s, bpRy, cx-1*ui_s, cy);
  gfx_line(sx, sy+1*ui_s, bpFx, bpFy+1*ui_s); gfx_line(bpFx, bpFy+1*ui_s, cx, cy+1*ui_s);
  gfx_line(sx, sy-1*ui_s, bpBx, bpBy-1*ui_s); gfx_line(bpBx, bpBy-1*ui_s, cx, cy-1*ui_s);
);

// bounce markers fade down when Room is low; they no longer imply reflections are active at 0
bm_r = 2.5*ui_s + 5.2*ui_s*ui_room;
bm_a = 0.16 + 0.82*ui_room;
gfx_set(bounce_r,bounce_g,bounce_b,bm_a);
gfx_circle(bpLx, bpLy, bm_r, 1, 1);
gfx_circle(bpRx, bpRy, bm_r, 1, 1);
gfx_circle(bpFx, bpFy, bm_r, 1, 1);
gfx_circle(bpBx, bpBy, bm_r, 1, 1);

(ui_room > 0.30) ? (
  gfx_set(bounce_r,bounce_g,bounce_b,0.12 + 0.24*ui_room);
  gfx_circle(bpLx, bpLy, bm_r + 4.0*ui_s*ui_room, 0, 1);
  gfx_circle(bpRx, bpRy, bm_r + 4.0*ui_s*ui_room, 0, 1);
  gfx_circle(bpFx, bpFy, bm_r + 4.0*ui_s*ui_room, 0, 1);
  gfx_circle(bpBx, bpBy, bm_r + 4.0*ui_s*ui_room, 0, 1);
);

// occlusion wedge
(ui_occ > 0.001) ? (
  bx = cx + (sx-cx)*0.56;
  by = cy + (sy-cy)*0.56;
  wx = (sy-cy) * 0.09 * ui_occ;
  wy = -(sx-cx) * 0.09 * ui_occ;
  ax = cx + (sx-cx)*0.23;
  ay = cy + (sy-cy)*0.23;
  gfx_set(occ_cr,occ_cg,occ_cb,0.48 + 0.22*ui_occ);
  gfx_triangle(ax,ay, bx+wx,by+wy, bx-wx,by-wy);
);

// --- visual cue: Push Out = listener externalization shell, not distance ---
head_r = 17*ui_s;
(ui_push > 0.001) ? (
  shell_r = head_r + (10 + 52*ui_push)*ui_s;
  shell_a = 0.06 + 0.22*ui_push;
  gfx_set(src_cr,src_cg,src_cb,shell_a);
  gfx_circle(cx, cy, shell_r, 0, 1);
  gfx_set(bounce_r,bounce_g,bounce_b,0.04 + 0.16*ui_push);
  gfx_circle(cx, cy, shell_r + 8*ui_s, 0, 1);

  // faint ear-to-source separation rays appear only as Push Out rises
  ear_a = 0.05 + 0.16*ui_push;
  gfx_set(src_cr,src_cg,src_cb,ear_a);
  gfx_line(cx-21*ui_s, cy, sx, sy);
  gfx_line(cx+21*ui_s, cy, sx, sy);
);

// cue ghost = effective DSP position after Spatial Throw/Cue Curve compression
ghost_r = dot_r*0.72;
gfx_set(src_cr,src_cg,src_cb,0.12 + 0.20*ui_throw);
gfx_circle(gsx, gsy, ghost_r, 1, 1);
gfx_set(src_cr,src_cg,src_cb,0.45 + 0.35*ui_throw);
gfx_circle(gsx, gsy, ghost_r + 3*ui_s, 0, 1);

// --- visual cue: Motion = green fading trail around source ---
(ui_motion > 0.002) ? (
  trail_n = 11;
  trail_i = 0;
  trail_amp = (4 + 28*ui_motion)*ui_s;
  trail_phase = ph1*0.70 + ph2*0.33;
  loop(trail_n,
    trail_t = trail_i / (trail_n - 1);
    trail_a = trail_phase - trail_t*(1.45 + 2.20*ui_motion)*$pi;
    trail_rr = trail_amp * (0.35 + 0.65*trail_t);
    tx = sx + cos(trail_a) * trail_rr;
    ty = sy + sin(trail_a) * trail_rr * 0.58;
    ta = (0.06 + 0.30*ui_motion) * (1 - trail_t);
    gfx_set(ok_r,ok_g,ok_b,ta);
    gfx_circle(tx, ty, (1.2 + 2.4*ui_motion)*ui_s, 1, 1);
    trail_i += 1;
  );
  gfx_set(ok_r,ok_g,ok_b,0.08 + 0.18*ui_motion);
  gfx_circle(sx, sy, trail_amp, 0, 1);
);

// --- visual cue: Size = orange source extent / diffusion ---
size_pow = ui_size^0.72;
halo_r = dot_r + (8 + 46*size_pow)*ui_s;
halo_a = 0.05 + 0.24*ui_size;
gfx_set(src_cr,src_cg,src_cb,halo_a);
gfx_circle(sx, sy, halo_r, 0, 1);
gfx_set(src_cr,src_cg,src_cb,0.04 + 0.14*ui_size);
gfx_circle(sx, sy, halo_r*0.58, 0, 1);

(ui_size > 0.12) ? (
  cloud_n = floor(4 + 14*ui_size);
  cloud_i = 0;
  loop(cloud_n,
    cloud_t = cloud_i / (cloud_n + 0.000001);
    ca = cloud_t*2*$pi + 0.55;
    cr = halo_r * (0.24 + 0.58*(cloud_i + 1)/(cloud_n + 1));
    px = sx + cos(ca)*cr;
    py = sy + sin(ca)*cr*0.68;
    pa = (0.06 + 0.20*ui_size) * (0.55 + 0.45*(cloud_n - cloud_i)/(cloud_n + 1));
    gfx_set(src_cr,src_cg,src_cb,pa);
    gfx_circle(px, py, (1.2 + 2.5*ui_size)*ui_s, 1, 1);
    cloud_i += 1;
  );
);

// focus crosshair fades out as Size becomes diffuse
focus_a_ui = 0.62 * (1 - ui_size);
(focus_a_ui > 0.02) ? (
  gfx_set(1,1,1,focus_a_ui);
  gfx_line(sx-13*ui_s, sy, sx+13*ui_s, sy);
  gfx_line(sx, sy-13*ui_s, sx, sy+13*ui_s);
);

// main source orb: size changes mildly; distance only dims the edge, avoiding size/distance confusion
core_a = 1 - 0.16*ui_dist_vis;
gfx_set(src_cr,src_cg,src_cb,core_a);
gfx_circle(sx, sy, dot_r, 1, 1);
gfx_set(1,0.88,0.55,0.35 + 0.20*(1-ui_dist_vis));
gfx_circle(sx, sy, dot_r + 1.8*ui_s, 0, 1);
gfx_set(0.12,0.12,0.13,1); gfx_circle(sx, sy, 2.6*ui_s, 1, 1);

// listener
gfx_set(0.60,0.66,0.76,1);
gfx_circle(cx, cy, head_r, 0, 1);
gfx_circle(cx-21*ui_s, cy, 5.1*ui_s, 0, 1);
gfx_circle(cx+21*ui_s, cy, 5.1*ui_s, 0, 1);
gfx_line(cx, cy-head_r, cx, cy-(head_r+9*ui_s));

// legend / readout on canvas
gfx_setfont(4,"Arial",fs4);
gfx_set(bounce_r,bounce_g,bounce_b,0.95);
gfx_x = canvas_x + 14*ui_s; gfx_y = canvas_y + 12*ui_s; gfx_printf("cyan = Room bounces");
gfx_set(src_cr,src_cg,src_cb,0.95);
gfx_x = canvas_x + 14*ui_s; gfx_y = canvas_y + 12*ui_s + fs4 + 4*ui_s; gfx_printf("orange halo = Size | ghost = cue");
gfx_set(0.78,0.82,0.92,0.82);
gfx_x = canvas_x + 14*ui_s; gfx_y = canvas_y + 12*ui_s + (fs4 + 4*ui_s)*2; gfx_printf("rings = Distance | shell = Push Out");
gfx_set(ok_r,ok_g,ok_b,0.82);
gfx_x = canvas_x + 14*ui_s; gfx_y = canvas_y + 12*ui_s + (fs4 + 4*ui_s)*3; gfx_printf("green trail = Motion");

// chips
gfx_setfont(4,"Arial",fs4,'b');

active = hover_chip==1;
gfx_set(active ? 0.22 : 0.15, active ? 0.24 : 0.17, active ? 0.30 : 0.22, 0.96);
gfx_rect(chip1x,chip_y,chip_w,chip_h); gfx_roundrect(chip1x,chip_y,chip_w,chip_h,7*ui_s,1);
